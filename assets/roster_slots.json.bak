        "variants": [
            {
                "name": "Ike",
                "boxing_ring_title": "The Radiant Hero of Legend",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Ike's Origins",
                "content": "Ike debuted in Fire Emblem: Path of Radiance, a 2005 title for the Nintendo GameCube. He's a strong fighter who wields a two-handed sword with ease.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Leader of the Greil Mercenaries. He's stoic and doesn't say much, but he's also kind and compassionate. He's the protagonist of Fire Emblem: Path of Radiance and appears in Fire Emblem: Radiant Dawn.",
                "level": "Beginner"
            },
            {
                "title": "Radiance and Radiant",
                "content": "Ike's odd-numbered costumes are from Fire Emblem: Path of Radiance, while the even-numbered costumes are from Fire Emblem: Radiant Dawn. The two look and sound different, but they're equally strong.",
                "level": "Beginner"
            },
            {
                "title": "Eruption (Neutral Special)",
                "content": "Charge this move by pressing and holding the button. Additional flames appear depending on the charge level. At full charge, it sends three pillars, allowing you to hit somewhat distant opponents.",
                "level": "Beginner"
            },
            {
                "title": "Eruption at the Edge (Neutral Special)",
                "content": "This attack reaches up and down as well as left and right. You can use it to ambush opponents who are trying to recover from offstage.",
                "level": "Beginner"
            },
            {
                "title": "Quick Draw (Side Special)",
                "content": "If you hit an opponent with Quick Draw in the air, you can quickly start your next action. But if you don't do anything afterward, Ike merely falls. Keep this in mind when trying to recover.",
                "level": "Beginner"
            },
            {
                "title": "Quick Draw's Traits (Side Special)",
                "content": "Using this move a bit before landing from a jump and you will reduce the amount of time you are vulnerable.",
                "level": "Beginner"
            },
            {
                "title": "Aether and Super Armor (Up Special)",
                "content": "Ike will be protected from flinching while he prepares this attack. This move can send foes flying upward!",
                "level": "Advanced"
            },
            {
                "title": "Meteor with Aether (Up Special)",
                "content": "During the downward strike, this attack has a meteor effect. You'll fall straight down until you hit solid ground, so make sure you aim well!",
                "level": "Advanced"
            },
            {
                "title": "Counter (Down Special)",
                "content": "If an opponent attacks while Ike's in his stance, it'll nullify the attack and Ike will counterattack. The power of the counterattack is based on the power of the opponent's attack.",
                "level": "Beginner"
            },
            {
                "title": "Great Aether (Final Smash)",
                "content": "This sweeping move can be used on the ground or in the air, and can catch opponents in front of Ike and above Ike. The final slash can also damage nearby opponents when it hits the ground.",
                "level": "Beginner"
            },
            {
                "title": "Neutral Attack",
                "content": "There are three levels of attack: a punch, a kick, and a sword swing. All pretty handy, since they're quicker than Ike's other moves!",
                "level": "Beginner"
            },
            {
                "title": "Cast Off (Down Smash Attack)",
                "content": "The backward strike of Ike's down smash is most powerful at the start of the move, dealing more damage and launching a foe farther than the forward strike.",
                "level": "Advanced"
            },
            {
                "title": "Repositioning Slash (Back Air Attack)",
                "content": "This is the quickest of all Ike's air attacks, and one of the most damaging too. A valuable weapon for a fighter whose attacks tend to be slow.",
                "level": "Intermediate"
            },
            {
                "title": "Rising Swing (Up Air Attack)",
                "content": "This attack covers a wide vertical and horizontal range, allowing you to hit opponents even if they're a little ways away. Try to follow up with this attack after using neutral air, down throw, or up throw.",
                "level": "Beginner"
            },
            {
                "title": "Repeated Edge Grabbing",
                "content": "Certain moves, such as Ike's Aether, have limits on how many times they can be used to grab on to edges without touching the ground.",
                "level": "Intermediate"
            }
        ],
        "fighters": [
