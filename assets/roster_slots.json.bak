        "variants": [
            {
                "name": "Duck Hunt",
                "boxing_ring_title": "Bark, Quack, Boom!",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Duck Hunt's Origins",
                "content": "Duck Hunt was released on the NES in North America in 1985, but did you know Nintendo released another toy in Japan with the same title in the '70s?",
                "level": "Beginner"
            },
            {
                "title": "In Their Series",
                "content": "Duck Hunt for the NES was played using the special NES Zapper. In that game, you hunted ducks that flew out of bushes, and the dog would collect them.",
                "level": "Beginner"
            },
            {
                "title": "Duck Hunt's Sales",
                "content": "The game Duck Hunt sold over 28 million copies worldwide. A big contribution to this was its inclusion as a pack-in title with the NES console.",
                "level": "Beginner"
            },
            {
                "title": "Trick Shot (Neutral Special)",
                "content": "This move kicks an exploding can toward your enemies. Keep pressing the button to fire shots that move the can forward.",
                "level": "Beginner"
            },
            {
                "title": "Risks with Trick Shot (Neutral Special)",
                "content": "If the Duck Hunt dog and duck are near the can when it's shot, the duo will crouch down and cover their eyes, leaving them vulnerable for a moment.",
                "level": "Beginner"
            },
            {
                "title": "Trick Shot Anytime (Neutral Special)",
                "content": "Even while grabbing opponents, being grabbed, or using Duck Jump, you can keep shooting the can.",
                "level": "Intermediate"
            },
            {
                "title": "Trick Shot Techniques (Neutral Special)",
                "content": "You can move the can by shooting it with the special-move button or by hitting it with other attacks. Try to position the can in an advantageous position while you move around the stage.",
                "level": "Beginner"
            },
            {
                "title": "Clay Shooting (Side Special)",
                "content": "The clay pigeon's speed will change if you're on the move. Tap the special-move button a second time for the gunman to open fire, hurting nearby foes if he hits.",
                "level": "Beginner"
            },
            {
                "title": "Duck Jump (Up Special)",
                "content": "The duck grabs the dog and carries him through the air. You're very vulnerable while in the air. You can cancel with attacks or with a midair dodge once a bit of time passes after initiating the move.",
                "level": "Beginner"
            },
            {
                "title": "Wild Gunman (Down Special)",
                "content": "This move summons a pixelated gunman who shoots straight ahead. The gunman selected is random, and each one works a little differently.",
                "level": "Beginner"
            },
            {
                "title": "Defeated Wild Gunman (Down Special)",
                "content": "The gunmen can be defeated if they take enough damage. For a surprise, hit the one in a black suit near the top or hit the lanky one near the bottom!",
                "level": "Intermediate"
            },
            {
                "title": "Wild Gunman Order (Down Special)",
                "content": "The gunmen's order is random, but all five will take a turn before cycling. Remember the first four, and you can predict the last one!",
                "level": "Beginner"
            },
            {
                "title": "Wild Gunman Attack Power (Down Special)",
                "content": "The gunmen's firepower, from best to worst: the sombrero guy, the cool leader, the guy in a suit, and then a tie between the lanky and beardy ones.",
                "level": "Advanced"
            },
            {
                "title": "Wild Gunman Range (Down Special)",
                "content": "The lanky gunman has a longer range than any of the others, and the one in the sombrero has the shortest range. The others are pretty much equal.",
                "level": "Advanced"
            },
            {
                "title": "Wild Gunman Speed (Down Special)",
                "content": "The gunmen from fastest to slowest: the cool leader (earning that title!), the one in a suit, the one in a sombrero, the beardy one, and then the lanky one.",
                "level": "Advanced"
            },
            {
                "title": "NES Zapper Posse (Final Smash)",
                "content": "Three games from the Light Gun Series team up: Duck Hunt, Hogan's Alley, and Wild Gunman.",
                "level": "Beginner"
            },
            {
                "title": "Zapper (Side Smash)",
                "content": "You can charge it up to extend the range a bit, which may catch opponents off guard if they don't expect it to reach that far.",
                "level": "Beginner"
            },
            {
                "title": "Wild Duck (Up Air Attack)",
                "content": "The duck will peck upward three times. The last peck has good launch power, so use it as a finisher.",
                "level": "Beginner"
            },
            {
                "title": "Can and Clay Pigeons",
                "content": "While the clay pigeon is flying, you cannot take out the can with Trick Shot. However, you can use a clay pigeon after taking out a can.",
                "level": "Beginner"
            }
        ],
        "fighters": [
