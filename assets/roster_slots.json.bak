        "variants": [
            {
                "name": "Jigglypuff",
                "boxing_ring_title": "The Sleepy Singer",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Jigglypuff's Origins",
                "content": "Jigglypuff has been singing its opponents to sleep in North America since its debut in the 1998 Game Boy games Pokémon Red and Pokémon Blue.",
                "level": "Beginner"
            },
            {
                "title": "In Its Series",
                "content": "Jigglypuff, a Balloon Pokémon, first appeared in Pokémon Red and Pokémon Blue. Starting with Pokémon X and Pokémon Y, Jigglypuff gained the new Fairy-type classification as well.",
                "level": "Beginner"
            },
            {
                "title": "Rollout's Vulnerability (Neutral Special)",
                "content": "When you hit a foe with this, you'll bounce up and then only be able to move sideways until you land. Try to avoid hitting foes with it if you're trying to recover!",
                "level": "Intermediate"
            },
            {
                "title": "Turning with Rollout (Neutral Special)",
                "content": "While rolling on the ground, press in the opposite direction to make a quick turn. It won't work if you're airborne, but it'll slow you down.",
                "level": "Beginner"
            },
            {
                "title": "Pound (Side Special)",
                "content": "A simple punch that travels horizontally. You can use it repeatedly in midair—combine it with jumps to stay aloft for a very long time.",
                "level": "Intermediate"
            },
            {
                "title": "Using Pound (Side Special)",
                "content": "This move can lay waste to opponents' shields. You can adjust the direction slightly by inputting up or down in the air right before attacking.",
                "level": "Intermediate"
            },
            {
                "title": "Sing (Up Special)",
                "content": "Enemies on the ground who hear this song will fall asleep. The more damage they have, the longer they'll nap.",
                "level": "Beginner"
            },
            {
                "title": "Pursue with Sing (Up Special)",
                "content": "If Jigglypuff uses Sing in midair, it can move left or right slightly. You can use this to chase after an opponent who evaded your attack or use it to get back onstage when the edge is just out of reach.",
                "level": "Intermediate"
            },
            {
                "title": "Rest (Down Special)",
                "content": "This move is hard to hit with but can really send opponents flying! You'll need to get very close or use it right when your opponent tries to attack.",
                "level": "Beginner"
            },
            {
                "title": "Rest Techniques (Down Special)",
                "content": "Jigglypuff can move again just a little sooner when it hits something compared to when it misses. This means that landing a hit instead of whiffing makes it harder for your opponent to counterattack.",
                "level": "Intermediate"
            },
            {
                "title": "Farewell Gift (Down Special)",
                "content": "Opponents launched by Rest will get a flower on their heads. Talk about insult to injury.",
                "level": "Intermediate"
            },
            {
                "title": "Puff Up (Final Smash)",
                "content": "Jigglypuff grows huge before launching nearby opponents. It's easy to escape on some stages, but it's a force to be reckoned with on stages with no place to escape, such as Battlefield.",
                "level": "Beginner"
            },
            {
                "title": "Jiggly Split (Down Smash Attack)",
                "content": "This move attacks in front of you and behind you at the same time, and your legs are invincible as they kick. It launches foes horizontally.",
                "level": "Intermediate"
            },
            {
                "title": "Jiggly Ram (Dash Attack)",
                "content": "When done on an opponent who hasn't taken much damage, you might find yourself open to counterattack, but when done on an opponent who's taken a lot of damage, you might get a KO.",
                "level": "Beginner"
            },
            {
                "title": "Shield",
                "content": "If its shield is shattered, Jigglypuff will get launched and KO'd no matter its damage.",
                "level": "Intermediate"
            },
            {
                "title": "Aerial Expert",
                "content": "Once in the air, Jigglypuff can jump five times, allowing it to move much quicker than running on the ground. Try to keep opponents in the air and build an advantageous scenario for yourself during battles.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "12",
                "name": "Jigglypuff",
                "slug": "jigglypuff",
                "also_appears_in": [
                    "64",
                    "Melee",
                    "Brawl",
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
