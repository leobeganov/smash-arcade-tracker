        "variants": [
            {
                "name": "Kirby",
                "boxing_ring_title": "The Pink Demon",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Kirby's Origins",
                "content": "Kirby made his debut in 1992 in Kirby's Dream Land for the Game Boy. The goal of his journey was to recover stolen food from King Dedede.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Kirby is a big eater who inhales any and everything. If he inhales an enemy, he can copy and use one of their abilities. He's also good at hovering by flapping his arms and puffing up like a balloon.",
                "level": "Beginner"
            },
            {
                "title": "Kirby's Copy Abilities",
                "content": "Kirby hasn't always been able to copy the abilities of the enemies he inhaled. That power debuted in his second title, Kirby's Adventure.",
                "level": "Beginner"
            },
            {
                "title": "Beginners and Experts Alike",
                "content": "The original Kirby game, Kirby's Dream Land, was designed to be easy for beginners to play, but finishing it unlocks a more challenging mode.",
                "level": "Beginner"
            },
            {
                "title": "Multiplayer Kirby",
                "content": "Kirby Super Star on the SNES was the first Kirby game where two players could team up.",
                "level": "Beginner"
            },
            {
                "title": "Inhale (Neutral Special)",
                "content": "If you press the attack button after sucking enemies in, you'll spit them back out. Use enemies to attack other enemies!",
                "level": "Beginner"
            },
            {
                "title": "Inhale Items (Neutral Special)",
                "content": "In addition to enemies, Kirby can inhale some items. You'll recover a little damage this way, but sucking in explosives will hurt!",
                "level": "Intermediate"
            },
            {
                "title": "Inhale's Projectiles (Neutral Special)",
                "content": "After Kirby inhales a fighter, he'll spit them out as a star-shaped projectile. The heavier the fighter, the more attack power the projectile will have.",
                "level": "Beginner"
            },
            {
                "title": "Hammer Flip (Side Special)",
                "content": "If fully charged, this move becomes very powerful, but Kirby will begin to take damage at full charge.",
                "level": "Beginner"
            },
            {
                "title": "Charged Up Hammer Flip (Side Special)",
                "content": "When Hammer Flip is fully charged and used on the ground, Kirby is invincible for a brief moment at the start of his swing.",
                "level": "Advanced"
            },
            {
                "title": "Final Cutter (Up Special)",
                "content": "Kirby slices up into the air and then slices straight down again. The shock wave that appears when you land can also damage your opponents.",
                "level": "Beginner"
            },
            {
                "title": "Canceling Stone (Down Special)",
                "content": "While falling, you can cancel the attack by pressing the special-move button again. It's a perfect way to trick other players!",
                "level": "Intermediate"
            },
            {
                "title": "Stone Transformation (Down Special)",
                "content": "Kirby's form is different each time he uses this, but the move's effect is the same.",
                "level": "Beginner"
            },
            {
                "title": "Ultra Sword (Final Smash)",
                "content": "This Final Smash uses Ultra Sword to lay into opponents with a flurry of slashes. It cuts through terrain and covers a huge area, making it easy to catch nearby opponents.",
                "level": "Beginner"
            },
            {
                "title": "Squish Kick (Down Tilt Attack)",
                "content": "This attack can sometimes cause an opponent to take a tumble. Watch your opponent carefully. If they start to fall over, follow up with a grab or smash attack.",
                "level": "Beginner"
            },
            {
                "title": "Burning (Dash Attack)",
                "content": "Kirby twists through the air like a flaming screw as he charges into an opponent. He's not a reckless fellow, so he'll automatically stop at edges instead of going over them.",
                "level": "Beginner"
            },
            {
                "title": "Lucario Copy Ability",
                "content": "Kirby gains the ability to use Aura Sphere from Lucario. No matter how high his damage gets, though, the attack won't get any stronger.",
                "level": "Intermediate"
            },
            {
                "title": "Rosalina & Luma Copy Ability",
                "content": "Kirby gets a Luma of his very own after inhaling Rosalina! It doesn't stay long enough to team up with him, though—it flies forward and then vanishes.",
                "level": "Intermediate"
            },
            {
                "title": "Miinhale",
                "content": "When Kirby inhales and copies a Mii Fighter, he'll wear a mask that looks like the Mii Fighter's face. Only the face itself is taken, though—headgear not included.",
                "level": "Intermediate"
            },
            {
                "title": "Copy Copying",
                "content": "Kirby can steal a Copy Ability from another Kirby who's already copied someone else's ability. Confused yet?",
                "level": "Advanced"
            },
            {
                "title": "Copying Another Kirby",
                "content": "If Kirby inhales another Kirby that doesn't have a Copy Ability, nothing will happen. However, if Kirby inhales another Kirby that does have a Copy Ability, Kirby can steal the inhaled Kirby's ability.",
                "level": "Beginner"
            },
            {
                "title": "Taunt",
                "content": "Taunt to discard your current Copy Ability. Find the most opportune moment to change your ability!",
                "level": "Beginner"
            },
            {
                "title": "Jump",
                "content": "Kirby's light body lets him jump six times—more than most other fighters. If Kirby gets launched but not KO'd, you can almost bet he's coming back!",
                "level": "Beginner"
            },
            {
                "title": "The Jump Masters",
                "content": "#1 is a tie between Jigglypuff, Meta Knight, and Kirby, who can all manage six. #4 is King Dedede with five, and Pit and Dark Pit are tied at #5 with four.",
                "level": "Beginner"
            }
        ],
        "fighters": [
