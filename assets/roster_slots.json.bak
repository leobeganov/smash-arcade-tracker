        "also_appears_in": [],
        "order": 75,
        "alts": [
            {
                "slot": 1,
                "variant": "Piranha Plant",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/piranha-plant/main.png"
            },
            {
                "slot": 2,
                "variant": "Piranha Plant",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/piranha-plant/main2.png"
            },
            {
                "slot": 3,
                "variant": "Piranha Plant",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/piranha-plant/main3.png"
            },
            {
                "slot": 4,
                "variant": "Piranha Plant",
