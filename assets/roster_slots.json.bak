        "variants": [
            {
                "name": "Pikachu",
                "boxing_ring_title": "Pika Pika!",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Pikachu's Origins",
                "content": "Pikachu debuted in Pokémon Red and Pokémon Blue for Game Boy. Consider yourself a very lucky Trainer if you catch one in Viridian Forest.",
                "level": "Beginner"
            },
            {
                "title": "In Its Series",
                "content": "Pikachu is an Electric-type Mouse Pokémon with a low appearance rate in Pokémon Red & Pokémon Blue. In Pokémon Yellow Version: Special Pikachu Edition, you could get one from Professor Oak at the start.",
                "level": "Beginner"
            },
            {
                "title": "Pikachu Libre",
                "content": "Pikachu Libre fights with a mask on. You can tell from the tail shape that this Pikachu is female.",
                "level": "Beginner"
            },
            {
                "title": "Thunder Jolt (Neutral Special)",
                "content": "Pikachu's Thunder Jolt bounces along the surface of the stage. It can even attack foes who are hanging from edges.",
                "level": "Beginner"
            },
            {
                "title": "Skull Bash (Side Special)",
                "content": "Execute this move like a smash attack, and it'll start off slightly charged already. This way, fully charging it doesn't take as long.",
                "level": "Intermediate"
            },
            {
                "title": "Quick Attack (Up Special)",
                "content": "Pikachu is vulnerable before landing after using Quick Attack in midair. However, if you direct the attack at the ground, the recovery time shortens a little.",
                "level": "Intermediate"
            },
            {
                "title": "Controlling Quick Attack (Up Special)",
                "content": "This move allows you to quickly attack while moving in the direction of your choice. You can move twice, but you can't continue moving in the same direction.",
                "level": "Beginner"
            },
            {
                "title": "Thunder (Down Special)",
                "content": "The bolt of lightning has a meteor effect. Use it after throwing a foe upward for a powerful combo.",
                "level": "Advanced"
            },
            {
                "title": "Electric Discharge with Thunder (Down Special)",
                "content": "Hit yourself with Thunder to cause a discharge that damages nearby foes. Using Thunder quickly after falling will pass through terrain, so it can be used below platforms in this way, too!",
                "level": "Intermediate"
            },
            {
                "title": "Volt Tackle (Final Smash)",
                "content": "Pikachu wreathes itself in lightning and dashes all over the place. It's possible to escape Pikachu's wrath by moving outside of the bounds of the screen.",
                "level": "Beginner"
            },
            {
                "title": "Headbutt (Neutral Attack)",
                "content": "Press and hold the button to attack repeatedly. Be careful, though, because Pikachu shifts slightly as it attacks. You'll eventually end up out of attack range!",
                "level": "Beginner"
            },
            {
                "title": "Electric Flower (Down Smash)",
                "content": "Pikachu's spinning down smash draws in nearby opponents, launching them in the direction Pikachu is facing. This makes it a powerful move to use at the edge of a stage.",
                "level": "Beginner"
            },
            {
                "title": "Neutral Air Attack",
                "content": "Pikachu's neutral air attack has short reach, but it hits in all directions. It's a handy move since it attacks quickly and easily allows for follow-up hits after you make contact.",
                "level": "Beginner"
            },
            {
                "title": "Glider (Back Air Attack)",
                "content": "This move can be triggered quickly and it hits multiple times, but it doesn't have a long reach, so you won't hit an opponent unless you're very close to them.",
                "level": "Beginner"
            },
            {
                "title": "Electric Screw (Down Air Attack)",
                "content": "This move has a meteor effect at the beginning. Pikachu has great recovery skills, so using it to dunk someone off the edge of the stage is a viable option.",
                "level": "Intermediate"
            }
        ],
        "fighters": [
            {
