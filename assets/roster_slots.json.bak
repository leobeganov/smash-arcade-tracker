        "variants": [
            {
                "name": "King K. Rool",
                "boxing_ring_title": "The Kremling Commander",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "King K. Rool's Origins",
                "content": "King K. Rool made his debut in 1994 in Donkey Kong Country. He is the leader of the Kremlings and his favorite hobby is stealing Donkey Kong's bananas.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "King K. Rool appears as the last boss in Donkey Kong Country. He will pretend to be defeated during the fight. After the fake ending and \"THE END?\" shows up, he will get up and attack again.",
                "level": "Beginner"
            },
            {
                "title": "Blunderbuss (Neutral Special)",
                "content": "Shoots a slow but powerful iron ball from a pirate-themed firearm. If you continue to hold the special-move button, you can suck the iron ball back in and then shoot it back out.",
                "level": "Beginner"
            },
            {
                "title": "Blunderbuss Suck Up (Neutral Special)",
                "content": "Suck up not only fighters, but the iron ball that was shot out. After sucking something up, you can aim the shot forward, above, or backward with the control stick.",
                "level": "Beginner"
            },
            {
                "title": "Slipping through Platforms while Vacuuming (Neutral Special)",
                "content": "If you press down on the control stick while holding the special-move button to suck things up with the gun, you can fall through platforms.",
                "level": "Intermediate"
            },
            {
                "title": "Crownerang (Side Special)",
                "content": "Throw the crown like a boomerang. While you're throwing it, you'll have super armor and can withstand weak attacks. If you don't catch the crown, you can't attack with it again until you retrieve it.",
                "level": "Beginner"
            },
            {
                "title": "The Crown as an Item (Side Special)",
                "content": "If your crown falls to the ground, it can be picked up by other fighters and used as an item. If your crown falls off the stage, it will reappear after a while.",
                "level": "Beginner"
            },
            {
                "title": "Propellerpack (Up Special)",
                "content": "Tilt the control stick to fly in that direction. You can travel pretty far, and you can also attack with the propeller.",
                "level": "Beginner"
            },
            {
                "title": "Gut Check (Down Special)",
                "content": "A counter move where King K. Rool sticks out his belly. If his belly is hit during this time, he'll counterattack not only direct attacks, but projectiles as well.",
                "level": "Beginner"
            },
            {
                "title": "Gut Check Behind (Down Special)",
                "content": "If you enter an input toward King K. Rool's backside right after successfully using this counter, he can quickly look back and counter.",
                "level": "Intermediate"
            },
            {
                "title": "Blast-o-Matic (Final Smash)",
                "content": "Shoot Donkey Kong Island with the Blast-o-Matic from the island fortress. All opponents hit by King K. Rool's initial attack will be blasted.",
                "level": "Beginner"
            },
            {
                "title": "Piledriver (Downward Throw)",
                "content": "Throw a grabbed opponent downward to bury them in the ground. The more damage an opponent has, the longer they will stay buried.",
                "level": "Beginner"
            },
            {
                "title": "Belly Super Armor",
                "content": "Some attacks, like side tilt attacks and neutral air attacks, cause King K. Rool's belly to have super armor. This allows you to land attacks even when getting hit by incoming attacks.",
                "level": "Advanced"
            },
            {
                "title": "Belly Crack",
                "content": "His belly's super armor is very reliable, but once it takes damage, a crack will appear. The crack will grow as it takes more damage, until finally King K. Rool becomes stunned while his belly heals.",
                "level": "Advanced"
            }
        ],
        "fighters": [
            {
                "id": "67",
                "name": "King K. Rool",
                "slug": "king-k-rool",
                "also_appears_in": []
            }
        ]
