            }
        ],
        "variants": [
            {
                "name": "Zelda",
                "boxing_ring_title": "Hyrule's Wise Princess",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Zelda's Origins",
                "content": "Zelda first appeared in the NES title The Legend of Zelda, released in North America in 1987. In that title, the evil Ganon kidnaps Zelda and steals the Triforce of Power.",
                "level": "Beginner"
            },
            {
                "title": "In Her Series",
                "content": "Zelda is the princess from the game series The Legend of Zelda. With a few exceptions, the Zelda in each game is a unique individual who shares the name Zelda, and the setting is different in each title.",
                "level": "Beginner"
            },
            {
                "title": "Special-Move Names",
                "content": "The names of Zelda's special moves come from the goddesses who created Hyrule. They are Din, the Goddess of Power; Nayru, the Goddess of Wisdom; and Farore, the Goddess of Courage.",
                "level": "Beginner"
            },
            {
                "title": "Nayru's Love (Neutral Special)",
                "content": "This move summons a magical barrier that reflects enemy projectiles. It's not just for defense, either—it also deals direct damage!",
                "level": "Beginner"
            },
            {
                "title": "Nayru's Love's Traits (Neutral Special)",
                "content": "Zelda is invincible at the start of this move, and the move can also reflect projectiles. It comes out very quickly, making it useful in a wide variety of situations.",
                "level": "Intermediate"
            },
            {
                "title": "Din's Fire (Side Special)",
                "content": "This explodes when you release the button. Hold it longer to get more range and a stronger explosion.",
                "level": "Beginner"
            },
            {
                "title": "Din's Fire's Traits (Side Special)",
                "content": "You can adjust the flame's path while the button is pressed. The flame will explode if it hits the stage, too much time passes, or you let go of the button.",
                "level": "Intermediate"
            },
            {
                "title": "Farore's Wind (Up Special)",
                "content": "Zelda will deal damage to those nearby when she disappears and reappears. Hold a direction to control where she teleports to.",
                "level": "Beginner"
            },
            {
                "title": "Aiming Farore's Wind (Up Special)",
                "content": "Hold a direction before disappearing to warp that way. Zelda will follow the direction of any platforms she encounters during the warp, as well.",
                "level": "Beginner"
            },
            {
                "title": "Feint with Farore's Wind (Up Special)",
                "content": "If you direct the move downward while standing on the ground, you'll reappear in the same place. It can really throw your opponent for a loop!",
                "level": "Advanced"
            },
            {
                "title": "Charged Phantom Slash (Down Special)",
                "content": "Charge this attack to make the Phantom travel farther. It'll attack differently based on how long the attack is charged.",
                "level": "Beginner"
            },
            {
                "title": "Phantom Slash's Traits (Down Special)",
                "content": "It's possible to attack by pressing the special-move button even before the Phantom is complete. The attack power and range increase depending on how complete the Phantom is.",
                "level": "Intermediate"
            },
            {
                "title": "Destroying the Phantom (Down Special)",
                "content": "If Zelda takes damage or the Phantom takes serious damage before it is complete, it will collapse before your eyes.",
                "level": "Beginner"
            },
            {
                "title": "Triforce of Wisdom (Final Smash)",
                "content": "A gigantic triangle swallows up one opponent and seals them away. The suction becomes progressively stronger. If an opponent has over 100% damage, it's an immediate KO.",
                "level": "Beginner"
            },
            {
                "title": "Lightning Kick (Forward Air / Back Air)",
                "content": "The tip of Zelda's foot is packed with launch power at the beginning of the move. It has good KO potential but leaves you vulnerable, and only the tip has good launch power.",
                "level": "Beginner"
            },
            {
                "title": "Meteor Heel (Down Air Attack)",
                "content": "A move with a meteor effect. The beginning of the move has the most power, but you can use it to disrupt somebody from recovering even if you don't get a clean hit.",
                "level": "Beginner"
            }
        ],
        "fighters": [
