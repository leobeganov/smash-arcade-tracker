            }
        ],
        "variants": [
            {
                "name": "King Dedede",
                "boxing_ring_title": "The Self-Made King",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "King Dedede's Origins",
                "content": "King Dedede debuted alongside Kirby in the 1992 title Kirby's Dream Land. He's a big eater who wants all the food in Dream Land for himself!",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "The mastermind who stole all the food in Kirby's Dream Land. He calls himself the ruler of Dream Land and gets the Waddle Dees and others to serve him.",
                "level": "Beginner"
            },
            {
                "title": "Masked Dedede",
                "content": "King Dedede appeared in this form in Revenge of the King from Kirby Super Star Ultra. Rather than his usual wooden hammer, he's equipped with a mechanical New Dedede Hammer.",
                "level": "Beginner"
            },
            {
                "title": "Inhale (Neutral Special)",
                "content": "After inhaling opponents, press the button again to spit them out as a projectile. This way, you can hit your opponents with each other!",
                "level": "Beginner"
            },
            {
                "title": "Inhale (Neutral Special)",
                "content": "Dedede is already perfect, so his Inhale won't copy abilities. Instead, it has a longer range than Kirby's.",
                "level": "Beginner"
            },
            {
                "title": "Inhaling Projectiles (Neutral Special)",
                "content": "You can inhale an opponent's projectiles, then spit them back out at them. The projectiles you spit back out have higher attack power than normal.",
                "level": "Beginner"
            },
            {
                "title": "Inhale Techniques (Neutral Special)",
                "content": "The Gordo that appears when using a side special can also be inhaled and spit back out. You're not vulnerable for long after spitting it out, so you can use it for a combo too.",
                "level": "Intermediate"
            },
            {
                "title": "Gordo Throw (Side Special)",
                "content": "Gordos will stick to any walls they hit. Try doing this on walls close to edges to cause serious trouble to enemies trying to climb up.",
                "level": "Intermediate"
            },
            {
                "title": "Returning Gordo (Side Special)",
                "content": "With the right timing, an opponent can hit a Gordo back at you. But then you can attack it or hit it with your side special again, and now a fierce battle has turned into a game of Gordo tennis.",
                "level": "Intermediate"
            },
            {
                "title": "Gordo Throw's Many Tricks (Side Special)",
                "content": "Choose up, middle, or down right after starting this move to hit the Gordo in three different ways, changing how it bounces.",
                "level": "Intermediate"
            },
            {
                "title": "Super Dedede Jump (Up Special)",
                "content": "After leaping up high, Dedede crashes down in a crushing body slam. This move can be canceled by the special-move button or up on the control stick.",
                "level": "Beginner"
            },
            {
                "title": "Jet Hammer (Down Special)",
                "content": "It's possible to charge this move to deal more damage, but charging for too long will start to hurt Dedede too!",
                "level": "Intermediate"
            },
            {
                "title": "Jet Hammer's Characteristics (Down Special)",
                "content": "If King Dedede's damage goes over 100%, he can keep charging this move past maximum without taking damage.",
                "level": "Intermediate"
            },
            {
                "title": "Dede-rush (Final Smash)",
                "content": "Stuck in a cage match, an opponent is subjected to Dedede Missiles and then a powerful Hammer attack. It's an over-the-top Final Smash that launches the opponent as well as the chain-link cage.",
                "level": "Beginner"
            },
            {
                "title": "Rolling (Down Tilt Attack)",
                "content": "He can attack while prone by cartwheeling forward. This lets him attack while moving, like a dash attack.",
                "level": "Beginner"
            },
            {
                "title": "Belly Flop (Dash Attack)",
                "content": "This attack leaves King Dedede wide open to attacks, but it can also launch opponents very far. King Dedede's been using this move since the first game in the series, Kirby's Dream Land.",
                "level": "Beginner"
            },
            {
                "title": "Hovering",
                "content": "King Dedede can float after taking in a big gulp of air. This move is the result of lots of hard work and training so he could put up a fight against Kirby after previously losing to him.",
                "level": "Intermediate"
            }
        ],
        "fighters": [
