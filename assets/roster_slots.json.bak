        ],
        "variants": [
            {
                "name": "Final Fantasy VII",
                "boxing_ring_title": "SOLDIER 1st Class",
                "type": "Same character"
            },
            {
                "name": "Advent Children",
                "boxing_ring_title": "SOLDIER 1st Class",
                "type": "Same character"
            }
        ],
        "tips": [
            {
                "title": "In His Series",
                "content": "Cloud is a former SOLDIER turned mercenary, hired by Avalanche—a group that stands against the Shinra Electric Power Company. Cloud's the strong, silent type, often using \"not interested\" as his go-to phrase.",
                "level": "Beginner"
            },
            {
                "title": "Limit Break",
                "content": "Fully charging your Limit Gauge lets you perform a Limit Break, which alters your special moves and gives them a boost.",
                "level": "Beginner"
            },
            {
                "title": "Limit Break's Charge",
                "content": "Once charged, Cloud's Limit Gauge can release when a special move is used, Cloud is KO'd, or a certain amount of time passes.",
                "level": "Beginner"
            },
            {
                "title": "Blade Beam (Neutral Special)",
                "content": "Cloud releases a shock wave along the ground. As you'd guess by looking, the attack range is quite wide, so you'll need to jump high to clear it.",
                "level": "Beginner"
            },
            {
                "title": "Blade Beam During Limit Break (Neutral Special)",
                "content": "The Limit Break version of this attack bursts on impact to hit multiple times. It can even KO opponents if their damage is high enough.",
                "level": "Intermediate"
            },
            {
                "title": "Blade Beam and Projectiles (Neutral Special)",
                "content": "The Limit Break version of this move neutralizes projectiles and thrown items. Try using it just as you're about to be hit by a projectile!",
                "level": "Beginner"
            },
            {
                "title": "Cross Slash (Side Special)",
                "content": "If you press the button again when connecting with an enemy, you can hit them up to three times. Otherwise, Cloud only attacks once.",
                "level": "Beginner"
            },
            {
                "title": "Cross Slash During Limit Break (Side Special)",
                "content": "You only need to press the button once to unleash the full attack if you use your Limit Break. Even better, launching enemies becomes much easier.",
                "level": "Intermediate"
            },
            {
                "title": "Climhazzard (Up Special)",
                "content": "Press the special-move button again on the way up to slash back down. You can't move sideways on the way down, so be careful during recoveries.",
                "level": "Beginner"
            },
            {
                "title": "Climhazzard During Limit Break (Up Special)",
                "content": "This move's Limit Break version allows you to climb even higher into the air, as well as letting you move sideways. It's great for recoveries!",
                "level": "Intermediate"
            },
            {
                "title": "Limit Charge (Down Special)",
                "content": "The Limit Gauge's charge will drop if you're attacked while charging. Make sure you're in a safe spot before you begin charging.",
                "level": "Beginner"
            },
            {
                "title": "Canceling Limit Charge (Down Special)",
                "content": "You can cancel charging by pressing the shield button or dodging left or right, or jumping. Use this to get in a quick charge during quiet moments!",
                "level": "Beginner"
            },
            {
                "title": "Finishing Touch (Down Special)",
                "content": "This is Cloud's down special once the Limit Gauge is charged. The tornado doesn't do much damage, but it can KO enemies with its high launching power.",
                "level": "Intermediate"
            },
            {
                "title": "Omnislash (Final Smash)",
                "content": "When using one of the odd-numbered color variations, toss opponents upward with the sword, unleash powerful slashes, and then send them downward. Fighters near where the opponent lands will be launched.",
                "level": "Beginner"
            },
            {
                "title": "Omnislash Ver. 5 (Final Smash)",
                "content": "The even color variations will launch an opponent into the air and then slash them with a barrage of hits before striking with one final blow. Damage dealt and time taken by the other color variations is identical.",
                "level": "Beginner"
            },
            {
                "title": "Sliding (Down Tilt Attack)",
                "content": "Cloud does a sliding kick over a set distance. He slides so low that this move can be used to dodge some thrown items.",
                "level": "Beginner"
            },
            {
                "title": "Triple Buster (Side Smash Attack)",
                "content": "This quick three-hit smash has high launching power on the last hit. The first hit isn't so powerful, so the penalty for getting countered isn't high.",
                "level": "Beginner"
            },
            {
                "title": "Double Thrust (Down Smash Attack)",
                "content": "Cloud attacks a foe and then sends the foe flying off behind him. Use this when close to an edge to get out of sticky situations.",
                "level": "Beginner"
            },
            {
                "title": "Meteor Slash (Forward Air Attack)",
                "content": "Cloud takes a huge vertical swing at an enemy. Hitting an opponent with the tip of the sword has a meteor effect.",
                "level": "Beginner"
            }
        ],
        "fighters": [
