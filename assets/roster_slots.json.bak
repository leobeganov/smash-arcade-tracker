        "variants": [
            {
                "name": "Peach",
                "boxing_ring_title": "Princess of Toadstools",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Princess of the Mushroom Kingdom",
                "content": "Peach first appeared in Super Mario Bros., where she was known as Princess Toadstool. This was also the first of her many run-ins with Bowser...",
                "level": "Beginner"
            },
            {
                "title": "In Her Series",
                "content": "Peach was the star of Super Princess Peach, released in North America in 2006. Mario and the others get kidnapped by Bowser and it's up to Peach to save them with the help of her friend Perry.",
                "level": "Beginner"
            },
            {
                "title": "Nurse Peach",
                "content": "When Mario took up a new career as Dr. Mario, Peach joined him as a nurse. But she didn't get to appear in the game itself—only in the manual!",
                "level": "Beginner"
            },
            {
                "title": "Peach Parasol Descent (Up Special)",
                "content": "Press up and down to open and close your parasol and adjust your fall speed.",
                "level": "Intermediate"
            },
            {
                "title": "Open and Shut Peach Parasol (Up Special)",
                "content": "Peach can't grab the ledge if she's facing away from it and her parasol is open. Tap down to close it, though, and she'll grab on safely.",
                "level": "Intermediate"
            },
            {
                "title": "Vegetable (Down Special)",
                "content": "Of the eight types, the wrinkle-faced vegetable is the strongest. If you throw it while tapping a direction, it can do over 30% damage!",
                "level": "Beginner"
            },
            {
                "title": "Rare \"Vegetables\" (Down Special)",
                "content": "Rarely, Peach will pull up a Bob-omb or Mr. Saturn. How rarely? Well, you have a 1/250 chance of a Bob-omb and a 1/166 chance of a Mr. Saturn!",
                "level": "Advanced"
            },
            {
                "title": "Peach Blossom (Final Smash)",
                "content": "Peach's charming dance puts nearby opponents into a deep sleep and causes three healing peaches to appear. It also does damage. The closer Peach is to her opponents, the greater the effect.",
                "level": "Beginner"
            },
            {
                "title": "Diverse Weapons (Side Smash Attack)",
                "content": "While preparing a side smash attack, moving the control stick up or down will produce a different weapon. Up for a frying pan, down for a tennis racket, or no direction for a golf club.",
                "level": "Beginner"
            },
            {
                "title": "A Tool for Every Job (Side Smash Attack)",
                "content": "The frying pan does the most damage, the tennis racket launches opponents at a low angle, and the golf club has the best reach.",
                "level": "Intermediate"
            },
            {
                "title": "Ribbon Dance (Up Smash)",
                "content": "Peach unleashes a powerful attack directed straight above her. In addition to opponents above her, it can also hit nearby opponents on the ground.",
                "level": "Intermediate"
            },
            {
                "title": "Attacking with Toad (Grab)",
                "content": "If your grab is successful, Peach's protector, Toad, will appear. He'll perform a combination attack with Peach during grab attacks and throws.",
                "level": "Beginner"
            },
            {
                "title": "Gliding",
                "content": "Holding the jump button will let Peach hover in the air for a short time. She can even attack as she floats!",
                "level": "Beginner"
            },
            {
                "title": "Low Gliding",
                "content": "Hold jump while crouching to float just above the ground. You can use air attacks quickly that way!",
                "level": "Advanced"
            },
            {
                "title": "Floating with Vegetables",
                "content": "When floating in the air and holding an item, it's possible to attack without throwing the item. Your battle options can increase if you think about how to use this tip in combination with Vegetable.",
                "level": "Beginner"
            }
        ],
        "fighters": [
