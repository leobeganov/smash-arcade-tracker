        ],
        "variants": [
            {
                "name": "Simon",
                "boxing_ring_title": "Evil's Whip-Wielding Bane",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Simon's Origins",
                "content": "Simon made his debut in Castlevania, released in North America in 1987. Armed with nothing but his legendary whip, he enters Dracula's Castle alone to slay all manner of foul beasts.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Simon is a vampire hunter of House Belmont. He uses not only whips, but also daggers, axes, Holy Water, crosses, and even stopwatches as weapons.",
                "level": "Beginner"
            },
            {
                "title": "Axe (Neutral Special)",
                "content": "A projectile that curves through the air when thrown. You can adjust the angle of the throw by moving the stick left or right. It can pass through the stage, hitting unsuspecting opponents!",
                "level": "Beginner"
            },
            {
                "title": "Cross (Side Special)",
                "content": "You can increase the distance and power by quickly moving the stick as you press the special-move button. It can hit while flying out and when flying back, but it's more powerful when flying out.",
                "level": "Beginner"
            },
            {
                "title": "Uppercut (Up Special)",
                "content": "A jumping punch that can hit repeatedly. The final hit has the most launch power.",
                "level": "Beginner"
            },
            {
                "title": "Holy Water (Down Special)",
                "content": "Throw a bottle of Holy Water forward. If it hits an opponent or the landscape, a red flaming pillar will appear, stopping the opponent's movements. Try following up with a whip attack!",
                "level": "Beginner"
            },
            {
                "title": "Grand Cross (Final Smash)",
                "content": "Summon a coffin that traps opponents who touch it. Using this on an opponent who is trapped in your Holy Water's fire or an opponent who's fallen down is a good strategy.",
                "level": "Beginner"
            },
            {
                "title": "Sliding (Down Tilt Attack)",
                "content": "Press the attack button again while sliding to perform an additional jump kick. Use it to catch your opponent off guard or as part of a combo.",
                "level": "Beginner"
            },
            {
                "title": "Holding the Whip",
                "content": "Press and hold the attack button to make the whip dangle. Rotate the control stick in a circular motion to swing the whip around.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "66",
