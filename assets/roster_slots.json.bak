        "tips": [
            {
                "title": "Richter's Origins",
                "content": "Richter debuted in Castlevania: Rondo of Blood in 1993. He heads to the castle to defeat Count Dracula and rescue his kidnapped girlfriend, Annette.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Richter uses a whip passed down through generations, along with various subweapons. In Castlevania: Symphony of the Night, he can appear as the final boss if you take a certain route.",
                "level": "Beginner"
            },
            {
                "title": "Axe (Neutral Special)",
                "content": "A projectile that curves through the air when thrown. You can adjust the angle of the throw by moving the stick left or right. It can pass through the stage, hitting unsuspecting opponents!",
                "level": "Beginner"
            },
            {
                "title": "Cross (Side Special)",
                "content": "You can increase the distance and power by quickly flicking the control stick as you press the special-move button. It can hit while flying out and back, but it's more powerful when flying out.",
                "level": "Beginner"
            },
            {
                "title": "Uppercut (Up Special)",
