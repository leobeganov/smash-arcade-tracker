            },
            {
                "name": "Female",
                "boxing_ring_title": "Blood of Dragons",
                "type": "Same character"
            }
        ],
        "tips": [
            {
                "title": "In Their Series",
                "content": "Corrin, the main character from Fire Emblem Fates, is of royal blood. As a descendant of the First Dragons, Corrin can transform into a dragon.",
                "level": "Beginner"
            },
            {
                "title": "Omega Yato",
                "content": "When Corrin's Yato blade resonates with the four other divine weapons, it will turn into its final form, the Omega Yato.",
                "level": "Beginner"
            },
            {
                "title": "Charging Dragon Fang Shot (Neutral Special)",
                "content": "The two stages of this move—shooting water and the bite attack—can both be charged by holding down the button at the right point.",
                "level": "Beginner"
            },
            {
                "title": "Dragon Fang Shot's Blast (Neutral Special)",
                "content": "The water projectile will paralyze whoever it hits, giving you the time you need to follow up with a fully charged biting attack!",
                "level": "Beginner"
            },
            {
                "title": "Dragon Lunge and Terrain (Side Special)",
                "content": "Skewering surfaces with this move allows for follow-up moves, such as recovering from falls by skewering a wall and then leaping to safety!",
                "level": "Intermediate"
            },
            {
                "title": "Lockdown with Dragon Lunge (Side Special)",
                "content": "You can keep enemies from moving for a while if you pierce them while skewering a surface. Beware: opponents can escape by wiggling around!",
                "level": "Beginner"
            },
            {
                "title": "Dragon Lunge Tips (Side Special)",
                "content": "After launching this move from the ground, quickly press the attack button to instantly skewer the ground.",
                "level": "Intermediate"
            },
            {
                "title": "Actions after Dragon Lunge (Side Special)",
                "content": "On the ground, Corrin won't thrust the spear until you press the button again after jumping. Once the spear is in the ground, tilt the stick to the side to kick, up to jump, and down to cancel.",
                "level": "Intermediate"
            },
            {
                "title": "Dragon Ascent's Direction (Up Special)",
                "content": "You can slightly adjust your flight angle by pressing in the direction you're facing. Push in the opposite direction to fly straight up and to a greater height.",
                "level": "Beginner"
            },
            {
                "title": "Invincibility for Dragon Ascent (Up Special)",
                "content": "Corrin is invincible while charging up power at the start of this move. Practice with the timing and you'll be able to interrupt enemy attacks!",
                "level": "Intermediate"
            },
            {
                "title": "Counter Surge (Down Special)",
                "content": "This move will knock foes skyward with a fair amount of force, so try using it in a high-up place to really boot them off the stage!",
                "level": "Beginner"
            },
            {
                "title": "Area Attack with Counter Surge (Down Special)",
                "content": "This counter is a bit slow compared to others, but it can hit foes on both sides. It's great for when you're in the middle of a brawl!",
                "level": "Intermediate"
            },
            {
                "title": "Torrential Roar (Final Smash)",
                "content": "Summon pillars of light and release a powerful torrent of water to launch opponents. The pillars of light will also hit opponents above you.",
                "level": "Beginner"
            },
            {
                "title": "Options for Dragon Fang Thrust (Side Smash Attack)",
                "content": "Charge this move to juggle foes with Corrin's sword Yato before unleashing the coup de grâce! It has a long range and can be aimed up or down a little!",
                "level": "Advanced"
            },
            {
                "title": "Tip on Dragon Fang Thrust (Side Smash Attack)",
                "content": "Try to get the hang of hitting opponents with the point of Corrin's lance-arm, as that part inflicts more damage than the rest.",
                "level": "Beginner"
            },
            {
                "title": "Vertical Dragon Fang Thrust (Up Smash Attack)",
                "content": "Corrin gets low and attacks straight up with lance-like arms. Try to hit enemies with the points for more damage.",
                "level": "Beginner"
            },
            {
                "title": "Yato Dragon Fang (Down Smash Attack)",
                "content": "Corrin strikes forward with a sword and backward with a lance-like foot. Try hitting sneaky backstabbers with the point of the lance!",
                "level": "Beginner"
            },
            {
                "title": "Dragon Fang Wings (Back Air Attack)",
                "content": "Propel yourself forward with a flap of the wings. You can deal some damage and get yourself out of tight spots.",
                "level": "Beginner"
            },
            {
                "title": "Dragon's Piercing Drop (Down Air Attack)",
                "content": "Transform both legs into a single lance and drop straight down. This move deals damage when landing but leaves you open if the enemy uses their shield.",
                "level": "Beginner"
            },
            {
                "title": "Dragon-Form Kick (Downward Throw)",
                "content": "Hits in a wide radius, sending multiple foes skyward when Corrin stomps the ground, lining them up for a nice follow-up attack.",
                "level": "Beginner"
            },
            {
                "title": "Get Multiple Opponents with a Throw",
                "content": "Corrin's arms change into spears when performing a forward throw or a backward throw. You can hit other fighters with the spears. If you can hit opponents with the tip, you can launch them far.",
                "level": "Beginner"
            }
        ],
        "fighters": [
