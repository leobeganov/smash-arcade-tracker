            }
        ],
        "variants": [
            {
                "name": "Shulk",
                "boxing_ring_title": "The Visionary",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Shulk's Origins",
                "content": "Shulk made his debut in North America with the 2012 release of Xenoblade Chronicles. A budding scientist, this young man has a kind and curious heart.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "The main character from Xenoblade Chronicles. Shulk is a gentle young man who hopes for peace, but he also has the courage to confront any opponent.",
                "level": "Beginner"
            },
            {
                "title": "Up Taunt",
                "content": "The line Shulk speaks when he uses his up taunt, \"Now it's Shulk time!\" is a reference to Shulk's childhood friend Reyn.",
                "level": "Beginner"
            },
            {
                "title": "Summertime Shulk",
                "content": "Shulk's eighth color variation puts him in a pair of swimming trunks! In the original game, this is how he appeared with all his equipment removed.",
                "level": "Beginner"
            },
            {
                "title": "Monado Arts (Neutral Special)",
                "content": "Shulk switches between five modes—Jump, Speed, Shield, Buster, and Smash—that change his abilities for a short time.",
                "level": "Beginner"
            },
            {
                "title": "Monado Arts - Speed (Neutral Special)",
                "content": "In Speed mode, you'll sacrifice damage and jump height in order to move faster.",
                "level": "Beginner"
            },
            {
                "title": "Monado Arts - Shield (Neutral Special)",
                "content": "In Shield mode, the power of your shield is boosted but you can't move as fast, jump as high, or deal as much damage.",
                "level": "Intermediate"
            },
            {
                "title": "Monado Arts - Buster (Neutral Special)",
                "content": "In Buster mode, you deal more damage than usual, but you can't launch opponents as far and you'll receive more damage.",
                "level": "Intermediate"
            },
            {
                "title": "Monado Arts - Smash (Neutral Special)",
                "content": "In Smash mode, you can launch opponents more effectively, but you deal less damage and can be launched more easily yourself.",
                "level": "Intermediate"
            },
            {
                "title": "Monado Arts - Jump (Neutral Special)",
                "content": "In Jump mode, it's not just Shulk's standard jump and midair jump that go higher—his Air Slash move gives him more height than usual, too.",
                "level": "Intermediate"
            },
            {
                "title": "Monado Arts and Being Launched (Neutral Special)",
                "content": "Shulk can switch between Monado Arts even while being launched. If you get launched off a cliff, switching to Jump mode might save you!",
                "level": "Intermediate"
            },
            {
                "title": "Limitations of Monado Arts (Neutral Special)",
                "content": "You can't use a Monado Art immediately after it's run out. If you wait a certain period of time, it will become available for use again.",
                "level": "Intermediate"
            },
            {
                "title": "Canceling Monado Arts (Neutral Special)",
                "content": "To cancel the current Monado Art, press the special-move button quickly three times in a row.",
                "level": "Beginner"
            },
            {
                "title": "Chain Attack and Monado Arts (Neutral Special)",
                "content": "Shulk's Monado Arts even affect his Final Smash. If you select Buster, your launch power will go down but your attack will go up, causing you to deal more damage!",
                "level": "Advanced"
            },
            {
                "title": "Shortcuts for Monado Arts (Neutral Special)",
                "content": "Press and hold the special-move button to see all the Monado Arts. Select the Monado Art you want with the control stick, and let go of the button to confirm your selection.",
                "level": "Beginner"
            },
            {
                "title": "Back Slash (Side Special)",
                "content": "Shulk leaps forward and performs a vertical slice downward. As the name implies, it deals more damage if you hit the enemy from behind.",
                "level": "Beginner"
            },
            {
                "title": "Back Slash Details (Side Special)",
                "content": "After using Back Slash, you won't be able to grab stage edges until enough time has passed. While swinging the Monado downward, you can move slightly left and right by tilting the control stick.",
                "level": "Beginner"
            },
            {
                "title": "Air Slash (Up Special)",
                "content": "Press the attack button while using an Air Slash to perform another slash forward and rise a little farther. It won't work after you start falling.",
                "level": "Beginner"
            },
            {
                "title": "Length of Vision (Down Special)",
                "content": "Shulk's Vision is a powerful counter move, but its activation timing becomes stricter when used repeatedly. It recovers slowly while not in use.",
                "level": "Intermediate"
            },
            {
                "title": "Strike from Behind with Vision (Down Special)",
                "content": "Input toward your foe when you pull off a counter, and you'll swing around them to attack from the other side. This launches farther but won't work in the air.",
                "level": "Advanced"
            },
            {
                "title": "Shouts in Chain Attack (Final Smash)",
                "content": "There are variations on this attack, depending on whether Shulk calls for Dunban, Fiora, or Riki. They don't change anything but the lines spoken, though.",
                "level": "Beginner"
            },
            {
                "title": "Chain Attack (Final Smash)",
                "content": "Shulk's Final Smash hits opponents within a set radius. Dunban, Riki, and Fiora join in to deal repeated attacks.",
                "level": "Beginner"
            },
            {
                "title": "Behind Thrust (Back Air Attack)",
                "content": "Shulk's back air has tremendous reach, but the timing can be a bit tricky.",
                "level": "Beginner"
            }
        ],
        "fighters": [
