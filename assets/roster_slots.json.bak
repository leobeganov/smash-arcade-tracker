        "variants": [
            {
                "name": "Meta Knight",
                "boxing_ring_title": "The Masked Swordsman",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Meta Knight's Origins",
                "content": "Meta Knight debuted in Kirby's Adventure on the NES as a mysterious figure who stood in Kirby's way as a boss but also sometimes helped him.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Meta Knight first appeared in Kirby's Adventure. He leads the Meta-Knights. He wears a mask, but when he loses to Kirby, you can see a glimpse of his true face when his mask cracks.",
                "level": "Beginner"
            },
            {
                "title": "Galacta Knight",
                "content": "Meta Knight's seventh color variation is based on Galacta Knight, who makes an appearance in Kirby Super Star Ultra and is said to be the strongest warrior in the galaxy.",
                "level": "Beginner"
            },
            {
                "title": "Dark Meta Knight",
                "content": "Meta Knight's eighth color variation is based on a shadow version of Meta Knight, Dark Meta Knight, who appears in Kirby & The Amazing Mirror.",
                "level": "Beginner"
            },
            {
                "title": "Mach Tornado (Neutral Special)",
                "content": "The tornado created around Meta Knight can destroy any weak projectiles it hits.",
                "level": "Beginner"
            },
            {
                "title": "Drill Rush (Side Special)",
                "content": "While Meta Knight's rushing through the air like a drill, you can adjust his direction.",
                "level": "Beginner"
            },
            {
                "title": "Drill Rush Technique (Side Special)",
                "content": "If you direct Meta Knight toward the ground, he'll cancel the move and do a little hop. Use that to avoid an enemy who is about to counter you.",
                "level": "Advanced"
            },
            {
                "title": "Shuttle Loop (Up Special)",
                "content": "Meta Knight thrusts his sword upward, loops in midair, and then thrusts upward once more. A swift and powerful attack, useful against falling foes.",
                "level": "Beginner"
            },
            {
                "title": "Shuttle Loop with Care (Up Special)",
                "content": "This powerful attack is useful for pursuing enemies directly above you. However, you're vulnerable during the postmove descent.",
                "level": "Intermediate"
            },
            {
                "title": "Shuttle Loop's Characteristics (Up Special)",
                "content": "You can use the attack slightly more quickly in the air. However, the first strike is more powerful when executed from the ground.",
                "level": "Intermediate"
            },
            {
                "title": "Dimensional Cape (Down Special)",
                "content": "Meta Knight wraps himself in his cape and disappears. If you keep holding the button, he'll strike when he's back!",
                "level": "Intermediate"
            },
            {
                "title": "Dimensional Cape Techniques (Down Special)",
                "content": "While Meta Knight is invisible, he'll move in the direction you input. He won't move if you don't input a direction, which is useful as a feint.",
                "level": "Intermediate"
            },
            {
                "title": "Dimensional Cape Warning (Down Special)",
                "content": "While unseen, you can move in a direction you input, but if you move backward, your attack and launch power will be reduced.",
                "level": "Intermediate"
            },
            {
                "title": "Darkness Illusion (Final Smash)",
                "content": "Lightning strikes and catches nearby opponents for a multi-hit attack. It wraps up with a side slice that sends opponents flying.",
                "level": "Beginner"
            },
            {
                "title": "Flurry Attack (Neutral Attack)",
                "content": "Press the attack button to unleash a flurry of strikes. Meta Knight doesn't care for the singular \"attack.\"",
                "level": "Beginner"
            },
            {
                "title": "Third Attack's Launch Power (Side Tilt Attack)",
                "content": "Keep pressing the button to unleash three attacks! The third strike of Meta Knight's side tilt attack is powerful enough to launch opponents.",
                "level": "Beginner"
            },
            {
                "title": "Midair Up Sweep (Up Air Attack)",
                "content": "Use this move to launch an opponent at an upward diagonal angle, then follow up with another of the same attack. If you then land an up special, you can launch your opponent up even further into the air.",
                "level": "Beginner"
            },
            {
                "title": "Trample (Downward Throw)",
                "content": "Your enemy will fly diagonally upward after this, so that's a good time to use a combo. If their damage is low, try a dash attack and then a forward air attack.",
                "level": "Intermediate"
            },
            {
                "title": "Falling Defenseless",
                "content": "If Meta Knight uses of any[sic] his special moves in the air, he'll fall to the ground in a defenseless state afterward. He's an adept midair fighter, but you have to be careful when using his specials.",
                "level": "Beginner"
            }
        ],
        "fighters": [
