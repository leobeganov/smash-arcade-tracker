        ],
        "variants": [
            {
                "name": "Dragon Quest XI",
                "boxing_ring_title": "The Luminary",
                "type": "Same character"
            },
            {
                "name": "Dragon Quest III",
                "boxing_ring_title": "The Legendary Hero",
