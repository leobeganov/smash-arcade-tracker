        ],
        "variants": [
            {
                "name": "Bowser",
                "boxing_ring_title": "The King of the Koopas",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "King of the Koopas",
                "content": "Mario's eternal rival, Bowser, debuted in Super Mario Bros. He appeared as the boss of every world, but they were all fake except for in World 8.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "As the king of the Koopas, Bowser lives to disturb the peace. He's the eternal archenemy of Mario. Bowser attempts to fulfill his own ambitions by leading his minions to attack the Mushroom Kingdom.",
                "level": "Beginner"
            },
            {
                "title": "A Bowser Impostor?!",
                "content": "In Super Mario Bros.: The Lost Levels, Mario fights a blue fake Bowser before the real thing. That blue fake is his eighth color in this game!",
                "level": "Beginner"
            },
            {
                "title": "Aim Fire Breath (Neutral Special)",
                "content": "You can change the angle of Bowser's flame. Try aiming slightly above the enemy to make it harder for them to escape! Bowser's not above dirty tricks.",
                "level": "Intermediate"
            },
            {
                "title": "The Power of Fire Breath (Neutral Special)",
                "content": "Once Bowser's used up his fire once, he needs time to recharge. Give him 12 seconds, and he'll be ready to roast!",
                "level": "Beginner"
            },
            {
                "title": "Flying Slam (Side Special)",
                "content": "Bowser's target has a bit of control over their direction in the air, too. The lower their damage, the more influence they have (but still not much).",
                "level": "Intermediate"
            },
            {
                "title": "Flying Slam Entanglement (Side Special)",
                "content": "The grabbed opponent is smashed on the ground under Bowser. While falling, Bowser can also catch other nearby opponents. But if you fall off the edge, you'll be KO'd before the grabbed opponent is!",
                "level": "Beginner"
            },
            {
                "title": "Whirling Tip for Whirling Fortress (Up Special)",
                "content": "Repeatedly pressing the button while using this in midair will give you a small boost in how high you fly.",
                "level": "Intermediate"
            },
            {
                "title": "Counter with Whirling Fortress (Up Special)",
                "content": "Try using this right after shielding an enemy attack. Cancel the shield and whirl toward the enemy to counterattack!",
                "level": "Intermediate"
            },
            {
                "title": "Bowser Bomb (Down Special)",
                "content": "Bowser will leap into the air hornsfirst. Hitting opponents on the way up makes it much easier to clobber them again on the way down.",
                "level": "Intermediate"
            },
            {
                "title": "Bowser Bomb the Ledge (Down Special)",
                "content": "You can grab on to an edge while bombing, but only if you're really close to it. It's a quick albeit risky way to descend quickly.",
                "level": "Intermediate"
            },
            {
                "title": "Bowser Bomb—the Shield Breaker (Down Special)",
                "content": "If you land this on a shielding enemy, you can break their shield in one hit. Just make sure you capitalize afterward with a dropkick!",
                "level": "Advanced"
            },
            {
                "title": "Giga Bowser Punch (Final Smash)",
                "content": "Giga Bowser's massive punch will launch opponents depending on where it lands. If an opponent has taken a lot of damage, they'll be launched for a guaranteed KO.",
                "level": "Beginner"
            },
            {
                "title": "Tough Guy",
                "content": "Bowser's a real tough guy. When he's only lightly damaged, weaker attacks won't make him flinch.",
                "level": "Beginner"
            },
            {
                "title": "Altering Landing Timing",
                "content": "When you're in the air prior to landing and it looks like an opponent is going to try to hit you from below, you can alter your landing timing by using a down air attack or a down special.",
                "level": "Beginner"
            },
            {
                "title": "Super Armor",
                "content": "Weak attacks won't cause him to flinch while his damage is low. He also gets super armor at the start of his tilt attacks and smash attacks.",
                "level": "Beginner"
            },
            {
                "title": "The Three Heaviest Fighters",
                "content": "#1 is Bowser, #2 is King K. Rool, and #3 is Donkey Kong and King Dedede. The heavier a fighter, the stronger their attacks and the harder they are to launch.",
                "level": "Beginner"
            }
        ],
        "fighters": [
