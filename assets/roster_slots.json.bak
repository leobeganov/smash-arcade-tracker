        "variants": [
            {
                "name": "Ness",
                "boxing_ring_title": "The PSI Powerhouse",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Ness's Origins",
                "content": "Ness first appeared in the SNES title EarthBound, released in North America in 1995. He might look like your average kid, but he can use a variety of PSI powers. He's also got a younger sister.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Ness is the main character of EarthBound. In that game, a messenger from the future entrusts him with the fate of the world, and Ness heads out to stop the evil plans of an invader named Giygas.",
                "level": "Beginner"
            },
            {
                "title": "Homesickness",
                "content": "In EarthBound, Ness occasionally gets homesick, which weakens him in battle. This can be cured by his going home or by just phoning his mom!",
                "level": "Beginner"
            },
            {
                "title": "Ness's Little Sister",
                "content": "Ness has a little sister named Tracy. She works part-time at Escargo Express, answering Ness's calls when he needs to have items delivered.",
                "level": "Beginner"
            },
            {
                "title": "Ness's PSI Powers",
                "content": "Ness always had a variety of PSI powers, but he couldn't actually use PK Fire or PK Thunder in EarthBound. His friend Paula could, though.",
                "level": "Beginner"
            },
            {
                "title": "Enlarging PK Flash (Neutral Special)",
                "content": "The power and radius of the charge grow as you hold down the button. You can also move it by tilting the stick left and right.",
                "level": "Beginner"
            },
            {
                "title": "PK Fire (Side Special)",
                "content": "If this attack connects, a big pillar of fire appears. \"I feel the burn!\" your foes will yell.",
                "level": "Beginner"
            },
            {
                "title": "Aerial PK Fire (Side Special)",
                "content": "There's less of a gap between PK Fire and your next move when used in the air instead of the ground. In midair, the attack flies down diagonally, so use it right before landing to keep opponents at bay.",
                "level": "Intermediate"
            },
            {
                "title": "PK Thunder's Bolt (Up Special)",
                "content": "You can guide the bolt of lightning around and hit yourself for propulsion—but this leaves you defenseless, so be careful!",
                "level": "Beginner"
            },
            {
                "title": "PK Thunder's Characteristics (Up Special)",
                "content": "The lightning won't disappear if an enemy hits its tail. It's also invulnerable for a very brief moment after Ness initially fires it.",
                "level": "Intermediate"
            },
            {
                "title": "Sneaky PK Thunder Play (Up Special)",
                "content": "Since you can move the attack yourself, you can stop enemies from recovering by moving it near an edge and waiting for them to climb up.",
                "level": "Beginner"
            },
            {
                "title": "PK Thunder Tackle (Up Special)",
                "content": "Ness can hit himself with the ball of electricity to launch himself like a missile. If you're good with the angle, it can be used for recovery.",
                "level": "Beginner"
            },
            {
                "title": "PK Thunder Usage (Up Special)",
                "content": "If you hit yourself with PK Thunder and run into an obstacle like a wall or the ground, you can immediately use your up special again to trigger PK Thunder without continuing to fall.",
                "level": "Intermediate"
            },
            {
                "title": "PSI Magnet (Down Special)",
                "content": "This move absorbs energy-based projectiles and heals Ness as a result.",
                "level": "Beginner"
            },
            {
                "title": "PK Starstorm (Final Smash)",
                "content": "With help from Paula and Poo, countless meteors fall from the sky. You can make slight adjustments to where the meteors fall by tilting left or right.",
                "level": "Beginner"
            },
            {
                "title": "Batter Up! (Side Smash Attack)",
                "content": "Ness's bat leaves him open to attack, but it has epic launching power. He can even hit projectiles with it!",
                "level": "Beginner"
            },
            {
                "title": "Around the World (Up Smash Attack)",
                "content": "Ness's yo-yo flies forward and then swings up and around to the back for a wide-ranging, heavy-hitting attack.",
                "level": "Beginner"
            },
            {
                "title": "Reverse PK Throw (Backward Throw)",
                "content": "Enemies with a higher damage percentage are much easier to launch with this. You can knock them out completely if they're damaged enough!",
                "level": "Intermediate"
            },
            {
                "title": "Yo-yo Attack with Charged Smash",
                "content": "While charging up the up smash or down smash attacks, it's still possible to do damage with the yo-yo.",
                "level": "Intermediate"
            },
            {
                "title": "Pursuing off the Stage",
                "content": "When an enemy is trying to get back on the stage, you can ruin their day with your side or down air attack. But try not to self-destruct!",
                "level": "Advanced"
            },
            {
                "title": "Aim for the Fences",
                "content": "When hitting an opponent with a bat, the tip will launch them the farthest. This is true of both the Home-Run Bat item and Ness's side smash.",
                "level": "Intermediate"
            }
        ],
        "fighters": [
