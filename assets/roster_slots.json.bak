        "slug": "byleth",
        "series": "Fire Emblem",
        "availability": "Paid DLC",
        "also_appears_in": [],
        "order": 80,
        "alts": [
            {
                "slot": 1,
                "variant": "Male",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/byleth/main.png"
            },
            {
                "slot": 2,
