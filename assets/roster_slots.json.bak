        ],
        "variants": [
            {
                "name": "Toon Link",
                "boxing_ring_title": "Wind-Waking Warrior",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Toon Link's Origins",
                "content": "Toon Link debuted in the Nintendo GameCube title The Legend of Zelda: The Wind Waker, released in North America in 2003. The cel-shaded art style cast Link in a whole new light.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "The Legend of Zelda: The Wind Waker starts on Link's birthday on Outset Island. He rides a ship named The King of Red Lions and sets out on a journey across the sea.",
                "level": "Beginner"
            },
            {
                "title": "Hero's Bow (Neutral Special)",
                "content": "You can attack immediately after using this move, so take advantage of that to really surprise your opponents. Fire while in the air with no fear of downtime when you land.",
                "level": "Intermediate"
            },
            {
                "title": "Hero's Bow Techniques (Neutral Special)",
                "content": "If you don't charge the attack, the arrow won't fly very far and will drop toward the ground. Do this close to an edge to attack enemies below!",
                "level": "Beginner"
            },
            {
                "title": "Boomerang (Side Special)",
                "content": "The boomerang is able to go through enemies as it returns. It flies to wherever you are, so move up or down after you throw it to hit more opponents!",
                "level": "Beginner"
            },
            {
                "title": "Bomb (Down Special)",
                "content": "If the bomb hits an opponent, Toon Link will not be damaged by the explosion. However, if the bomb hits the ground or time passes and the bomb explodes, Toon Link will be damaged by the explosion.",
                "level": "Beginner"
            },
            {
                "title": "Triforce Slash (Final Smash)",
                "content": "Toon Link shoots out the Triforce with his left hand to trap opponents, and then strikes them repeatedly with his sword. The attack won't hit if there is a wall between Toon Link and the opponent.",
                "level": "Beginner"
            },
            {
                "title": "Half-Moon Slash (Up Tilt Attack)",
                "content": "It doesn't leave you vulnerable and can be used repeatedly, so it's great for juggling. Once the opponent is in the air, follow up with an up smash or an air attack.",
                "level": "Beginner"
            },
            {
                "title": "Two Part Slash (Neutral Air Attack)",
                "content": "Toon Link swings his sword in front and behind. The attack doesn't have much power, but it's quick enough to use repeatedly in a short time frame.",
                "level": "Beginner"
            },
            {
                "title": "Sword Plant (Down Air Attack)",
                "content": "Unlike Link's and Young Link's down air attack, Toon Link's doesn't bounce up when it hits a foe. If you try to dunk someone with it, you're gonna have a bad time.",
                "level": "Beginner"
            },
            {
                "title": "Midair Hookshot (Grab Attack)",
                "content": "Using the grab button will fire the Hookshot even in midair, but you can't grab opponents with it. You can, however, use it to attack or grab edges.",
                "level": "Beginner"
            },
            {
                "title": "Midair Hookshot Techniques (Grab Attack)",
                "content": "Land with the Hookshot out, and you'll put it away quickly. It's handy as a feint—use it just before landing, and then surprise 'em with a different attack.",
                "level": "Intermediate"
            },
            {
                "title": "Hero's Shield",
                "content": "Toon Link's shield blocks lower down than Link's and Young Link's and can better cover his smaller body. However, he can't guard while moving faster than a walk.",
                "level": "Beginner"
            }
        ],
        "fighters": [
