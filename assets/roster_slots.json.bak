                "variant": "R.O.B.",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/rob/main6.png"
            },
            {
                "slot": 7,
                "variant": "R.O.B.",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/rob/main7.png"
            },
            {
                "slot": 8,
                "variant": "R.O.B.",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/rob/main8.png"
            }
        ],
        "variants": [
            {
                "name": "R.O.B.",
                "boxing_ring_title": "The Last of His Kind",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "R.O.B.'s Origins",
                "content": "R.O.B. made his debut in 1985 as a peripheral for the NES. The ability to move a real robot using in-game actions made a splash with media and gamers alike.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "A robot toy that worked with the NES using similar technology to the Zapper. It was supported by two games: Stack-Up and Gyromite. The robot's model number is HVC-012.",
                "level": "Beginner"
            },
            {
                "title": "Color Variations",
                "content": "R.O.B.'s red-and-white second color is based on the Japan version of R.O.B. In fact, it's even his default color when the language is set to Japanese!",
                "level": "Advanced"
            },
            {
                "title": "Robo Beam (Neutral Special)",
                "content": "After charging, R.O.B. fires a beam from his eyes. The red light on his head shows the charge level.",
                "level": "Beginner"
            },
            {
                "title": "Aiming the Robo Beam (Neutral Special)",
                "content": "The beam can be angled up or down. Also, if it hits the ground, it'll reflect and change direction.",
                "level": "Intermediate"
            },
            {
                "title": "Pointblank Robo Beam (Neutral Special)",
                "content": "You can't fire a beam if you don't have any energy charged, but the sparks will still harm enemies right in front of you!",
                "level": "Intermediate"
            },
            {
                "title": "Charging Robo Beam (Neutral Special)",
                "content": "The beam will constantly charge while it's not in use, reaching three levels of power. R.O.B. starts each battle at the second charge level.",
                "level": "Intermediate"
            },
            {
                "title": "Robo Beam Path Changes (Neutral Special)",
                "content": "If the beam is fired at a low angle toward the terrain, it'll bounce once. If fired at a more extreme angle, the beam will disappear.",
                "level": "Intermediate"
            },
            {
                "title": "Arm Rotor (Side Special)",
                "content": "The spinning arms can deflect enemy projectiles. Also, press the button repeatedly for a slightly longer attack!",
                "level": "Intermediate"
            },
            {
                "title": "Robo Burner (Up Special)",
                "content": "The Robo Burner's fuel slowly replenishes while R.O.B. is on the ground. Be careful if you find yourself in the air a lot—it won't refill there.",
                "level": "Beginner"
            },
            {
                "title": "Robo Burner Fuel Consumption (Up Special)",
                "content": "R.O.B. will use his burner to fly up. Don't jump—just press the special- move button repeatedly to save fuel and let yourself fly longer.",
                "level": "Advanced"
            },
            {
                "title": "Robo Burner Care (Up Special)",
                "content": "The Robo Burner won't recharge while R.O.B. is hanging from an edge. You'll need to spend some time on the ground to make sure you're fueled!",
                "level": "Intermediate"
            },
            {
                "title": "Canceling Robo Burner (Up Special)",
                "content": "Even if you stop midflight or attack, you can still use Robo Burner as long as it has fuel. Good for chasing foes off the edge to finish them!",
                "level": "Advanced"
            },
            {
                "title": "Gyro (Down Special)",
                "content": "If you shoot out a gyro, you won't be able to shoot out another gyro while the first one is still present in the stage. If it's still lying around, go and pick it up!",
                "level": "Beginner"
            },
            {
                "title": "Guided Robo Beam (Final Smash)",
                "content": "Shoot quick guided laser beams and then shoot an enormous laser beam. The laser beam can be moved up or down. Hit as many opponents as you can!",
                "level": "Beginner"
            },
            {
                "title": "AirN (Neutral Air Attack)",
                "content": "Attack 360 degrees with the burner. If the attack lands, you'll be able to act again quickly, so you can use it after short hopping to transition into the next attack.",
                "level": "Beginner"
            },
            {
                "title": "Air Boosters (Back Air Attack)",
                "content": "When R.O.B. fires the burner on his base, the force of the attack will move him forward a bit.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "42",
                "name": "R.O.B.",
                "slug": "r-o-b",
                "also_appears_in": [
                    "Brawl",
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
