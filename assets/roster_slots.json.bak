        "variants": [
            {
                "name": "Dr. Mario",
                "boxing_ring_title": "The Prescriber",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Dr. Mario's Origins",
                "content": "Dr. Mario made his debut in 1990 in the puzzle game of the same name. He was developing vitamins to combat some nasty viruses.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "The game Dr. Mario was released for the NES and the Game Boy in the same year. It's a puzzle game where Mario tries to eradicate viruses using vitamin capsules.",
                "level": "Beginner"
            },
            {
                "title": "Capsules (Neutral Special)",
                "content": "The capsules bounce higher than Mario's fireballs. Also, since they're physical projectiles, energy-absorbing specials won't work on them.",
                "level": "Beginner"
            },
            {
                "title": "Capsule Types (Neutral Special)",
                "content": "The capsules Dr. Mario throws are selected at random from nine different combinations of red, blue, and yellow. The difference is only cosmetic.",
                "level": "Advanced"
            },
            {
                "title": "Super Sheet (Side Special)",
                "content": "This move doesn't have as much horizontal range as Mario's Cape, but it has more range vertically, so lure your foes in and then strike!",
                "level": "Beginner"
            },
            {
                "title": "Super Jump Punch (Up Special)",
                "content": "It won't hit multiple times, but it does do a lot of damage. The beginning has good launching power too. It's good for mix-ups since it triggers quickly and you can initiate it while shielding.",
                "level": "Beginner"
            },
            {
                "title": "Dr. Tornado (Down Special)",
                "content": "Press the button repeatedly midattack to rise into the air. However, after it ends you are vulnerable, so be careful using it to recover.",
                "level": "Intermediate"
            },
            {
                "title": "Doctor Finale (Final Smash)",
                "content": "Two giant vitamin capsules catch opponents and send them flying. Dr. Mario is invincible while using the move, and he'll float in the air for a short while if you use the move midair.",
                "level": "Beginner"
            },
            {
                "title": "Ear, Nose, and Throat (Up Smash)",
                "content": "Launches opponents a great distance backward at an upward diagonal. If it lands while you're on a tall platform, you may be able to KO opponents through the top of the screen.",
                "level": "Intermediate"
            },
            {
                "title": "Dr. Kick (Neutral Air)",
                "content": "A rare move in that the end of the move is stronger than the beginning. Time your movement well so you hit opponents near the end of the move to launch them.",
                "level": "Intermediate"
            },
            {
                "title": "Dr. Punch (Forward Air Attack)",
                "content": "Unlike Mario's similar move, this will never have a meteor effect regardless of your timing, but it is strongest when his fist is directly in front of him.",
                "level": "Advanced"
            },
            {
                "title": "CLEAR! (Down Air Attack)",
                "content": "Unlike Mario's down air attack, Dr. Mario's down air has a meteor effect. It's powerful, but Dr. Mario's recovery is limited, so be careful with your aim.",
                "level": "Beginner"
            },
            {
                "title": "Hospital Bed (Downward Throw)",
                "content": "Unlike Mario's downward throw, Dr. Mario's always sends the foe bouncing upward, so you can follow it up more easily with an air attack.",
                "level": "Intermediate"
            }
        ],
        "fighters": [
