        "variants": [
            {
                "name": "Chrom",
                "boxing_ring_title": "The Prince of Ylisse",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Chrom's Origins",
                "content": "Chrom made his debut in Fire Emblem Awakening released in 2013. He wields the Falchion that belongs to the royal family and has the Brand that proves he is a descendant of the Hero-King Marth.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "The prince of the Halidom of Ylisse can be clumsy at times, but he cares deeply for his comrades. With Falchion in hand, he fights off the neighboring country of Plegia. Lucina is his daughter.",
                "level": "Beginner"
            },
            {
                "title": "Flare Blade (Neutral Special)",
                "content": "Slashes opponents with a sword. You can change direction while charging up the attack, but if you overcharge it, you will receive damage.",
                "level": "Beginner"
            },
            {
                "title": "Double-Edge Dance (Side Special)",
                "content": "Repeatedly attack up to four times, with additional input. The repeated attacks will change if you input up, sideways, or down on the control stick.",
                "level": "Beginner"
            },
            {
                "title": "Soaring Slash (Up Special)",
                "content": "Slash upward and then slam down into the ground. You can't cancel the move until you land, so be careful to use it near edges.",
                "level": "Beginner"
            },
            {
                "title": "Counter (Down Special)",
                "content": "Use this move right before an opponent's attack hits you to launch a quick and powerful counterattack.",
                "level": "Beginner"
            },
            {
                "title": "Awakening Aether (Final Smash)",
                "content": "Get close to an opponent and hit them with a technique called Sol. Then, follow up with the piercing Luna technique for a perfect combination.",
                "level": "Beginner"
            }
        ],
        "fighters": [
