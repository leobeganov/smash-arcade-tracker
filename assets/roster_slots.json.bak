        "variants": [
            {
                "name": "Zero Suit Samus",
                "boxing_ring_title": "The Warrior Within",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Zero Suit Samus's Origins",
                "content": "Samus first donned her blue Zero Suit in the 2004 title Metroid: Zero Mission.",
                "level": "Beginner"
            },
            {
                "title": "In Her Series",
                "content": "Her blue suit, known as the Zero Suit, first appeared in Metroid: Zero Mission. In that game, Samus tries to infiltrate the Space Pirates' Mother Ship armed with nothing but a handgun.",
                "level": "Beginner"
            },
            {
                "title": "Paralyzer",
                "content": "Samus uses this in Metroid: Zero Mission when she's not wearing her Power Suit. In that game, she uses her handgun to temporarily paralyze enemies.",
                "level": "Beginner"
            },
            {
                "title": "Zero Suit Samus's 7th Color",
                "content": "Zero Suit Samus's seventh color variation is a unique orange outfit. This outfit first appeared in certain endings of Metroid: Zero Mission.",
                "level": "Beginner"
            },
            {
                "title": "Paralyzer (Neutral Special)",
                "content": "Attack with this to paralyze foes for just a moment. When they can't move, that's your chance to strike!",
                "level": "Beginner"
            },
            {
                "title": "Plasma Whip (Side Special)",
                "content": "This move swings a whiplike stream of plasma directly in front of Zero Suit Samus. Hold down the button to raise the whip up. This move works as a follow-up attack, or a counter to aerial attacks.",
                "level": "Beginner"
            },
            {
                "title": "Grabbing Ledges with Plasma Whip (Side Special)",
                "content": "If the whip reaches an edge, you'll grab on to it. Handy! You can use the whip with either grabs or your side special.",
                "level": "Intermediate"
            },
            {
                "title": "Flip Jump (Down Special)",
                "content": "Fighters struck while on the ground will be buried, while airborne fighters will be meteored.",
                "level": "Advanced"
            },
            {
                "title": "Flip Jump's Traits (Down Special)",
                "content": "If you hit an opponent in the air with this move, it has a meteor effect. Hit an opponent on the ground to bury them. You can also press the special-move button again for an extra kick with good launch power.",
                "level": "Intermediate"
            },
            {
                "title": "Flip Jump's Meteor Effect (Down Special)",
                "content": "Press the attack button during this move to launch a kick. This kick deals a lot of damage and has a powerful meteor effect too.",
                "level": "Advanced"
            },
            {
                "title": "Zero Laser (Final Smash)",
                "content": "The laser gradually gains power and lets out a powerful burst at the end. Pay close attention to the way the reticle looks to judge when power has fully charged.",
                "level": "Beginner"
            },
            {
                "title": "Zero Laser Controls (Final Smash)",
                "content": "The reticle moves faster prior to the laser firing, so first decide where you want to aim it. For the last shot, the sight grows slightly larger.",
                "level": "Intermediate"
            },
            {
                "title": "Slant Paralyzer (Down Smash Attack)",
                "content": "This attack fires Zero Suit Samus's Paralyzer diagonally down. Its victims will be stunned for a moment, leaving them open to another attack!",
                "level": "Beginner"
            },
            {
                "title": "Slash Dive (Down Air Attack)",
                "content": "This move sends Zero Suit Samus diagonally downward while attacking. When she lands, the impact damages enemies around her.",
                "level": "Beginner"
            }
        ],
        "fighters": [
