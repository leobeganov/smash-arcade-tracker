        "variants": [
            {
                "name": "Lucas",
                "boxing_ring_title": "The Boy from Nowhere",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "In His Series",
                "content": "The main protagonist from Mother 3. He lived in Tazmily Village with his parents and twin brother Claus, until a fire led to tragedy. He sets off on adventure with his telekinetic PSI powers.",
                "level": "Beginner"
            },
            {
                "title": "PK Freeze's Traits (Neutral Special)",
                "content": "The icy projectile can freeze enemies. Try using it to stop anybody returning to the stage!",
                "level": "Beginner"
            },
            {
                "title": "PK Freeze's Duration (Neutral Special)",
                "content": "Hold down the button and a direction to extend the projectile's arc, but remember, the ice only bursts once you let go, so plan carefully!",
                "level": "Beginner"
            },
            {
                "title": "PK Fire's Traits (Side Special)",
                "content": "Shoot a blast of fire straight forward. Once it connects, it will become pillars of fire. A short-range attack that is great for hitting and launching multiple enemies.",
                "level": "Beginner"
            },
            {
                "title": "A PK Fire Diversion (Side Special)",
                "content": "This move can disrupt incoming attacks and projectiles, but it leaves Lucas vulnerable for a time. Be careful!",
                "level": "Beginner"
            },
            {
                "title": "PK Thunder's Traits (Up Special)",
                "content": "This move can help you return to the battle. Be careful, though, since the orb vanishes if it runs into solid ground.",
                "level": "Beginner"
            },
            {
                "title": "Multiple Attacks with PK Thunder (Up Special)",
                "content": "The orb from this attack won't disappear when it hits your rivals. Shock multiple opponents!",
                "level": "Beginner"
            },
            {
                "title": "PSI Magnet (Down Special)",
                "content": "This move lets Lucas absorb energy-based projectiles and heal himself. It'll even slow his descent while airborne!",
                "level": "Beginner"
            },
            {
                "title": "PSI Magnet - Movement and Disruption (Down Special)",
                "content": "After grabbing a projectile with this move, Lucas can roll backward. By releasing the button at the right time, you can also disrupt enemy attacks.",
                "level": "Intermediate"
            },
            {
                "title": "PK Starstorm (Final Smash)",
                "content": "With Kumatora and Boney, a shower of meteors descend toward Lucas. You can press up or down on the control stick to slightly raise or lower the position of where the meteors cross paths.",
                "level": "Beginner"
            },
            {
                "title": "PK Smash Geyser's Pros and Cons (Up Smash Attack)",
                "content": "This attack has very high launching power compared to many other moves. However, it will leave you wide open after using it, and envious enemies may punish you for missing.",
                "level": "Advanced"
            },
            {
                "title": "PK Smash Geyser's Traits (Up Smash Attack)",
                "content": "This attack will move upward when you use it. It's strongest if you catch an enemy with the start. Not even enemies hanging on an edge are safe!",
                "level": "Intermediate"
            },
            {
                "title": "PK Blow (Down Smash Attack)",
                "content": "Lucas fires three PSI blasts that are good for foes on ledges or under you. Each one is weaker than the last, but the range increases.",
                "level": "Beginner"
            },
            {
                "title": "PK Meteor Kick (Back Air Attack)",
                "content": "This powerful kick has a meteor effect. Try to hit with Lucas's knee for the best result!",
                "level": "Beginner"
            },
            {
                "title": "PK Foot Stomp (Down Air Attack)",
                "content": "Unleash a sequence of four kicks downward. Start the attack at the peak of a jump to make it easier to land all four blows. The last kick has a meteor effect!",
                "level": "Beginner"
            },
            {
                "title": "Rope Snake's Traits (Grab Attack)",
                "content": "The Rope Snake extends Lucas's reach for grabbing foes and edges. It can reach especially far in midair.",
                "level": "Intermediate"
            },
            {
                "title": "Midair Rope Snake (Grab Attack)",
                "content": "You can't grab and throw opponents in midair, but don't worry—this attack will still hurt them!",
                "level": "Intermediate"
            }
        ],
