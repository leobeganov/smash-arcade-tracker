        "variants": [
            {
                "name": "Little Mac",
                "boxing_ring_title": "Bruiser from the Bronx",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Little Mac's Origins",
                "content": "Even though Punch-Out!! was released in 1984, Little Mac didn't receive his name until the 1987 NES release.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "The main character from the Punch-Out!! game. Little Mac is 17 years old and from the Bronx in the United States. He aims to be the champion and trains to defeat opponents bigger than him.",
                "level": "Beginner"
            },
            {
                "title": "Unique Traits",
                "content": "At high damage levels, bruises and a bandage appear on Little Mac's face. Also, since he's a boxer, he never attacks using his legs.",
                "level": "Beginner"
            },
            {
                "title": "Straight Lunge (Neutral Special)",
                "content": "This attack gives you super armor while charging up and while dashing forward. This is especially prominent when it's fully charged.",
                "level": "Intermediate"
            },
            {
                "title": "Flipped Straight Lunge (Neutral Special)",
                "content": "When unleashing a Straight Lunge, tilt the control stick toward Little Mac's backside to change the direction of the move regardless of how much it's been charged.",
                "level": "Intermediate"
            },
            {
                "title": "Charging KO Uppercut (Neutral Special)",
                "content": "Little Mac's KO Meter builds up when he deals or receives damage. Once it's full, he can use the KO Uppercut to deal some serious hurt!",
                "level": "Beginner"
            },
            {
                "title": "Jolt Haymaker (Side Special)",
                "content": "You get a window of invincibility if you start this move on the ground, but not in the air. So be careful!",
                "level": "Advanced"
            },
            {
                "title": "Jolt Haymaker Warning (Side Special)",
                "content": "You can move around after using the move in the air, but you can't use it again until you land. Be careful when using it to return to the stage.",
                "level": "Beginner"
            },
            {
                "title": "Jolt Haymaker's Movement Range (Side Special)",
                "content": "Press the button during the jump, and you can deliver the punch more quickly. You won't move as far, though, so consider that before using it.",
                "level": "Intermediate"
            },
            {
                "title": "Rising Uppercut (Up Special)",
                "content": "Little Mac zooms upward with a powerful uppercut. He travels farther when used on the ground than when used in the air.",
                "level": "Intermediate"
            },
            {
                "title": "Slip Counter (Down Special)",
                "content": "Just when you think you've got him, Little Mac socks you with a nasty counter. He's invincible during the attack, so there's no stopping him!",
                "level": "Beginner"
            },
            {
                "title": "Giga Mac Rush (Final Smash)",
                "content": "Transform into Giga Mac and unleash a rapid series of punches. The final uppercut is incredibly powerful.",
                "level": "Beginner"
            },
            {
                "title": "Straight Smash (Side Smash Attack)",
                "content": "If you press up when performing Little Mac's side smash, it will change into an uppercut that sends enemies flying upward.",
                "level": "Intermediate"
            },
            {
                "title": "Angled Straight Smash (Side Smash Attack)",
                "content": "Little Mac's side smash changes if you tilt the stick up or down immediately after inputting the command. Tilting the stick up will launch opponents upward, and tilting it down will deal more damage.",
                "level": "Intermediate"
            },
            {
                "title": "Weak Jab (Neutral Air Attack)",
                "content": "Little Mac's neutral air attack is the fastest of his aerial attacks. It doesn't deal much damage, and it has low launch potential, but it's quick and doesn't leave you vulnerable after using it.",
                "level": "Beginner"
            },
            {
                "title": "Power Meter",
                "content": "If you get launched after the Power Meter is full or some time has passed, the Power Meter will be emptied. Use it or lose it!",
                "level": "Beginner"
            }
        ],
        "fighters": [
