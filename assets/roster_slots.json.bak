                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/sheik/main8.png"
            }
        ],
        "variants": [
            {
                "name": "Sheik",
                "boxing_ring_title": "The Illusive Sheikah",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Sheik's Origins",
                "content": "Sheik first appeared in the 1998 N64 title The Legend of Zelda: Ocarina of Time. Her true identity is Ze— I won't spoil it for you.",
                "level": "Beginner"
            },
            {
                "title": "In Her Series",
                "content": "After Link pulls the Master Sword and ages over time, this mysterious youth appears before him. Sheik appears before Link a number of times after that, teaching him various songs using a harp.",
                "level": "Beginner"
            },
            {
                "title": "Breath of the Wild",
                "content": "If you use the Sheik amiibo in The Legend of Zelda: Breath of the Wild, you can sometimes obtain Sheik's Mask. You can re-create Sheik's look by wearing that with pieces from the Stealth series.",
                "level": "Beginner"
            },
            {
                "title": "Needle Storm (Neutral Special)",
                "content": "You can start charging this attack in the air. The more charged it is, the more needles are fired, but they lose power the farther they get from Sheik.",
                "level": "Beginner"
            },
            {
                "title": "Burst Grenade (Side Special)",
                "content": "Hold the special-move button to throw the grenade farther. It doesn't move much once it lands, but it can travel three times as far in the air.",
                "level": "Intermediate"
            },
            {
                "title": "Burst Grenade as an Item (Side Special)",
                "content": "If Burst Grenade is hit before the pin is removed, it'll fly off and explode. If Sheik is hit before the pin is removed, Burst Grenade will become an item and fall to the ground.",
                "level": "Beginner"
            },
            {
                "title": "Bouncing Fish's Potential (Down Special)",
                "content": "Press the button again to make Sheik use the axe kick faster. Use it again right after the first kick hits, and you won't freeze up when you land.",
                "level": "Intermediate"
            },
            {
                "title": "Bouncing Fish's Reach (Down Special)",
                "content": "Hold left or right to greatly affect the range of the attack. In this way, you can use the attack as a feint or really surprise an opponent!",
                "level": "Intermediate"
            },
            {
                "title": "Sheikah Dance (Final Smash)",
                "content": "Sheik advances forth and slices through the opponent she hits. She can catch only one opponent with this move, but catching an opponent is pretty easy and the move is very powerful.",
                "level": "Beginner"
            },
            {
                "title": "Cycle Kick (Side Tilt Attack)",
                "content": "This attack is fast and can lift the enemy up a short distance, making it easier to strike the enemy multiple times in a combo.",
                "level": "Intermediate"
            },
            {
                "title": "Razor Wing (Up Smash Attack)",
                "content": "Landing this attack while Sheik's hand is coming up will launch opponents upward. Landing it when her hand comes down will launch them sideways.",
                "level": "Intermediate"
            },
            {
                "title": "Hatchet (Forward Air)",
                "content": "This move doesn't have much attack power, but you can trigger it quickly and it doesn't leave Sheik vulnerable for long. It's also great for combos on opponents that haven't taken much damage yet.",
                "level": "Beginner"
            }
        ],
        "fighters": [
