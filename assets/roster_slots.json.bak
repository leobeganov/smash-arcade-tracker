                "slot": 1,
                "variant": "Terry",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/terry/main.png"
            },
            {
                "slot": 2,
                "variant": "Terry",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/terry/main2.png"
            },
            {
                "slot": 3,
