        "variants": [
            {
                "name": "Ryu",
                "boxing_ring_title": "Eternal Wanderer",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "In His Series",
                "content": "Of the characters in the Street Fighter series, Ryu is one of the most well-known. His goal is to be a true fighter. In the first game, his hair was red.",
                "level": "Beginner"
            },
            {
                "title": "Hadoken (Neutral Special)",
                "content": "A projectile from a world-class fighting game. Hold down the button to vary how fast it travels. It'll disappear after a set distance.",
                "level": "Beginner"
            },
            {
                "title": "Hadoken (Neutral Special / Command-Input Move)",
                "content": "Input the commands from the original series to increase the Hadoken's power. Use it in midair to make Ryu glide slightly.",
                "level": "Beginner"
            },
            {
                "title": "Hadoken's Power (Neutral Special / Command-Input Move)",
                "content": "When facing right, quickly input ↓ ↘ → for 1.2x power. You might have to practice a bit to really get the hang of a Hadoken.",
                "level": "Beginner"
            },
            {
                "title": "Shakunetsu Hadoken (Neutral Special / Command-Input Move)",
                "content": "When facing right, input ← ↙ ↓ ↘ → to unleash a fiery Shakunetsu Hadoken that can deal multiple hits.",
                "level": "Beginner"
            },
            {
                "title": "Tatsumaki Senpukyaku (Side Special)",
                "content": "Ryu will float up slightly when using this move after a jump, making this spinning side kick great for recovering.",
                "level": "Beginner"
            },
            {
                "title": "Tatsumaki Senpukyaku (Side Special / Command-Input Move)",
                "content": "Input the commands from the original series to power up the attack. One thing to remember: you can't use it repeatedly in midair.",
                "level": "Beginner"
            },
            {
                "title": "Tatsumaki Senpukyaku's Power (Side Special / Command-Input Move)",
                "content": "When facing right, enter ↓ ↙ ← for 1.16x power. Increasing the strength also increases the move's speed and travel distance.",
                "level": "Beginner"
            },
            {
                "title": "Shoryuken (Up Special / Command-Input Move)",
                "content": "When you enter the original commands, Ryu is invincible for longer, the move is stronger and looks different...and his shout even changes!",
                "level": "Beginner"
            },
            {
                "title": "Shoryuken's Power (Up Special / Command-Input Move)",
                "content": "When facing right, input → ↓ ↘ for 1.2x attack power. Pull it off for some extra damage!",
                "level": "Beginner"
            },
            {
                "title": "Focus Attack (Down Special)",
                "content": "Ryu will hold his stance until you release the button or a certain amount of time has passed. Then he'll unleash the punch.",
                "level": "Beginner"
            },
            {
                "title": "Looking Back then Focus Attack (Down Special)",
                "content": "By turning the opposite way the moment Ryu punches, he will strike in that direction instead.",
                "level": "Intermediate"
            },
            {
                "title": "Focus Attack Follow-ups (Down Special)",
                "content": "Hitting an opponent on the ground with the fully charged version of this move will make them slowly crumple. Time for a follow-up attack!",
                "level": "Intermediate"
            },
            {
                "title": "Canceling Focus Attack (Down Special)",
                "content": "You can cancel this move by pressing left or right twice quickly, either while charging or right after the punch connects.",
                "level": "Intermediate"
            },
            {
                "title": "Defend with Focus Attack (Down Special)",
                "content": "Ryu can take one hit while readying for this move. This is true until right before he attacks, even when charging the move to maximum power.",
                "level": "Intermediate"
            },
            {
                "title": "Shin Shoryuken (Final Smash)",
                "content": "When an opponent is near, the move turns into Shin Shoryuken. It deals more damage than Shinku Hadoken, and if you land a KO, there will be flashy special effects in the background.",
                "level": "Beginner"
            },
            {
                "title": "Shinku Hadoken (Final Smash)",
                "content": "If the enemy is far away, it becomes Shinku Hadoken. This move penetrates through the stage, making it easy to hit multiple enemies at once.",
                "level": "Beginner"
            },
            {
                "title": "Final Smash between Attacks",
                "content": "Ryu's Final Smash can be used after canceling various attacks. It's perfect as a combo finisher.",
                "level": "Advanced"
            },
            {
                "title": "Collarbone Breaker (Side Tilt Attack - Heavy)",
                "content": "Keep up the pressure on a guarding enemy with Ryu's Collarbone Breaker, a double hit that's good for shield breaking.",
                "level": "Beginner"
            },
            {
                "title": "Light Ankle Kick (Down Tilt Attack - Light)",
                "content": "Use this attack by crouching and tapping the attack button. If you hit a downed opponent with it, you'll knock them back to their feet.",
                "level": "Beginner"
            },
            {
                "title": "Heavy Ankle Kick (Down Tilt Attack - Heavy)",
                "content": "You might have seen this kick in the original games. Just like in those, you can cancel the move after striking by going straight into a special.",
                "level": "Beginner"
            },
            {
                "title": "Canceling Heavy Ankle Kick (Down Tilt Attack - Heavy)",
                "content": "Hold down the attack button while crouching to use this move. You can cancel it into a special even if the foe is shielding, but only if you hit.",
                "level": "Beginner"
            },
            {
                "title": "Joudan Sokutogeri (Side Smash Attack)",
                "content": "Ryu steps forward and unleashes his Joudan Sokutogeri. The tip of his foot is the strongest part, but it won't hit a small crouching enemy.",
                "level": "Beginner"
            },
            {
                "title": "Tobigeri (Forward Air Attack)",
                "content": "Hitting an enemy with Ryu's foot has higher launch power, while his upper leg is perfect for shield breaking. It's a good move for combos.",
                "level": "Beginner"
            },
            {
                "title": "Sukui Tsuki (Up Air Attack)",
                "content": "This uppercut hits the enemy twice and has a deceptively large range. It's fairly easy to hit enemies directly above you.",
                "level": "Beginner"
            },
            {
                "title": "Straight Punch (Down Air Attack)",
                "content": "This is the only attack in Ryu's arsenal that has a meteor effect. If it hits, your victim will fly diagonally downward.",
                "level": "Beginner"
            },
            {
                "title": "Air Attack Cancel",
                "content": "Air attacks can be canceled immediately after they hit by pressing the special-move button just like some other attacks can. You can create powerful combos like Grab → Up Throw → Up Air → Shoryuken.",
                "level": "Intermediate"
            },
            {
                "title": "Heel Drop (Up Throw)",
                "content": "This move kicks a grabbed opponent straight upward. As Ryu brings his leg back down, he'll hit anyone else unlucky enough to be in the way.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "60",
                "name": "Ryu",
                "slug": "ryu",
                "also_appears_in": [
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
