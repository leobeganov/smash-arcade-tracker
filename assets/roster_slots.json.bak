        "variants": [
            {
                "name": "Mega Man",
                "boxing_ring_title": "The Blue Bomber",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Mega Man's Origins",
                "content": "Mega Man made his 1987 debut in the NES game of the same name, in which the weapons acquired from defeating each boss were the key to victory.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Mega Man was created as a lab assistant by the scientist Dr. Light. He volunteered to be converted to a fighting robot to fight for justice. Solar energy powers his movement.",
                "level": "Beginner"
            },
            {
                "title": "Mega Man Series",
                "content": "Since its debut in 1987, the Mega Man series as a whole has sold more than 32 million copies worldwide.",
                "level": "Beginner"
            },
            {
                "title": "Metal Blade (Neutral Special)",
                "content": "Mega Man's neutral special, Metal Blade, can throw circular saws in any of eight directions. It was the special weapon of Metal Man in Mega Man 2.",
                "level": "Beginner"
            },
            {
                "title": "Metal Blade as an Item (Neutral Special)",
                "content": "The Metal Blade will deal less damage if it gets stuck in the ground and is then picked up and used as a weapon. Also, your foes can pick it up!",
                "level": "Intermediate"
            },
            {
                "title": "Crash Bomber (Side Special)",
                "content": "Mega Man's side special Crash Bomber fires an explosive that sticks to walls and fighters. It was originally Crash Man's special weapon in Mega Man 2.",
                "level": "Beginner"
            },
            {
                "title": "Crash Bomber Connection (Side Special)",
                "content": "This bomb is incredibly clingy, latching on to walls, floors, and even fighters! It can be given to other fighters by bumping into them.",
                "level": "Beginner"
            },
            {
                "title": "Rush Coil (Up Special)",
                "content": "Mega Man's up special Rush Coil lets him leap to great heights with a little help from Rush, his robot-dog partner. Rush debuted in Mega Man 3.",
                "level": "Beginner"
            },
            {
                "title": "Midair Jump after Rush Coil (Up Special)",
                "content": "After using Rush Coil you can move around freely and even perform a midair jump. When trying to return to the stage, you may want to use Rush Coil before using your midair jump.",
                "level": "Beginner"
            },
            {
                "title": "Rush Coil's Downtime (Up Special)",
                "content": "When Rush is standing there after you use this move, he'll bounce you higher than when you first use it. Other players can jump on him too!",
                "level": "Intermediate"
            },
            {
                "title": "Leaf Shield (Down Special)",
                "content": "Mega Man's down special is Leaf Shield, a rotating barrier of leaves. It was originally the special weapon of Wood Man, a boss in Mega Man 2.",
                "level": "Beginner"
            },
            {
                "title": "Mega Legends (Final Smash)",
                "content": "Mega Man, X, MegaMan Volnutt, MegaMan.EXE, Star Force Mega Man, Proto Man, and Bass all appear in Mega Man's Final Smash.",
                "level": "Beginner"
            },
            {
                "title": "Mega Legends Timing (Final Smash)",
                "content": "The Black Hole Bomb will explode when it hits a foe, or you can blow it up by pressing the special-move button. Use that method to draw in nearby foes.",
                "level": "Intermediate"
            },
            {
                "title": "The Mega Buster (Neutral Attack / Side Tilt Attack / Neutral Air Attack)",
                "content": "Mega Man's neutral attack, side tilt attack, and neutral air attack all fire the Mega Buster—his main weapon ever since his first game.",
                "level": "Beginner"
            },
            {
                "title": "One Mega Buster at a Time",
                "content": "Mega Man fires solar bullets made of hyper-compressed solar energy from his Mega Buster. Both arms can transform into a Buster, but the energy is so powerful that only one Buster can be used at a time.",
                "level": "Intermediate"
            },
            {
                "title": "Mega Upper (Up Tilt Attack)",
                "content": "Mega Man's up tilt attack is Mega Upper, a move he uses in games like Mega Man 2: The Power Fighters.",
                "level": "Beginner"
            },
            {
                "title": "A Clean Mega Upper (Up Tilt Attack)",
                "content": "The start of this attack strongly launches foes straight upward. It leaves you quite open if you miss, but a clean hit can really turn things around!",
                "level": "Intermediate"
            },
            {
                "title": "Sliding (Down Tilt Attack)",
                "content": "Mega Man's down tilt attack is simply called Sliding. It's based on the nonoffensive technique he's been able to use since Mega Man 3.",
                "level": "Beginner"
            },
            {
                "title": "Charge Shot (Side Smash Attack)",
                "content": "Mega Man's side smash is the Charge Shot, an attack he gained in Mega Man 4 that lets his Mega Buster build up energy before firing.",
                "level": "Beginner"
            },
            {
                "title": "Charging Charge Shot (Side Smash Attack)",
                "content": "Mega Man unleashes a powerful Charge Shot. The damage and distance increase the longer you charge it!",
                "level": "Beginner"
            },
            {
                "title": "Spark Shock (Up Smash Attack)",
                "content": "Mega Man's up smash is the electrifying Spark Shock. He originally obtained this special weapon by defeating Spark Man, a boss in Mega Man 3.",
                "level": "Beginner"
            },
            {
                "title": "Flame Blast (Down Smash Attack)",
                "content": "Mega Man's down smash is Flame Blast, which creates twin pillars of fire from his hands. He got this special weapon from Flame Man in Mega Man 6.",
                "level": "Beginner"
            },
            {
                "title": "Flame Sword (Forward Air Attack)",
                "content": "Mega Man's forward air attack is a decisive strike with his Flame Sword. He obtained this special weapon by defeating Sword Man in Mega Man 8.",
                "level": "Beginner"
            },
            {
                "title": "Slash Claw (Back Air Attack)",
                "content": "Mega Man's back air attack is the multihitting Slash Claw. He obtained this special weapon by beating the boss Slash Man in Mega Man 7.",
                "level": "Beginner"
            },
            {
                "title": "Air Shooter (Up Air Attack)",
                "content": "Mega Man's up air attack is Air Shooter, which fires a tornado upward. He obtained this special weapon by defeating Air Man in Mega Man 2.",
                "level": "Beginner"
            },
            {
                "title": "Air Shooter's Tornado (Up Air Attack)",
                "content": "Mega Man can launch a little tornado upward. If opponents get caught in this minigale, they'll be carried up into the air!",
                "level": "Beginner"
            },
            {
                "title": "Hard Knuckle (Down Air Attack)",
                "content": "Mega Man's down air attack is Hard Knuckle, which fires his fist downward like a rocket. It was the special weapon of Hard Man in Mega Man 3.",
                "level": "Beginner"
            },
            {
                "title": "Hard Knuckle Meteor (Down Air Attack)",
                "content": "After Mega Man's fist flies a little way from his body, it has a meteor effect. To send foes flying down, you'll want to leave a little distance.",
                "level": "Advanced"
            },
            {
                "title": "Top Spin (Dash Attack)",
                "content": "Mega Man's dash attack is a whirlwind of pain called Top Spin. It was originally a special weapon he acquired from Top Man, a boss in Mega Man 3.",
                "level": "Beginner"
            },
            {
                "title": "Super Arm (Grab Attack)",
                "content": "Mega Man's grab is the Super Arm, a special weapon that lifts the heaviest of foes with ease. He got it from Guts Man in the very first Mega Man game.",
                "level": "Beginner"
            },
            {
                "title": "Mega Man's Heat Release System",
                "content": "If you use a move where both of Mega Man's arms turn into Busters, his arms will overheat and Mega Man will release heat from his arms after the move is complete.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "46",
                "name": "Mega Man",
                "slug": "mega-man",
                "also_appears_in": [
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
