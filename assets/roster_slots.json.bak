        "variants": [
            {
                "name": "Ganondorf",
                "boxing_ring_title": "The King of Darkness",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "In His Series",
                "content": "He appears in The Legend of Zelda: Ocarina of Time as the king of the Gerudo. He pretends to pledge his loyalty to the King of Hyrule while plotting to make the kingdom his own.",
                "level": "Beginner"
            },
            {
                "title": "Ganon, The Demon King",
                "content": "Ganon appears as the final boss in The Legend of Zelda. In that title, he looks more beast than human, making him a sharp contrast to Ganondorf.",
                "level": "Beginner"
            },
            {
                "title": "Warlock Punch (Neutral Special)",
                "content": "After pressing the attack button, quickly turn around to make Ganondorf unleash an even more powerful attack as he turns.",
                "level": "Intermediate"
            },
            {
                "title": "Midair Warlock Punch (Neutral Special)",
                "content": "This attack is much more powerful when used in the air. However, you'll have to use a Bunny Hood or high platforms to find enough time to pull it off.",
                "level": "Advanced"
            },
            {
                "title": "Midair Flame Choke (Side Special)",
                "content": "An enemy hit by this in the air will be slammed to the ground and can't recover quickly. It's also slightly more powerful than when used on the ground.",
                "level": "Intermediate"
            },
            {
                "title": "Flame Choke Travels (Side Special)",
                "content": "You can use this to grab an enemy and drag them offstage with you. However, the point will go to the last person to strike that enemy before your grab.",
                "level": "Advanced"
            },
            {
                "title": "Escaping from Flame Choke (Side Special)",
                "content": "If you get caught by Flame Choke in midair, you can try to wriggle about to escape. However, it's harder to escape if you've taken more damage than Ganondorf.",
                "level": "Beginner"
            },
            {
                "title": "Wizard's Foot (Down Special)",
                "content": "Used on the ground, this move is a horizontal flying kick. In the air, it goes downward instead and has a meteor effect at the very start.",
                "level": "Advanced"
            },
            {
                "title": "Aerial Wizard's Foot (Down Special)",
                "content": "When done in the air, this move has immense launching power. Sometimes it can also be effective to use against a fighter who is waiting below.",
                "level": "Beginner"
            },
            {
                "title": "Ganon, The Demon King (Final Smash)",
                "content": "After transforming into Ganon, the Demon King, he rushes forward with his swords to obliterate the enemy. The first swing stuns foes. Hit with that, and it'll be easier to hit with the finishing rush.",
                "level": "Beginner"
            },
            {
                "title": "Smash Attacks",
                "content": "All of Ganondorf's smash attacks use a sword. They leave him vulnerable, but the moves are very powerful.",
                "level": "Beginner"
            },
            {
                "title": "Volcano Kick (Up Tilt Attack)",
                "content": "It's a slow attack, but it can do more damage than a smash attack. Even if defended against, the attack can break all but a perfect shield.",
                "level": "Intermediate"
            },
            {
                "title": "Leg Sweep (Down Tilt Attack)",
                "content": "A crouching kick that sends opponents flying upward. It has good reach and is one of Ganondorf's faster attacks.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "23",
                "name": "Ganondorf",
                "slug": "ganondorf",
                "also_appears_in": [
                    "Melee",
                    "Brawl",
                    "3DS",
                    "Wii U"
                ]
            }
        ]
