        "variants": [
            {
                "name": "Mr. Game & Watch",
                "boxing_ring_title": "Master of Two Dimensions",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Mr. Game & Watch's Origins",
                "content": "Mr. Game & Watch first appeared in the early '80s in the Game & Watch handheld game series—predating even the NES and Game Boy!",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "This game character is older than Mario, coming from a series of handheld Nintendo games with LCD screens. Within the Game & Watch games, he took on various shapes and roles.",
                "level": "Beginner"
            },
            {
                "title": "Move Names",
                "content": "Mr. Game & Watch's moves Chef, Judge, Fire, Oil Panic, and Octopus are all named after games released in the Game & Watch series.",
                "level": "Beginner"
            },
            {
                "title": "Chef (Neutral Special)",
                "content": "Food jumps out of Mr. Game & Watch's frying pan in all directions. Use this to protect yourself.",
                "level": "Beginner"
            },
            {
                "title": "Chef Techniques (Neutral Special)",
                "content": "You can change the timing of the flying food by varying the length of time you hold the button. Push it repeatedly to throw more food more quickly.",
                "level": "Intermediate"
            },
            {
                "title": "Judge (Side Special)",
                "content": "This move's power depends on the number displayed. Swinging a 1 is nearly useless, but a 9 has incredible launching power!",
                "level": "Beginner"
            },
            {
                "title": "Judge (Side Special)",
                "content": "Three apples appear if the number seven shows up. You can eat these to heal up, but if you're not careful, an opponent might snap them up.",
                "level": "Beginner"
            },
            {
                "title": "Fire (Up Special)",
                "content": "A pair of firemen launch Mr. Game & Watch high into the air. Nearby opponents will also be pushed back a bit.",
                "level": "Beginner"
            },
            {
                "title": "Launching with Fire (Up Special)",
                "content": "You can launch enemies sideways by hitting them on your ascent. This is a good way to turn the tables on someone waiting for you to pop up from a ledge.",
                "level": "Intermediate"
            },
            {
                "title": "Oil Panic (Down Special)",
                "content": "This bucket can hold all manner of projectiles. Once filled, unleash the contents on an unsuspecting foe.",
                "level": "Beginner"
            },
            {
                "title": "Oil Panic and Projectiles (Down Special)",
                "content": "This will only absorb energy-based projectiles. Physical projectiles, like Link's arrows, will be reflected instead.",
                "level": "Beginner"
            },
            {
                "title": "Oil Panic's Gauge (Down Special)",
                "content": "Absorbing a particularly powerful energy blast can fill the gauge in one go. However, even the weakest of attacks will always fill it by one segment.",
                "level": "Intermediate"
            },
            {
                "title": "Oil Panic and Bombs (Down Special)",
                "content": "You can use this to absorb explosions from Link's bombs or from Bob-ombs. Don't try it with the Bob-ombs that fall during Sudden Death, though.",
                "level": "Advanced"
            },
            {
                "title": "Oil Panic and Getting KO'd (Down Special)",
                "content": "The gauge doesn't reset when Mr. Game & Watch is KO'd. Try surprising enemies with a bucket full of boiling-hot oil as soon as you respawn!",
                "level": "Beginner"
            },
            {
                "title": "Oil Panic (Down Special)",
                "content": "This move can reflect items and physical projectiles that can't be absorbed. If something comes flying at you, give it a try!",
                "level": "Beginner"
            },
            {
                "title": "Octopus (Final Smash)",
                "content": "For his Final Smash, he'll turn into a giant octopus and catch opponents in his tentacles. If an opponent doesn't escape by pressing buttons rapidly, they'll be dragged offstage.",
                "level": "Beginner"
            },
            {
                "title": "Octopus and Obstacles (Final Smash)",
                "content": "An opponent caught in the giant octopus's tentacles will be dragged off-screen. If it seems like they might escape, you could purposefully hit a floor or wall to flick them away.",
                "level": "Beginner"
            },
            {
                "title": "Octopus Tentacles (Final Smash)",
                "content": "You can extend the giant octopus tentacles farther by pressing the special-move button. They'll extend and retract even if you don't do anything, but pressing the button speeds up the movement.",
                "level": "Beginner"
            },
            {
                "title": "Spitball Sparky (Up Air Attack)",
                "content": "Release a puff of air right above you to push opponents. You can even try to KO an opponent with this if you can hit them from a high position onstage.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "26",
                "name": "Mr. Game & Watch",
                "slug": "mr-game-watch",
                "also_appears_in": [
                    "Melee",
                    "Brawl",
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
