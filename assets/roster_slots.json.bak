        ],
        "variants": [
            {
                "name": "Fox",
                "boxing_ring_title": "The Leader of Star Fox",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Fox's Origins",
                "content": "Fox made his debut in 1993, in the SNES game Star Fox. In his fighter craft, the Arwing, he fought to take down the evil scientist Andross.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Fox is the leader of the mercenary group Star Fox. He cares about his team and has a strong sense of justice. He heads to Venom to defeat Andross, the scientist responsible for the disappearance of his father.",
                "level": "Beginner"
            },
            {
                "title": "Blaster (Neutral Special)",
                "content": "The Blaster fires quickly, and its shots go a long way, but enemies won't flinch when they're hit, so use this at a safe distance.",
                "level": "Beginner"
            },
            {
                "title": "Fox Illusion (Side Special)",
                "content": "When you use this move on the ground, Fox will always stop if he reaches an edge. When used in the air, you need to be a little more careful.",
                "level": "Intermediate"
            },
            {
                "title": "Using Fox Illusion Effectively (Side Special)",
                "content": "A shielded opponent will stop Fox in his tracks, leaving him open to counterattack. Try to use this move when your opponent can't anticipate it.",
                "level": "Intermediate"
            },
            {
                "title": "Reflector (Down Special)",
                "content": "This move can reflect projectiles, and it also damages nearby opponents when activated.",
                "level": "Intermediate"
            },
            {
                "title": "Reflector in the Air (Down Special)",
                "content": "Using Reflector in midair slows down Fox's fall back to the ground. Using this when an enemy is about to attack from below can throw off their timing.",
                "level": "Advanced"
            },
            {
                "title": "Launching with Reflector (Down Special)",
                "content": "A direct hit from Reflector will launch opponents at a low angle. You can use this to disrupt an opponent trying to make their way back to the stage.",
                "level": "Beginner"
            },
            {
                "title": "Team Star Fox (Final Smash)",
                "content": "The full force of Team Star Fox engages the targeted opponents. If Wolf is one of the opponents, Fox will deliver a special line.",
                "level": "Beginner"
            },
            {
                "title": "Tornado Kick (Forward Air Attack)",
                "content": "Time your attack so that you land before hitting your opponent for a fifth time. They'll bounce off the ground, and you can make follow-up attacks.",
                "level": "Advanced"
            },
            {
                "title": "McCloud Flip (Up Air)",
                "content": "A two-part attack where Fox kicks and swats opponents with his tail. It's great for doing damage and launching opponents.",
                "level": "Beginner"
            }
        ],
