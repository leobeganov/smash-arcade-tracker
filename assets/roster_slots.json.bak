                "variant": "Male",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/pokemon-trainer/main7.png"
            },
            {
                "slot": 8,
                "variant": "Female",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/pokemon-trainer/main8.png"
            }
        ],
        "variants": [
            {
                "name": "Male",
                "boxing_ring_title": "Wants to Be the Very Best",
                "type": "Same character"
            },
            {
                "name": "Female",
                "boxing_ring_title": "Wants to Be the Very Best",
                "type": "Same character"
            }
        ],
        "tips": [
            {
                "title": "Pokémon Trainer",
                "content": "The Pokémon Trainer stands in the background and instructs Squirtle, Ivysaur, and Charizard. You can play as a female Pokémon Trainer by changing Pokémon Trainer's costume when choosing your fighter.",
                "level": "Beginner"
            },
            {
                "title": "Pokémon Trainer: Mannerisms",
                "content": "Pokémon Trainer will react when taunting or when a Pokémon takes damage. The girl and boy Pokémon Trainer have different reactions.",
                "level": "Beginner"
            },
            {
                "title": "Pokémon Trainer: Pokémon Change (Down Special)",
                "content": "You can cycle through Pokémon from Squirtle → Ivysaur → Charizard. You can switch them as many times as you like, so choose your favorite Pokémon and get to Smashin'!",
                "level": "Beginner"
            },
            {
                "title": "Pokémon Trainer: Triple Finish (Final Smash)",
                "content": "The three Pokémon combine their powers for this Final Smash. The effect of the attack is the same for all three Pokémon.",
                "level": "Beginner"
            },
            {
                "title": "Squirtle's Origins",
                "content": "Squirtle debuted in Pokémon Red and Blue, released in North America in 1998. It's a Tiny Turtle Pokémon that excels at Water-type moves.",
                "level": "Beginner"
            },
            {
                "title": "Squirtle: In Its Series",
                "content": "Squirtle is one of three Pokémon you can get from Professor Oak in Pokémon Red and Blue. Squirtle was one of the few Water-type Pokémon you could get until you got a Fishing Rod.",
                "level": "Beginner"
            },
            {
                "title": "Squirtle: Water Gun (Neutral Special)",
                "content": "Squirtle shoots water from its mouth to push opponents away. It doesn't do any damage, but it's great for interfering with opponents trying to return to the stage.",
                "level": "Beginner"
            },
            {
                "title": "Squirtle: Withdraw (Side Special)",
                "content": "Spin across the ground quickly to tackle opponents. Squirtle won't take damage while it is in its shell.",
                "level": "Beginner"
            },
            {
                "title": "Squirtle: Advancing with Withdraw (Side Special)",
                "content": "Tilt the control stick in the opposite direction of the movement to shorten the distance you slide. If you hit an opponent or their shield, you will be reflected.",
                "level": "Intermediate"
            },
            {
                "title": "Squirtle: Withdraw's Weakness (Side Special)",
                "content": "If Squirtle gets stepped on from above, it will flip over and become completely vulnerable. Squirtle can't move until it gets back up, leaving you wide open to attack.",
                "level": "Intermediate"
            },
            {
                "title": "Squirtle: Waterfall (Up Special)",
                "content": "Tilt the control stick forward or backward while rising up to slightly change the angle you rise. It can be used as a recovery move, but it can also be used to attack opponents above.",
                "level": "Beginner"
            },
            {
                "title": "Squirtle: Triple Finish (Final Smash)",
                "content": "The three Pokémon combine their powers for this Final Smash. Squirtle's Hydro Pump is wide, covering the top and the bottom, and can draw in opponents.",
                "level": "Beginner"
            },
            {
                "title": "Ivysaur's Origins",
                "content": "Ivysaur debuted in Pokémon Red and Blue, released in North America in 1998. Due to the favorable matchups, Ivysaur was very useful against Rock-type and Water-type opponents in beginning Gyms.",
                "level": "Beginner"
            },
            {
                "title": "Ivysaur: In Its Series",
                "content": "Ivysaur is the evolved form of Bulbasaur, one of the three Pokémon you can choose in the beginning. Compared to the other two Pokémon, you can reach the third form, Venusaur, quickest.",
                "level": "Beginner"
            },
            {
                "title": "Ivysaur: Bullet Seed (Neutral Special)",
                "content": "Ivysaur's Bullet Seed move not only shoots seeds, but if an opponent touches its body while it's using the move, that opponent can get launched!",
                "level": "Beginner"
            },
            {
                "title": "Ivysaur: Bullet Seed Firing Time (Neutral Special)",
                "content": "Holding the special-move button will make Bullet Seed last longer. You'll be open to attack from the side, but if it hits, it deals a lot of damage.",
                "level": "Beginner"
            },
            {
                "title": "Ivysaur: Razor Leaf (Side Special)",
                "content": "Quickly flick the control stick to the side as you press the button to shoot leaves farther. The trajectory of the leaves is random. They may fly diagonally instead of straight to the side.",
                "level": "Beginner"
            },
            {
                "title": "Ivysaur: Vine Whip (Up Special)",
                "content": "Vine Whip can be used as many times as you want in midair and the direction it shoots out can be changed slightly. It can be used to grab the edge when falling off the stage.",
                "level": "Beginner"
            },
            {
                "title": "Ivysaur: Triple Finish (Final Smash)",
                "content": "The three Pokémon combine their powers for this Final Smash. Ivysaur's Solar Beam has a long range and traps opponents hit by the attack.",
                "level": "Beginner"
            },
            {
                "title": "Ivysaur: Exploding Flower (Up Smash)",
                "content": "It has very high launch power, but the move is slow to activate. Use this move a bit early and try to predict where the opponent will land or where they will go after dodging.",
                "level": "Beginner"
            },
            {
                "title": "Ivysaur: Pollen from Bloom",
                "content": "Ivysaur's up smash, up air, and down air attacks all release pollen from the bud on its back. These moves excel at launching opponents.",
                "level": "Intermediate"
            },
            {
                "title": "Charizard's Origins",
                "content": "Charizard made its debut in North America in the 1998 games Pokémon Red and Pokémon Blue. It was even featured on the cover of Pokémon Red.",
                "level": "Beginner"
            },
            {
                "title": "Charizard: In Its Series",
                "content": "Charizard, the Flame Pokémon, graced the package cover of Pokémon Red. Its fiery breath can melt anything, but it never turns its flame on an opponent weaker than itself.",
                "level": "Beginner"
            },
            {
                "title": "Charizard: Flamethrower (Neutral Special)",
                "content": "Charizard will keep breathing fire as long as you hold the button down, but it'll get weaker and weaker as you use it.",
                "level": "Beginner"
            },
            {
                "title": "Charizard: Flare Blitz (Side Special)",
                "content": "This move engulfs Charizard in flames. It's extremely powerful, but it hurts Charizard too.",
                "level": "Beginner"
            },
            {
                "title": "Charizard: Flare Blitz (Side Special)",
                "content": "There's a big explosion when Charizard hits a fighter or an obstacle. This can hit other nearby fighters too!",
                "level": "Beginner"
            },
            {
                "title": "Charizard: Fly (Up Special)",
                "content": "Fly doesn't have much horizontal movement, and it leaves Charizard vulnerable afterward, but it has great launch power. It can make a good counterattack after blocking an attack with your shield.",
                "level": "Beginner"
            },
            {
                "title": "Charizard: Triple Finish (Final Smash)",
                "content": "The three Pokémon combine their powers for this Final Smash. Charizard dishes out continuous Fire Blasts for massive damage.",
                "level": "Beginner"
            },
            {
                "title": "Charizard: Wing Thrust (Up Tilt Attack)",
                "content": "Charizard's wings won't take damage, making this attack good for overpowering foes who are attacking from above.",
                "level": "Advanced"
            },
            {
                "title": "Charizard: Aerial Tail (Back Air Attack)",
                "content": "In this aerial move, Charizard sweeps away opponents behind it with its long tail. The fiery tip of its tail has high attack and launch power.",
                "level": "Beginner"
            },
            {
                "title": "Charizard: Midair Jump",
                "content": "Charizard can perform two successive midair jumps. The second one doesn't get as much height as the first, though.",
                "level": "Beginner"
            },
            {
                "title": "Hydrophobic Fighters",
                "content": "Don't talk to Charizard or Inkling about swimming. They'll take gradual damage while they're in the water.",
                "level": "Beginner"
            }
        ],
        "fighters": [
