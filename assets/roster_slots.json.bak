        "variants": [
            {
                "name": "Incineroar",
                "boxing_ring_title": "The Ring's Raging Flame",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Incineroar's Origins",
                "content": "Incineroar's debut was in Pokémon Sun and Moon released in 2016. Incineroar has a pro-wrestler vibe going on, and can use the powerful Blaze ability.",
                "level": "Beginner"
            },
            {
                "title": "In Its Series",
                "content": "Incineroar is the final form of Litten, one of the three Pokémon you can choose at the beginning of Pokémon Sun and Moon. It's a well-balanced Pokémon with very high attack and defense.",
                "level": "Beginner"
            },
            {
                "title": "Darkest Lariat (Neutral Special)",
                "content": "Become invincible right after using the move and deal big damage. When Incineroar is swinging its arms, you can make it go forward or backward with the control stick.",
                "level": "Beginner"
            },
            {
                "title": "Alolan Whip (Side Special)",
                "content": "Grab an opponent and throw them into the ropes before following up with an attack. The follow-up attack will change depending on the timing you press the button when the opponent comes back.",
                "level": "Beginner"
            },
            {
                "title": "Controls during Cross Chop (Up Special)",
                "content": "When falling down, tilt the control stick left or right to slightly change your landing location. Also, you can go through platforms by tilting the control stick downward.",
                "level": "Beginner"
            },
            {
                "title": "Recovery after Cross Chop (Up Special)",
                "content": "Even after diving downward with Cross Chop, you can use your midair jump and side special. You might get lucky and make it back to the stage!",
                "level": "Advanced"
            },
            {
                "title": "Revenge (Down Special)",
                "content": "If hit shortly after using Revenge, the attack power of Incineroar's next move will increase and Incineroar will glow red. However, if Incineroar is thrown or gets hit hard, the effect will vanish.",
                "level": "Beginner"
            },
            {
                "title": "Max Malicious Moonsault (Final Smash)",
                "content": "Incineroar charges forward, grabs an opponent, and hits them with a series of attacks. It's easier to land the attack right after the opponent breaks free from a grab.",
                "level": "Beginner"
            },
            {
                "title": "Taunting after an Attack Hits",
                "content": "After certain attacks hit, Incineroar will pose and taunt like a pro wrestler. You can move during these taunts, so they don't actually leave you vulnerable.",
                "level": "Intermediate"
            },
            {
                "title": "The Three Slowest Walkers",
                "content": "#1 is Incineroar, #2 is Robin, and #3 is Jigglypuff. Incineroar may be slow, but has some serious launching power.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "69",
                "name": "Incineroar",
                "slug": "incineroar",
                "also_appears_in": []
            }
        ]
    },
