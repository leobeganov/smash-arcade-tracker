            },
            {
                "name": "Dragon Quest VIII",
                "boxing_ring_title": "The Dragovian Descendant",
                "type": "Same character"
            }
        ],
        "tips": [
            {
                "title": "Hero: (P1/P5 Costume) Origins",
                "content": "This hero first appeared in DRAGON QUEST XI: Echoes of an Elusive Age, released in 2018 in Europe and North America. He leaves his hometown to meet with the king before being labeled \"The Darkspawn\" and hunted.",
                "level": "Beginner"
            },
            {
                "title": "Hero: (P2/P6 Costume) Origins",
                "content": "This hero first appeared in DRAGON QUEST III: The Seeds of Salvation, released as Dragon Warrior III in 1992 in North America. The hero carries on his father's will and embarks on a journey to defeat the archfiend Baramos.",
                "level": "Beginner"
            },
            {
                "title": "Hero: (P3/P7 Costume) Origins",
                "content": "This hero first appeared in DRAGON QUEST IV: Chapters of the Chosen, released in 1992 in North America. A descendant of the Zenithians, the hero teams up with his friends to save the world after his hometown is destroyed.",
                "level": "Beginner"
            },
            {
                "title": "Hero: (P4/P8 Costume) Origins",
                "content": "This hero first appeared in DRAGON QUEST VIII: Journey of the Cursed King, released in 2005 in North America. A royal guardsman, he embarks on a journey to undo a curse placed upon his king and princess.",
                "level": "Beginner"
            },
            {
                "title": "Charging Up Specials (Neutral, Up, Side Special)",
                "content": "The more they're charged, the more powerful these moves become. If you have enough MP, you can charge them up to a maximum of three levels.",
                "level": "Beginner"
            },
            {
                "title": "Frizz/Frizzle/Kafrizz (Neutral Special)",
                "content": "Start charging with the special-move button. Press the button again to unleash a fireball spell. You can store your charge if you shield, dodge, or jump while charging.",
                "level": "Beginner"
            },
            {
                "title": "Zap/Zapple/Kazap (Side Special)",
                "content": "Press and hold the special-move button to imbue your sword with lightning magic. The move will be unleashed when you release the button or when it reaches maximum charge. The charge cannot be stored.",
                "level": "Beginner"
            },
            {
                "title": "Kazap (Side Special)",
                "content": "Charge it all the way to point the sword skyward and summon lightning. You'll then unleash a spin attack that has a wide range. Foes that you hit with the spin attack will be struck by a lightning bolt.",
                "level": "Beginner"
            },
            {
                "title": "Woosh/Swoosh/Kaswoosh (Up Special)",
                "content": "Use a wind spell to summon a tornado underneath you that will slash nearby enemies and lift you up. The more it's charged, the higher you will rise. If you don't have enough MP, you will hop slightly.",
                "level": "Beginner"
            },
            {
                "title": "Swoosh and Kaswoosh Characteristics (Up Special)",
                "content": "Swoosh allows you to move left or right easily, and Kaswoosh allows you to rise higher in the air. Choose which move to use depending on the situation.",
                "level": "Beginner"
            },
            {
                "title": "Canceling Command Selection (Down Special)",
                "content": "You can close the command window with the jump or shield buttons. However, you'll need to wait a little while before opening it again.",
                "level": "Beginner"
            },
            {
                "title": "Bang/Kaboom (Down Special)",
                "content": "A light spell that unleashes a bolt that explodes when it hits an opponent or after a time. Kaboom draws opponents near before exploding and causes a bigger explosion than Bang.",
                "level": "Beginner"
            },
            {
                "title": "Sizz/Sizzle (Down Special)",
                "content": "A fire spell that sends out a quick spark. When it hits the landscape or an opponent, it bursts into flames. Sizzle's shot is bigger than Sizz, and it is more powerful.",
                "level": "Beginner"
            },
            {
                "title": "Whack/Thwack (Down Special)",
                "content": "These moves have a chance to instantly KO opponents they hit. The KO success rate increases as you and your opponent take damage. Thwack has a wider range than Whack.",
                "level": "Beginner"
            },
            {
                "title": "Kamikazee (Down Special)",
                "content": "Deal damage to nearby opponents by self-destructing. You will be KO'd. Your opponent gets credit for the KO in a 1-on-1 battle.",
                "level": "Beginner"
            },
            {
                "title": "Magic Burst (Down Special)",
                "content": "Use all your MP to create an explosion with you at the center. The power and size of the explosion grows with every point of MP used.",
                "level": "Beginner"
            },
            {
                "title": "Snooze (Down Special)",
                "content": "Shoot a projectile that puts opponents to sleep. The size of the projectile increases the longer it travels. However, the closer the opponent is, the deeper they'll sleep.",
                "level": "Beginner"
            },
            {
                "title": "Heal (Down Special)",
                "content": "Heal some of the damage you've taken. If you use it multiple times, it will not come up as a selectable command again until you get KO'd.",
                "level": "Beginner"
            },
            {
                "title": "Oomph (Down Special)",
                "content": "Increase your launch power and melee attack power for a while. However, your defense will decrease a little.",
                "level": "Beginner"
            },
            {
                "title": "Acceleratle (Down Special)",
                "content": "Increase your movement speed and jump for a while. You will also become easier to launch.",
                "level": "Beginner"
            },
            {
                "title": "Bounce (Down Special)",
                "content": "Automatically reflects opponents' projectiles for a while. The reflected projectiles will be powered up after being reflected.",
                "level": "Beginner"
            },
            {
                "title": "Kaclang (Down Special)",
                "content": "Block attacks by becoming metal for a while. However, you cannot move until the status wears off, and you cannot cancel it yourself.",
                "level": "Beginner"
            },
            {
                "title": "Zoom (Down Special)",
                "content": "Rise straight upward in order to return to the stage. You can't be hit by opponents while rising, but you can still run into the stage's terrain.",
                "level": "Beginner"
            },
            {
                "title": "Hocus Pocus (Down Special)",
                "content": "Try your luck and hope for the best. This move may randomly trigger other commands, or it may change your status or size.",
                "level": "Beginner"
            },
            {
                "title": "Flame Slash / Kacrackle Slash (Down Special)",
                "content": "Wreathe your sword in flame for Flame Slash or in ice for Kacrackle Slash. When Kacrackle Slash hits, it freezes opponents for a short time.",
                "level": "Beginner"
            },
            {
                "title": "Hatchet Man (Down Special)",
                "content": "Slash opponents with full force. It takes a bit of time to attack, but if it hits, it lands a critical hit that deals massive damage.",
                "level": "Beginner"
            },
            {
                "title": "Metal Slash (Down Special)",
                "content": "Hit an opponent that is metal or has the Kaclang status to instantly KO them. However, nonmetal opponents will only receive one percent damage.",
                "level": "Beginner"
            },
            {
                "title": "Psyche Up (Down Special)",
                "content": "Charge up power to make your next melee attack stronger. The effect ends once you hit an opponent, but it will not end if you miss.",
                "level": "Beginner"
            },
            {
                "title": "Gigaslash (Final Smash)",
                "content": "Hero makes a wide sweep with his sword. If it hits an opponent, protagonists from different generations will lend you their strength so you can unleash a deadly blow.",
                "level": "Beginner"
            },
            {
                "title": "Side Tilt Attack",
                "content": "Press the attack button a second time to unleash an additional attack. The first attack uses the shield to repel incoming attacks.",
                "level": "Beginner"
            },
            {
                "title": "Down Air Attack",
                "content": "Jab the sword downward. The move has a meteor effect at the beginning of the move.",
                "level": "Beginner"
            },
            {
                "title": "MP",
                "content": "You will miss and become vulnerable if you try to use a special move without enough MP. You'll recover MP as time passes and as you deal damage to opponents.",
                "level": "Beginner"
            },
            {
                "title": "Critical Hit",
                "content": "Smash attacks have a 1/8 chance to be critical hits. If a critical hit strikes an opponent, it'll deal massive damage!",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "72",
                "name": "Hero",
                "slug": "hero",
                "also_appears_in": []
            }
        ]
    },
