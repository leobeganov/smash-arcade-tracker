        "variants": [
            {
                "name": "Lucario",
                "boxing_ring_title": "The Master of Aura",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Lucario's Origins",
                "content": "Lucario first appeared in Pokémon Diamond and Pearl. Lucario has the power to detect its opponent's thoughts and actions by reading their Aura.",
                "level": "Beginner"
            },
            {
                "title": "In Its Series",
                "content": "Lucario is the evolved form of Riolu, the Emanation Pokémon, and can detect Aura from living things. It's said that Lucario can use this power to learn someone's hiding place or understand what people are saying.",
                "level": "Beginner"
            },
            {
                "title": "Aura Sphere (Neutral Special)",
                "content": "Aura Sphere can damage opponents while it's charging. Try dropping onto a foe from above while charging it!",
                "level": "Intermediate"
            },
            {
                "title": "Force Palm (Side Special)",
                "content": "Force Palm deals more damage and has a greater range if Lucario's Aura is stronger.",
                "level": "Beginner"
            },
            {
                "title": "Force Palm Throws (Side Special)",
                "content": "If used close to opponents, it will become a throw. It has high launching power, so you might be able to land a one-hit KO if you have enough Aura charged up.",
                "level": "Intermediate"
            },
            {
                "title": "Projectiles and Force Palm (Side Special)",
                "content": "Force Palm becomes a projectile against opponents when used from a distance. It has a risk of being reflected. The more Aura you have charged up, the more reach and power the move will have.",
                "level": "Intermediate"
            },
            {
                "title": "Extreme Speed (Up Special)",
                "content": "This move will send Lucario flying in the direction you indicate. The more damage Lucario has taken, the farther it will fly.",
                "level": "Beginner"
            },
            {
                "title": "Launching with Extreme Speed (Up Special)",
                "content": "The end of this move launches nearby foes. With enough Aura, you can dash in and attack from far away, but try not to zoom right off the screen!",
                "level": "Intermediate"
            },
            {
                "title": "Aura Storm (Final Smash)",
                "content": "Lucario will use Aura Storm downward from above. You can adjust the beam left or right while shooting it.",
                "level": "Beginner"
            },
            {
                "title": "Grab Attack",
                "content": "Thanks to Aura, an injured Lucario can pull off this move more quickly and do a lot more damage than other fighters can.",
                "level": "Intermediate"
            },
            {
                "title": "Aura",
                "content": "Lucario's Aura power increases as it takes damage. At 190%, Lucario's attacks are 2.5 times normal strength, but it's possible to grow even stronger...",
                "level": "Beginner"
            }
        ],
        "fighters": [
