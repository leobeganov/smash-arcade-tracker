        "tips": [
            {
                "title": "Isabelle's Origins",
                "content": "Isabelle first appeared in Animal Crossing: New Leaf in 2013. She is a secretary that supports the main character, who happens to become the mayor of the town.",
                "level": "Beginner"
            },
            {
                "title": "In Her Series",
                "content": "Isabelle is loved by all the residents and is always happy to help. She loves festivals and changes her outfit depending on the season and event.",
                "level": "Beginner"
            },
            {
                "title": "Pocket (Neutral Special)",
                "content": "Use this move to put items or incoming projectiles into Isabelle's pocket. Press the button again to take the item or projectile back out of her pocket.",
                "level": "Beginner"
            },
            {
                "title": "Toss with Fishing Rod (Side Special)",
                "content": "Cast the fishing hook to catch opponents, then reel them in and launch them forward, backward, up, or down. Opponents and even items can be caught while reeling in the line as well!",
                "level": "Beginner"
            },
            {
                "title": "Fishing Rod's Hook (Side Special)",
                "content": "If the fishing hook catches the edge of the stage, you can pull yourself up with it. You can also catch nearby opponents with the hook and bring them down with you.",
                "level": "Beginner"
            },
            {
                "title": "Balloon Trip (Up Special)",
                "content": "Unlike the Villager, Isabelle will float up sitting on a swing-like seat attached to bunny-shaped balloons. The move is pretty much the same as the Villager's, but it's, like, super cute.",
                "level": "Beginner"
            },
            {
                "title": "Lloid Trap (Down Special)",
                "content": "If someone walks over the buried Lloid, it will rise up and deal damage. After burying Lloid, you can do another down special to make Lloid rise on command.",
                "level": "Beginner"
            },
            {
                "title": "Dream Town Hall (Final Smash)",
                "content": "Tom Nook and his gang will show up and build the town hall from Animal Crossing: New Leaf on top of an opponent. At the end, it will explode, launching anyone nearby.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "68",
                "name": "Isabelle",
                "slug": "isabelle",
                "also_appears_in": []
            }
        ]
    },
