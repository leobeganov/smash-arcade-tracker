            {
                "slot": 8,
                "variant": "Sonic",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/sonic/main8.png"
            }
        ],
        "variants": [
            {
                "name": "Sonic",
                "boxing_ring_title": "The Blue Blur",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Sonic's Origins",
                "content": "Sonic's first appearance was a cameo in the 1991 arcade racing game Rad Mobile. You can see him dangling near the top of the windshield.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "His first starring role was at blistering speeds in the side-scrolling action game Sonic The Hedgehog. The high-speed action unfolds using simple controls with only directional buttons and jumping.",
                "level": "Beginner"
            },
            {
                "title": "Homing Attack (Neutral Special)",
                "content": "Sonic rises into the air while charging the move. Once charged, it'll automatically attack. You can press the button midway to instantly attack, but if you miss an opponent, you're left vulnerable for a while.",
                "level": "Beginner"
            },
            {
                "title": "Spin Dash (Side Special)",
                "content": "When Spin Dash is used on the ground, Sonic becomes invincible for a brief period of time right after he starts rolling. You can use this to avoid an opponent's attack and counterattack!",
                "level": "Beginner"
            },
            {
                "title": "Spring Jump (Up Special)",
                "content": "Use this in midair to drop a spring on someone below. Give yourself a boost while disrupting your rivals!",
                "level": "Intermediate"
            },
            {
                "title": "Spring Jump Care (Up Special)",
                "content": "Even after a Spring Jump, Sonic can still attack and dodge in the air. However, he can't perform a midair jump or use any more special moves.",
                "level": "Intermediate"
            },
            {
                "title": "Spin Charge (Down Special)",
                "content": "If you jump while spinning forward, you'll keep spinning in the air. You can hit opponents like that or use other attacks.",
                "level": "Intermediate"
            },
            {
                "title": "Boosting Spin Charge (Down Special)",
                "content": "If you hold down and keep tapping the button, you can charge up this move, making it faster and stronger.",
                "level": "Intermediate"
            },
            {
                "title": "Spin Charge Care (Down Special)",
                "content": "Jump while charging a Spin Charge to do a Spin Jump. After a midair jump, you won't be able to Spin Jump until you hit the ground.",
                "level": "Intermediate"
            },
            {
                "title": "Super Sonic (Final Smash)",
                "content": "Sonic transforms into Super Sonic and bashes into opponents at high speeds. The moment his transformation ends can also launch nearby opponents.",
                "level": "Beginner"
            },
            {
                "title": "Shooting Star Kick (Down Air Attack)",
                "content": "If you jump, Spring Jump, and then use an attack like this one in quick succession, it will end right before you land, which means no landing delay!",
                "level": "Advanced"
            },
            {
                "title": "The Three Fastest Fighters",
                "content": "#1 is Sonic, #2 is Captain Falcon, and #3 is Little Mac. In contrast, the slowest of all the fighters is Incineroar.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "38",
                "name": "Sonic",
                "slug": "sonic",
                "also_appears_in": [
                    "Brawl",
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
