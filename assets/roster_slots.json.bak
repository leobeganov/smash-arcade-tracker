        "variants": [
            {
                "name": "Wario",
                "boxing_ring_title": "Scoundrel with a Fart of Gold",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Wario's Origins",
                "content": "Wario made his debut in 1992 as the villain of Super Mario Land 2: 6 Golden Coins, where he stole a castle from Mario.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "He calls himself Mario's childhood friend and biggest rival, and he cares for nothing but money and treasure. He loves to eat, and is particularly fond of garlic.",
                "level": "Beginner"
            },
            {
                "title": "First Starring Role",
                "content": "Wario's first starring role was in Wario Land: Super Mario Land 3 in 1994. Its appeal was Wario's powerful abilities, powering up with garlic, and tackling enemies to defeat them.",
                "level": "Beginner"
            },
            {
                "title": "Chomp's Traits (Neutral Special)",
                "content": "Like his throw moves, Chomp can't be blocked by an opponent's shield. While chewing, Wario will slowly heal damage.",
                "level": "Intermediate"
            },
            {
                "title": "Chomp's Healing (Neutral Special)",
                "content": "Can be used to bite opponents or eat items. If he eats food, it'll restore more health than usual!",
                "level": "Intermediate"
            },
            {
                "title": "Chomping for Power (Neutral Special)",
                "content": "Eating items will make Wario more gassy. The gassier he is, the stronger his down special will be.",
                "level": "Intermediate"
            },
            {
                "title": "Chomp Indigestion (Neutral Special)",
                "content": "Wario's hunger knows no bounds, but eating explosives will cause him a bit of damage. The blast will hurt those around him too!",
                "level": "Intermediate"
            },
            {
                "title": "Repurposing Wario Bike (Side Special)",
                "content": "Wario's motorcycle can break into parts. You can't pick them up, but Wario can eat them to heal or fill his...gas tank.",
                "level": "Beginner"
            },
            {
                "title": "Controlling Wario Bike (Side Special)",
                "content": "Press up to do a wheelie and then down to lower the wheel again. Any enemy hit by that front wheel has a good chance of getting launched.",
                "level": "Beginner"
            },
            {
                "title": "Wario Bike Taunting (Side Special)",
                "content": "Wario does a special taunt when he's riding his bike. It doesn't have any particular effect on the bike's power, though.",
                "level": "Beginner"
            },
            {
                "title": "Wario Waft (Down Special)",
                "content": "Fully charged, it will rocket Wario into the air, launching nearby foes and totally grossing them out. This can be very handy while recovering.",
                "level": "Intermediate"
            },
            {
                "title": "Wario Waft's Gas (Down Special)",
                "content": "When Wario's bursting at the seams with gas, he'll glow. Getting KO'd won't release any gas, either—there's only one way to let it out...",
                "level": "Beginner"
            },
            {
                "title": "Wario-Man (Final Smash)",
                "content": "After transforming into Wario Man, he splits himself into copies that attack all at once. The final fart isn't affected by the charge of his down-special fart.",
                "level": "Beginner"
            },
            {
                "title": "Hand Slap (Up Air Attack)",
                "content": "While it only attacks directly above Wario, this move has a lot of power, and you aren't left vulnerable for long after landing. If you can mix this into a combo, you can expect to deal good damage.",
                "level": "Beginner"
            },
            {
                "title": "Shoulder Tackle (Dash Attack)",
                "content": "Wario often uses this move in the Wario Land series. It's still powerful in Smash Bros., and boasts serious launching power.",
                "level": "Beginner"
            }
        ],
        "fighters": [
