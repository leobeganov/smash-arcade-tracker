        "variants": [
            {
                "name": "Mario",
                "boxing_ring_title": "Mr. Video Game Himself",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Mario's Origins",
                "content": "Mario made his debut in the arcade game Donkey Kong. He wore a blue shirt and red overalls—the opposite of his current outfit.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "When you think of Mario, you might think of his signature phrases like \"Mamma Mia!\" and \"It's-a me, Mario!\" These classic Mario phrases were first uttered by Mario in Super Mario 64.",
                "level": "Beginner"
            },
            {
                "title": "The Gold Standard of Action Games",
                "content": "The Super Mario series has released 35 titles, appeared on at least 15 systems, and it's sold more than 340 million copies worldwide!",
                "level": "Beginner"
            },
            {
                "title": "Luigi's Air Superiority",
                "content": "The title Super Mario Bros. 2 refers to different games in the West and in Japan, but both games introduced Luigi's ability to jump higher than Mario!",
                "level": "Beginner"
            },
            {
                "title": "Mario's Name",
                "content": "When Mario first appeared in the arcade version of Donkey Kong, he was known as Jumpman. The kidnapped woman was called \"Lady,\" but she was later given the name Pauline.",
                "level": "Beginner"
            },
            {
                "title": "A Familiar Face",
                "content": "In Punch-Out!!, released on the NES in 1987, the referee was none other than Mario! His outfit was a bit different, but he still wore his trademark cap.",
                "level": "Beginner"
            },
            {
                "title": "F.L.U.D.D. from Super Mario Sunshine",
                "content": "A device in Super Mario Sunshine made by Gadd Science, Inc. It's a handy partner that can defeat enemies with water or change abilities by changing the nozzle.",
                "level": "Beginner"
            },
            {
                "title": "Builder Mario",
                "content": "Select the seventh color variation to play as Builder Mario from Super Mario Maker.",
                "level": "Beginner"
            },
            {
                "title": "Wedding",
                "content": "Select the eighth color variation to play as Wedding Mario from Super Mario Odyssey.",
                "level": "Beginner"
            },
            {
                "title": "Cape's Effect (Side Special)",
                "content": "This move has the effect of turning your opponents around. This can really mess them up if they're trying to get back onto the stage!",
                "level": "Intermediate"
            },
            {
                "title": "Dodging with Cape (Side Special)",
                "content": "Use this in midair to slow down Mario's falling speed for a moment. In particular, the first time you use it, he'll float up a bit—great for dodging!",
                "level": "Advanced"
            },
            {
                "title": "Reversing Controls with Cape (Side Special)",
                "content": "Mario's Cape doesn't just flip an opponent's body around. It also reverses an opponent's controls for a short period of time.",
                "level": "Beginner"
            },
            {
                "title": "Super Jump Punch (Up Special)",
                "content": "Sometimes the coins that appear will become the regional coins from Super Mario Odyssey. When that happens, Mario's cap will turn into Cappy.",
                "level": "Beginner"
            },
            {
                "title": "F.L.U.D.D.ing a Recovery",
                "content": "F.L.U.D.D.'s water is great for stopping fighters like Ness and Ike from recovering with their up specials. Try to keep it charged and ready!",
                "level": "Intermediate"
            },
            {
                "title": "F.L.U.D.D. (Down Special)",
                "content": "A blast of water is an effective way to disrupt your opponents. It doesn't hurt, but it can slide them around.",
                "level": "Beginner"
            },
            {
                "title": "F.L.U.D.D.ing Items",
                "content": "F.L.U.D.D. isn't just for pushing fighters—it can also push some items, like capsules and crates, and even deflect incoming Bob-ombs.",
                "level": "Intermediate"
            },
            {
                "title": "Water from F.L.U.D.D. (Down Special)",
                "content": "Tilt the control stick up or down to change the angle of the water spray. The more water you charge up, the more forcefully it will spray out.",
                "level": "Beginner"
            },
            {
                "title": "Mario Finale (Final Smash)",
                "content": "Unleash a wave of fire that damages and pushes opponents. Hit opponents when they are close to deal big damage. It's perfect for stopping opponents from returning to the stage.",
                "level": "Beginner"
            },
            {
                "title": "Mario Finale Warning (Final Smash)",
                "content": "You'll slide backward little by little when releasing Mario Finale. Trigger it too close to an edge, or while on a narrow platform, and you might find yourself in midair!",
                "level": "Beginner"
            },
            {
                "title": "Lead Headbutt (Up Smash Attack)",
                "content": "A powerful upward headbutt. Mario's head is invulnerable while performing it. Useful against opponents moving in to attack from above.",
                "level": "Advanced"
            },
            {
                "title": "Meteor Knuckle (Forward Air Attack)",
                "content": "It's a slow attack, but Mario swings his fist down hard enough for a meteor smash as it begins.",
                "level": "Advanced"
            },
            {
                "title": "Airplane Swing (Back Throw)",
                "content": "When grabbing opponents and swinging them around, you can hit other fighters with the move as well. Use this to deal damage to an entire group of fighters.",
                "level": "Beginner"
            }
        ],
        "fighters": [
