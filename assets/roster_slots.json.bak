            {
                "name": "Female",
                "boxing_ring_title": "The Mayor of Smashville",
                "type": "Same character"
            }
        ],
        "tips": [
            {
                "title": "Villager's Origins",
                "content": "The Villager debuted in Animal Crossing, released in North America in 2002. In Animal Crossing, players enjoyed a peaceful village life with a variety of animal neighbors.",
                "level": "Beginner"
            },
            {
                "title": "In Their Series",
                "content": "The main character from Animal Crossing. The Villager lives a free, slow life in a world populated by many different animals. These animals speak a unique language called Animalese.",
                "level": "Beginner"
            },
            {
                "title": "Pocket (Neutral Special)",
                "content": "The Villager uses this move to pocket items or incoming projectiles. Press the button again to bring the pocketed item back out.",
                "level": "Beginner"
            },
            {
                "title": "Lloid Rocket (Side Special)",
                "content": "Hold the button when using this move to ride on the Lloid Rocket.",
                "level": "Beginner"
            },
            {
                "title": "Lloid Rocket's Power (Side Special)",
                "content": "The Lloid Rocket is more powerful when you're riding it, but you can bail at any time just by pressing the button.",
                "level": "Intermediate"
            },
            {
                "title": "Balloon Trip (Up Special)",
                "content": "The Villager's up special Balloon Trip is named after a mode from the NES game Balloon Fight.",
                "level": "Beginner"
            },
            {
                "title": "Balloon Trip's Balloons (Up Special)",
                "content": "Your balloons can be popped if hit. If you lose one, you'll lose lift. If you lose both, down you go!",
                "level": "Beginner"
            },
            {
                "title": "Timber (Down Special)",
                "content": "A three-stage move: planting a seed, watering it, and then chopping down the tree. Don't use the first stage in the air—it'll just leave you wide open.",
                "level": "Beginner"
            },
            {
                "title": "Timber Techniques (Down Special)",
                "content": "The Villager can move sideways while using the watering can. It's also possible to water and chop down trees planted by other Villagers.",
                "level": "Intermediate"
            },
            {
                "title": "Timber (Down Special)",
                "content": "The axe is surprisingly powerful! You can swing it at your rivals as long as the tree is standing.",
                "level": "Intermediate"
            },
            {
                "title": "If a Tree Falls in a Battle... (Down Special)",
                "content": "If the felled tree hits an opponent, it deals some serious damage. The wood that pops out as it falls can be thrown as a projectile, too.",
                "level": "Beginner"
            },
            {
                "title": "Dream Home (Final Smash)",
                "content": "Tom Nook rushes over and builds a house around the opponent. If you look closely, you can see the Villager giving Tom Nook Bells, the currency of the Animal Crossing games.",
                "level": "Beginner"
            },
            {
                "title": "Bowling Ball (Side Smash Attack)",
                "content": "If you stand next to a cliff above your opponent, you can use this smash attack to drop a bowling ball on them from above like a projectile.",
                "level": "Intermediate"
            },
            {
                "title": "Dig (Down Smash Attack)",
                "content": "Attack forward and backward with a shovel, and bury any opponent hit with the attack in the ground. Once you bury them, follow up with a powerful attack.",
                "level": "Beginner"
            },
            {
                "title": "Downward Turnips (Down Air Attack)",
                "content": "One to three turnips will appear. More turnips means more damage, as well as a stronger meteor effect.",
                "level": "Advanced"
            },
            {
                "title": "Net (Grab)",
                "content": "Swing the net over an item to put the item in your pocket. You can then retrieve the item from your pocket at any time by pressing the special-move button.",
                "level": "Beginner"
            }
        ],
