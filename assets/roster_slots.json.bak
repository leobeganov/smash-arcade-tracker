                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/ice-climbers/main4.png"
            },
            {
                "slot": 5,
                "variant": "Ice Climbers",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/ice-climbers/main5.png"
            },
            {
                "slot": 6,
                "variant": "Ice Climbers",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/ice-climbers/main6.png"
            },
            {
                "slot": 7,
                "variant": "Ice Climbers",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/ice-climbers/main7.png"
            },
            {
                "slot": 8,
                "variant": "Ice Climbers",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/ice-climbers/main8.png"
            }
        ],
        "variants": [
            {
                "name": "Ice Climbers",
                "boxing_ring_title": "Bone-Chilling Duo",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Ice Climbers' Origins",
                "content": "Ice Climbers first appeared in the 1985 release Ice Climber. The boy is Popo and the girl is Nana. They jump with hammers in hand as they aim for the summit.",
                "level": "Beginner"
            },
            {
                "title": "In Their Series",
                "content": "In Ice Climber, Popo and Nana are identical outside of their clothing. Two players can play at the same time, and the game can be cooperative or competitive depending on how you play.",
                "level": "Beginner"
            },
            {
                "title": "Ice from Ice Shot (Neutral Special)",
                "content": "Popo and Nana both shoot ice from their hammers. If both climbers are present, there are two hunks of ice, but only one hunk if only one of them is present.",
                "level": "Beginner"
            },
            {
                "title": "Ice Shot Reflected (Neutral Special)",
                "content": "Ice Shot will be sent back at you if hit by an opponent or blocked by their shield. If an opponent's attack sends it back your way, it can damage you, so stay alert.",
                "level": "Beginner"
            },
            {
                "title": "Squall Hammer (Side Special)",
                "content": "Move left and right with the control stick and rise into the air by repeatedly pressing the button. When both Popo and Nana are present, you can launch opponents with the final hit.",
                "level": "Beginner"
            },
            {
                "title": "Belay (Up Special)",
                "content": "Popo tosses Nana upward, and Nana then pulls Popo up with a rope. The rope is a lifeline that connects the two climbers.",
                "level": "Beginner"
            },
            {
                "title": "Blizzard (Down Special)",
                "content": "The Ice Climbers unleash a snowstorm from their hands that freezes opponents. If this move is used on opponents that are already frozen, they will stay frozen longer.",
                "level": "Beginner"
            },
            {
                "title": "Iceberg (Final Smash)",
                "content": "A Final Smash where the Ice Climbers summon an iceberg from the bottom of the screen. The iceberg can be spun left and right, but you will move as well, so be smart.",
                "level": "Beginner"
            },
            {
                "title": "Iceberg's Condor (Final Smash)",
                "content": "A condor will appear along with the iceberg. Only the Ice Climbers can grab on to its legs.",
                "level": "Beginner"
            },
            {
                "title": "Polar Bear in Iceberg (Final Smash)",
                "content": "The Polar Bear will be in the middle area of the iceberg trying to maintain its balance. If you touch the Polar Bear, it will launch you farther than the iceberg. Quite dangerous.",
                "level": "Advanced"
            },
            {
                "title": "Hammer Sweep (Down Smash)",
                "content": "Popo attacks in front of himself and Nana attacks behind. When Popo is alone, his attack range will become smaller.",
                "level": "Intermediate"
            },
            {
                "title": "Hammer Slam (Forward Air Attack)",
                "content": "Roll forward in the air and slam down the hammer. Popo's attack can launch opponents far, and Nana's attack has a meteor effect if it hits just right.",
                "level": "Advanced"
            },
            {
                "title": "Grab",
                "content": "Popo will be the only one that grabs. When throwing an opponent, Nana will raise her arms and cheer!",
                "level": "Beginner"
            },
            {
                "title": "Grabbing Popo",
                "content": "If Popo is grabbed, Nana will panic and be unable to move. Once Popo is freed, Nana will begin moving again.",
                "level": "Beginner"
            },
            {
                "title": "Nana",
                "content": "Nana is slightly easier to launch than Popo. When Nana is gone, the Special moves and normal attacks will become weaker and Belay won't be as effective for recoveries.",
                "level": "Intermediate"
            }
        ],
        "fighters": [
            {
                "id": "15",
                "name": "Ice Climbers",
                "slug": "ice-climbers",
                "also_appears_in": [
                    "Melee",
                    "Brawl",
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
