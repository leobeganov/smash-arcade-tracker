        "variants": [
            {
                "name": "Pit",
                "boxing_ring_title": "Captain of Lady Palutena's Guard",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Pit's Origins",
                "content": "Pit's debut was in Kid Icarus, released in North America in 1987. His goal was to collect the Three Sacred Treasures and defeat the evil Medusa.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "The protagonist of Kid Icarus, Pit is an angel who serves Palutena, the Goddess of Light, as captain of her royal guard. He aims to defeat Medusa, the Goddess of Darkness, by retrieving the Three Sacred Treasures.",
                "level": "Beginner"
            },
            {
                "title": "Pit vs. Dark Pit",
                "content": "Pit and Dark Pit are similar in some ways, but they both summon different weapons and both celebrate victory to a different tune.",
                "level": "Beginner"
            },
            {
                "title": "Pit and the Hammer",
                "content": "When Pit grabs a Hammer, he swings it from the wrist, with only two frames of movement—just like how he used the mallets in the original Kid Icarus!",
                "level": "Beginner"
            },
            {
                "title": "Palutena Bow (Neutral Special)",
                "content": "Press up before firing to aim the arrow that way. Also, you can guide the arrow while it's in the air.",
                "level": "Intermediate"
            },
            {
                "title": "Palutena Bow's Direction and Timing (Neutral Special)",
                "content": "The arrow fires automatically once it's fully charged, but it won't fire while Pit's changing his aim. You can delay firing that way.",
                "level": "Advanced"
            },
            {
                "title": "Upperdash Arm (Side Special)",
                "content": "A dash forward followed by an uppercut. While Pit is dashing, the Upperdash Arm deflects projectiles! Cool!",
                "level": "Beginner"
            },
            {
                "title": "Upperdash Arm Techniques (Side Special)",
                "content": "When used midair, it has less launching power, but you're not vulnerable for as long after the uppercut. When recovering from offstage, you can use it to rush a waiting opponent.",
                "level": "Intermediate"
            },
            {
                "title": "Power of Flight (Up Special)",
                "content": "Pit's wings glow and then send him flying in the direction you choose. This move travels a long way, making it an excellent recovery move.",
                "level": "Beginner"
            },
            {
                "title": "Power of Flight's Vulnerability (Up Special)",
                "content": "This move travels very far, making it great for recovering. However, what goes up must come down, so use it wisely.",
                "level": "Beginner"
            },
            {
                "title": "Guardian Orbitars (Down Special)",
                "content": "These handy items will block enemy attacks as well as reflect projectiles. They'll even push back foes who touch them!",
                "level": "Beginner"
            },
            {
                "title": "Guardian Orbitars' Recovery Time (Down Special)",
                "content": "If the shields take too much damage, they'll break. When that happens, it'll be 10 seconds before they can be used again.",
                "level": "Intermediate"
            },
            {
                "title": "Lightning Chariot (Final Smash)",
                "content": "Pit summons the Lightning Chariot and flies offstage. Use the reticle to aim at opponents. When the gauge inside the reticle runs out, he'll come rushing back and launch any opponents that he hits.",
                "level": "Beginner"
            },
            {
                "title": "Lightning Chariot Timing (Final Smash)",
                "content": "For Pit's Final Smash, take aim at an opponent and then come rushing in. If you don't want to wait for time to pass, you can trigger the move instantly with the attack or special-move buttons.",
                "level": "Beginner"
            },
            {
                "title": "Anti-air Attack (Up Tilt Attack)",
                "content": "A two-part kick that sends an opponent into the air. It'll send them up even if they haven't taken a lot of damage, so try to follow up with another attack afterward.",
                "level": "Intermediate"
            },
            {
                "title": "Under-Arc Slash (Down Air Attack)",
                "content": "Pit swings his sword below him with a lot of power. If you hit the opponent when the sword is directly below him, it'll have a meteor effect.",
                "level": "Intermediate"
            },
            {
                "title": "Smash Taunts",
                "content": "In the Palutena's Temple stage, you can trigger a special smash taunt if you use Pit's down taunt for a brief instant. It'll only work once per battle.",
                "level": "Advanced"
            }
        ],
        "fighters": [
