        "variants": [
            {
                "name": "Luigi",
                "boxing_ring_title": "The Eternal Understudy",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Luigi's Origins",
                "content": "Luigi made his debut in the 1983 arcade classic Mario Bros. At the time, he wore a white shirt and cap with green overalls.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "In Mario games, Luigi usually appears as the character for player 2. He's Mario's younger twin brother. A little cowardly at times, but he'll also fight hard to help Mario.",
                "level": "Beginner"
            },
            {
                "title": "First Starring Role",
                "content": "Luigi's first big break as a main protagonist was in the 2001 release Luigi's Mansion. This is also the first appearance of the Poltergust. While Luigi can normally jump, he couldn't jump in that game.",
                "level": "Beginner"
            },
            {
                "title": "Fireball (Neutral Special)",
                "content": "Luigi's green fireballs don't travel as far as his brother's, but they're slightly more powerful and they can bounce off of walls.",
                "level": "Beginner"
            },
            {
                "title": "Green Missile's Vulnerability (Side Special)",
                "content": "This move can end with Luigi's head stuck in a wall. That leaves him vulnerable, so be careful!",
                "level": "Intermediate"
            },
            {
                "title": "Overzealous Green Missile (Side Special)",
                "content": "This move has a 1-in-10 chance to hit REALLY hard and fly REALLY far. Too far, in some cases.",
                "level": "Intermediate"
            },
            {
                "title": "Exhausting Green Missile (Side Special)",
                "content": "If you charge this for too long, he'll get worn out and give up. Let him catch his breath, and then try again.",
                "level": "Beginner"
            },
            {
                "title": "Super Jump Punch (Up Special)",
                "content": "Get close to your enemy before using this. Hit them right at the start of the uppercut for maximum damage and launching power.",
                "level": "Intermediate"
            },
            {
                "title": "Using Luigi Cyclone (Down Special)",
                "content": "Press the button repeatedly while using this attack to move upward. It has an invincibility window while winding up, and it pulls in nearby opponents, too!",
                "level": "Intermediate"
            },
            {
                "title": "Landing Luigi Cyclone (Down Special)",
                "content": "If you land during Luigi Cyclone after using it in midair, you can slide left or right. This is a great way to suddenly avoid an opponent's follow-up attacks.",
                "level": "Intermediate"
            },
            {
                "title": "Poltergust G-00 (Final Smash)",
                "content": "With the Poltergust G-00 on his back, Luigi sucks in nearby fighters and items. The move wraps up with just the fighters being launched out of the vacuum cleaner.",
                "level": "Beginner"
            },
            {
                "title": "Lead Headbutt (Up Smash Attack)",
                "content": "Hit an enemy in front to launch them backward. Hit an enemy behind you to launch them forward. The green guy's kooky like that!",
                "level": "Beginner"
            },
            {
                "title": "Luigi Kick (Neutral Air Attack)",
                "content": "This attack launches opponents almost straight upward. Since you know which way they're going, it's easy to move in and attack again.",
                "level": "Intermediate"
            },
            {
                "title": "Down Taunt",
                "content": "If your foe's clinging to an edge for dear life, try using Luigi's down taunt. That meteor smash will be VERY satisfying!",
                "level": "Advanced"
            },
            {
                "title": "Luigi's Air Superiority",
                "content": "The title Super Mario Bros. 2 refers to different games in the West and in Japan, but both games introduced Luigi's ability to jump higher than Mario!",
                "level": "Beginner"
            }
        ],
        "fighters": [
