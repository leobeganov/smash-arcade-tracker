        ],
        "variants": [
            {
                "name": "Ken",
                "boxing_ring_title": "The Fire-Breathing Fist",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Ken's Origins",
                "content": "Ken first debuted in 1987 in the arcade version of Street Fighter. He showed up as the P2 character. He was exactly the same as Ryu besides his looks.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Ken is friends with Ryu and also trained with him. He considers Ryu as his rival. He is the son of the well-known Masters family.",
                "level": "Beginner"
            },
            {
                "title": "Hadoken (Neutral Special)",
                "content": "Press the button longer to increase the speed, distance, and power. The Hadoken's shape is a bit different than Ryu's, and you can see the shape of Ken's hands within the Hadoken.",
                "level": "Beginner"
            },
            {
                "title": "Tatsumaki Senpukyaku (Side Special)",
                "content": "It can hit multiple times, so get all the hits in to do a lot of damage. Input ↓ ↙ ← + special-move button to increase the attack's power even more.",
                "level": "Beginner"
            },
            {
                "title": "Shoryuken (Up Special / Command-Input Move)",
                "content": "This version of the attack increases invincibility time at the start, and boosts attack power. The light version leaves you less vulnerable when you land, and the medium version hits foes twice.",
                "level": "Beginner"
            },
            {
                "title": "Flaming Shoryuken (Up Special - Heavy)",
                "content": "Press and hold the button to unleash a Shoryuken engulfed in flames. It can hit three times and does big damage, and it launches opponents farther horizontally than Ryu's Shoryuken.",
                "level": "Beginner"
            },
            {
                "title": "Focus Attack (Down Special)",
                "content": "Ken can take one hit without flinching while charging this spinning kick. If it lands at max charge, the opponent will fall slowly to the ground.",
                "level": "Intermediate"
            },
            {
                "title": "Shippu Jinraikyaku (Final Smash)",
                "content": "If an opponent is nearby when you activate your Final Smash, you'll execute this flashy kick, rising into the air and hitting your opponent multiple times before launching them.",
                "level": "Beginner"
            },
            {
                "title": "Shinryuken (Final Smash)",
                "content": "If your opponent is far away, your Final Smash becomes Shinryuken. It does good damage and can hit opponents in front of you and around you.",
                "level": "Beginner"
            },
            {
                "title": "Hell Wheel (Backward Throw)",
                "content": "Unlike Ryu's Somersault Throw, Ken rolls backward once and then throws his opponent with Hell Wheel. Ken gains the distance he moved during the throw, making it easy to follow up quickly.",
                "level": "Beginner"
            },
            {
                "title": "Nata Otoshi Geri (Command-Input Move)",
                "content": "Input → ↘ ↓ + attack button while facing right to unleash a high spin kick. You can perform this immediately after canceling a neutral attack.",
                "level": "Beginner"
            },
            {
                "title": "Oosoto Mawashi Geri (Command-Input Move)",
                "content": "Input ← ↙ ↓ ↘ → + attack button while facing right to execute this move. You can perform this immediately after canceling a neutral attack.",
                "level": "Beginner"
            },
            {
                "title": "Inazuma Kick (Command-Input Move)",
                "content": "Hold down the button after entering → ↘ ↓ + attack button or ← ↙ ↓ ↘ → + attack button while facing right to execute this move. It does major damage to shields.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "60e",
                "name": "Ken",
                "slug": "ken",
                "also_appears_in": []
            }
        ]
    },
