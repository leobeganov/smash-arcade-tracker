        ],
        "tips": [
            {
                "title": "Dark Samus's Origins",
                "content": "Dark Samus made her debut in 2002 in Metroid Prime. She was born from Metroid Prime cells merged with Samus Aran's DNA. She is highly intelligent.",
                "level": "Beginner"
            },
            {
                "title": "In Her Series",
                "content": "Dark Samus is a living Phazon entity with the radioactive substance Phazon as her energy supply. She has a wide range of abilities, like being able to teleport, cloak herself, and attack with an arm cannon.",
                "level": "Beginner"
            },
            {
                "title": "Charge Shot (Neutral Special)",
                "content": "Devastating when fully charged, it can be unleashed instantly and fired repeatedly. You can also charge it in midair.",
                "level": "Beginner"
            },
            {
                "title": "Missile (Side Special)",
                "content": "Holding a direction when you press the special-move button will fire a homing missile, and quickly inputting a direction as you press the special-move button will fire a Super Missile!",
                "level": "Beginner"
            },
            {
                "title": "Screw Attack (Up Special)",
                "content": "When recovering with the Screw Attack, you can't grab edges behind you until you've finished rising. Make sure to face the right way when you use it!",
                "level": "Beginner"
            },
            {
                "title": "Bomb (Down Special)",
                "content": "Dark Samus morphs into a ball and drops a bomb. You can use the explosion to gain a little height.",
                "level": "Beginner"
            },
            {
                "title": "Phazon Laser (Final Smash)",
                "content": "Unleash an enormous laser beam that goes through the stage. You can change the angle of the beam with the control stick. The beam will repeatedly hit opponents caught in its blast.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
