        ],
        "variants": [
            {
                "name": "Snake",
                "boxing_ring_title": "The Legendary Mercenary",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Snake's Origins",
                "content": "Snake made his debut in Metal Gear, released in North America in 1988. It's a stealth-based game that has Snake acquiring weapons and equipment while on various missions.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Snake's job is to infiltrate enemy bases alone to stop terrorist organizations. The player has the option to stay quiet and sneak around, or go loud with guns and bombs.",
                "level": "Beginner"
            },
            {
                "title": "Hand Grenade (Neutral Special)",
                "content": "The hand grenade explodes 2.5 seconds after the pin is pulled out. Opponents won't flinch even if the grenade hits when thrown. You can get caught in the explosion as well, so be smart.",
                "level": "Beginner"
            },
            {
                "title": "Holding Hand Grenade (Neutral Special)",
                "content": "Pressing and holding the special-move button will allow you to move around while holding the grenade. You can move forward, backward, jump, and even perform midair jumps.",
                "level": "Intermediate"
            },
            {
                "title": "Throwing the Hand Grenade (Neutral Special)",
                "content": "Depending on the direction you tilt the control stick, you can throw the grenade near, medium, or far. Press the shield button to drop it at your feet.",
                "level": "Beginner"
            },
            {
                "title": "Remote Missile (Side Special)",
                "content": "You can control the missile freely, but you cannot move around. If opponents try to attack you, press the shield button to cancel.",
                "level": "Beginner"
            },
            {
                "title": "Cypher (Up Special)",
                "content": "Attack or dodge while rising up in the air to let go of the Cypher. If you take damage while airborne, you can use this move again.",
                "level": "Beginner"
            },
            {
                "title": "C4 (Down Special)",
                "content": "The C4 bombs that you've set can be detonated by using your down special again. When trying to recover, you can detonate it in midair to blast yourself back to the stage.",
                "level": "Beginner"
            },
            {
                "title": "C4 - Butterfly Form (Down Special)",
                "content": "Sometimes Snake will use a butterfly-shaped C3 explosive instead of a C4 bomb. They may look different, but both bombs behave identically.",
                "level": "Intermediate"
            },
            {
                "title": "C4 Placement (Down Special)",
                "content": "You can attach C4 bombs to not only the ground, but to walls and opponents as well. The bomb will detonate automatically once enough time has passed. Don't blow yourself up!",
                "level": "Advanced"
            },
            {
                "title": "Covering Fire (Final Smash)",
                "content": "Snake's Final Smash allows him to lock on to opponents and shoot five missiles at them. The missiles will fire even if you are unable to lock on.",
                "level": "Beginner"
            },
            {
                "title": "Silent Takedown (Downward Throw)",
                "content": "Snake's unique downward throw lays opponents flat on the ground. If the opponent has high damage, this can be a great setup for a KO.",
                "level": "Beginner"
            },
            {
                "title": "Cardboard Box",
                "content": "Snake's taunt involves him hiding in his beloved cardboard box. When an opponent gets near and picks up the cardboard box...well...you'll just have to see for yourself.",
                "level": "Beginner"
            },
            {
                "title": "Attack with the Cardboard Box",
                "content": "The cardboard box you use during your taunt can also be used to deal damage to opponents when cast off. The box falls off of Snake's back, so be mindful of the direction you use it.",
                "level": "Intermediate"
            }
        ],
        "fighters": [
