        "variants": [
            {
                "name": "Female",
                "boxing_ring_title": "The Yoga Warrior",
                "type": "Same character"
            },
            {
                "name": "Male",
                "boxing_ring_title": "The BMI Bandit",
                "type": "Same character"
            }
        ],
        "tips": [
            {
                "title": "Wii Fit Trainer's Origins",
                "content": "Wii Fit Trainer debuted in the title Wii Fit, released in North America in 2008. Players could choose a male or female trainer to guide them through their fitness routines.",
                "level": "Beginner"
            },
            {
                "title": "In Their Series",
                "content": "There is a female version and a male version of the Wii Fit Trainer. In the Wii Fit games, they act as a fitness coach. Sometimes they run late, oversleep, or have the other trainer fill in for them.",
                "level": "Beginner"
            },
            {
                "title": "Sun Salutation (Neutral Special)",
                "content": "Fully charge the attack before striking to recover a bit of health. Talk about flexible!",
                "level": "Beginner"
            },
            {
                "title": "Header (Side Special)",
                "content": "The ball's trajectory depends on when you press the button again. You can also attack with the headbutt directly, which has a meteor effect.",
                "level": "Advanced"
            },
            {
                "title": "Canceling Header (Side Special)",
                "content": "Shield before hitting the ball to cancel your serve and let the ball fall, dejected, to the ground.",
                "level": "Intermediate"
            },
            {
                "title": "Super Hoop (Up Special)",
                "content": "Press the button repeatedly to float up higher, making recovery easier. If foes are trying to stop you getting back to the stage, just fly out of reach!",
                "level": "Intermediate"
            },
            {
                "title": "Deep Breathing (Down Special)",
                "content": "Deep Breathing can reduce stress. Oh, it also heals a small amount of damage and increases your attack power, launch power, and movement speed.",
                "level": "Intermediate"
            },
            {
                "title": "Timing Deep Breathing (Down Special)",
                "content": "If you press the button again just as the outer circle meets the red inner circle, you'll give yourself a boost. However, the circle moves slower if used repeatedly, and it can leave you vulnerable.",
                "level": "Beginner"
            },
            {
                "title": "Wii Fit (Final Smash)",
                "content": "Wii Fit Trainer unleashes a wave of silhouettes that can push opponents off the stage. There are 10 different silhouettes.",
                "level": "Beginner"
            },
            {
                "title": "Lunge (Neutral Attack)",
                "content": "The third neutral attack in the sequence can bury your opponents in the ground for a time.",
                "level": "Intermediate"
            },
            {
                "title": "Dancer (Side Tilt Attack)",
                "content": "It's not just the front arm thrust that deals damage—the leg raised up behind is also a powerful attack that launches foes straight up.",
                "level": "Intermediate"
            },
            {
                "title": "Tree (Up Smash Attack)",
                "content": "You're invincible for a moment just before unleashing this. Try using it to launch foes attacking from above.",
                "level": "Advanced"
            },
            {
                "title": "Arm & Leg Lift (Down Smash)",
                "content": "Launch opponents at a low angle. If these moves have been strengthened, you can sometimes even KO opponents who aren't significantly damaged.",
                "level": "Beginner"
            },
            {
                "title": "Single-Leg Extension (Forward Air Attack)",
                "content": "You can deal damage with the extended back leg. It actually has a small meteor effect.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "47",
