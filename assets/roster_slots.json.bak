            },
            {
                "slot": 5,
                "variant": "Piranha Plant",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/piranha-plant/main5.png"
            },
            {
                "slot": 6,
                "variant": "Piranha Plant",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/piranha-plant/main6.png"
            },
            {
                "slot": 7,
                "variant": "Piranha Plant",
