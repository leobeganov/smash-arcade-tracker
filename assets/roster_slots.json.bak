        "variants": [
            {
                "name": "Donkey Kong",
                "boxing_ring_title": "The King of the Jungle",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "In His Series",
                "content": "Donkey Kong first wore his signature red necktie with the initials DK in Donkey Kong Country. In that game, he sets off on an adventure to recover his banana hoard that was stolen by King K. Rool.",
                "level": "Beginner"
            },
            {
                "title": "Donkey Kong's Origins",
                "content": "Donkey Kong, the arcade classic, was released in 1981. In that game, the heroine known as Lady was kidnapped and Donkey Kong tried to stop Mario from rescuing her.",
                "level": "Beginner"
            },
            {
                "title": "Giant Punch (Neutral Special)",
                "content": "You can tell this move is fully charged from the steam and the look on Donkey Kong's face. It's a powerful blow, but it leaves you wide open.",
                "level": "Advanced"
            },
            {
                "title": "Headbutt Effect (Side Special)",
                "content": "Use this move to bury your opponents if they're on the ground or meteor smash them in midair.",
                "level": "Advanced"
            },
            {
                "title": "Headbutt's Traits (Side Special)",
                "content": "Headbutt grants super armor at the beginning of the move, allowing you to fight through incoming attacks. It's also useful when returning to the stage, landing, and against opponents waiting for you to land.",
                "level": "Intermediate"
            },
            {
                "title": "Spinning Kong Movement (Up Special)",
                "content": "This move doesn't offer a lot of lift, but it can carry Donkey Kong a fair distance left or right.",
                "level": "Beginner"
            },
            {
                "title": "No Pushing during Spinning Kong (Up Special)",
                "content": "When the move is activated, things that push fighters (like water) will have no effect on Donkey Kong. When used on the ground, you'll get super armor at the beginning of the move.",
                "level": "Intermediate"
            },
            {
                "title": "Hand Slap (Down Special)",
                "content": "When used on the ground, DK's Hand Slap affects a large area around him, but it won't hit airborne fighters. When used in midair, it has a meteor effect on opponents.",
                "level": "Beginner"
            },
            {
                "title": "Jungle Rush (Final Smash)",
                "content": "Repeatedly punch the opponent and finish off by launching them with an uppercut. The move won't activate if the first punch misses, but it's super powerful.",
                "level": "Beginner"
            },
            {
                "title": "Slouch Slap (Down Tilt Attack)",
                "content": "Hit an opponent that doesn't have much damage to make them fall over. Follow up with a dash attack or dash grab!",
                "level": "Intermediate"
            },
            {
                "title": "Comboing with Kong Karry (Forward Throw)",
                "content": "You'll toss opponents diagonally upward when throwing forward, toss them high when throwing backward, and launch them low when tossed down. Throwing them up is a great start to a combo.",
                "level": "Intermediate"
            },
            {
                "title": "Forward Throw Info",
                "content": "Donkey Kong can pick up opponents and carry them around! Try to throw them before they shake free, though.",
                "level": "Beginner"
            },
            {
                "title": "Shield Break",
                "content": "Donkey Kong can use his side special Headbutt and his down special Hand Slap to damage or even shatter his foes' shields.",
                "level": "Advanced"
            },
            {
                "title": "Moves with Meteor Effect",
                "content": "Four of Donkey Kong's moves have a meteor effect—his forward air attack, down air attack, midair side special, and the second hit of his midair down special.",
                "level": "Intermediate"
            }
        ],
