        ],
        "variants": [
            {
                "name": "Greninja",
                "boxing_ring_title": "The Master of Stealth",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Greninja's Origins",
                "content": "Greninja, the final evolved form of Froakie, made its debut in 2013's Pokémon X and Pokémon Y. What looks like a scarf is actually its tongue!",
                "level": "Beginner"
            },
            {
                "title": "In Its Series",
                "content": "Greninja is a Ninja Pokémon that uses attacks like Spikes and Double Team. Water Shuriken, an attack using compressed water, was created specifically for Greninja.",
                "level": "Beginner"
            },
            {
                "title": "Water Shuriken (Neutral Special)",
                "content": "The longer this attack is charged, the shorter its range is. The uncharged version can be more useful for keeping a foe from approaching.",
                "level": "Intermediate"
            },
            {
                "title": "Shadow Sneak (Side Special)",
                "content": "Greninja instantly travels to the location of the shadow and ambushes nearby opponents. Press and hold the button to make the shadow travel farther.",
                "level": "Beginner"
            },
            {
                "title": "Hydro Pump (Up Special)",
                "content": "Aim the water jets by tilting the stick in a particular direction. You can then quickly tilt the stick in a different direction to go that way with the second burst.",
                "level": "Beginner"
            },
            {
                "title": "Hydro Pump's Flow (Up Special)",
                "content": "The water flow doesn't just cause damage—it can also push your foes if you hit them just right.",
                "level": "Intermediate"
            },
            {
                "title": "Substitute (Down Special)",
                "content": "This move makes an enemy attack hit a substitute instead of you. You then reappear somewhere else and attack!",
                "level": "Intermediate"
            },
            {
                "title": "Substitute (Down Special)",
                "content": "After successfully countering with this, input a direction, and you'll reappear while attacking in that direction.",
                "level": "Advanced"
            },
            {
                "title": "Secret Ninja Attack (Final Smash)",
                "content": "Greninja uses Battle Bond to transform and unleash its Final Smash. An opponent hit with the Mat Block will be slashed repeatedly and smashed downward, while the moon glows in the background.",
                "level": "Beginner"
            },
            {
                "title": "Down Taunt",
                "content": "Greninja's down taunt involves Greninja performing water tricks. Opponents hit by the water will take damage and float a bit.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "50",
                "name": "Greninja",
                "slug": "greninja",
                "also_appears_in": [
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
    {
        "ids": [
            "51"
        ],
        "name": "Mii Brawler",
        "slug": "mii-brawler",
        "series": "Super Smash Bros.",
        "availability": "Custom",
        "also_appears_in": [
            "3DS",
            "Wii U"
        ],
        "order": 54,
        "alts": [
            {
                "slot": 1,
                "variant": "Mii Brawler",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/mii-brawler/main.png"
            }
        ],
        "variants": [
            {
                "name": "Mii Brawler",
                "boxing_ring_title": "The Brawler of Many Faces",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Shot Put (Neutral Special)",
                "content": "Throws a metal ball diagonally upward, just like the real shot-put event. It's effective at blocking opponents' attempts at recovery.",
                "level": "Beginner"
            },
            {
                "title": "Flashing Mach Punch (Neutral Special)",
                "content": "Unleash a super-fast flurry of punches. If the rush of punches hits an opponent, you become invincible and unleash a powerful uppercut.",
                "level": "Beginner"
            },
            {
                "title": "Exploding Side Kick (Neutral Special)",
                "content": "Input in the opposite direction right after pressing the button to turn around and deliver this kick the other way! It'll also deal more damage.",
                "level": "Intermediate"
            },
            {
                "title": "Onslaught (Side Special)",
                "content": "The more damage you've taken, the harder your final kick will hit. Once used, it will take some time for this ability to be at full strength again.",
                "level": "Beginner"
            },
            {
                "title": "Burning Dropkick (Side Special)",
                "content": "This move combines a big forward leap with a drop kick. Also, it's on fire. If you hit an opponent, you'll gain some air from the recoil.",
                "level": "Beginner"
            },
            {
                "title": "Suplex (Side Special)",
                "content": "Dash forward and grab the opponent, and then throw them backward. If you grab the opponent in the air, you'll dive downward. If you dive off the stage, you'll be KO'd before the fighter you grabbed is KO'd.",
                "level": "Beginner"
            },
            {
                "title": "Soaring Axe Kick (Up Special)",
                "content": "Rise with a somersault kick. Hit the button right before the peak and you'll perform a falling heel kick. The heel kick has a powerful meteor effect, but it can carry you down to your doom if you aren't careful.",
                "level": "Advanced"
            },
            {
                "title": "Soaring Axe Kick Recovery (Up Special)",
                "content": "When recovering with this move, it often goes past the edge, leaving you open to attack. Try waiting until exactly the right height to grab on to the edge.",
                "level": "Intermediate"
            },
            {
                "title": "Helicopter Kick (Up Special)",
                "content": "When performing this move, pressing left or right will let you change the direction of the kick.",
                "level": "Beginner"
            },
            {
                "title": "Thrust Uppercut (Up Special)",
                "content": "This powerful upward punch will drag in your opponents as you rise. You can also move a little to the right or left while attacking.",
                "level": "Beginner"
            },
            {
                "title": "Head-On Assault (Down Special)",
                "content": "When used in the air, this move becomes a descending headbutt. You can even grab an edge during your rapid descent, but if there's no edge or ground beneath you...",
                "level": "Beginner"
            },
            {
                "title": "Feint Jump (Down Special)",
                "content": "Invincible at the start, then becomes a rising backflip. Avoid attacks with it, then descend quickly with another button press. You'll kick at anyone nearby when you land.",
                "level": "Beginner"
            },
            {
                "title": "Counter Throw (Down Special)",
                "content": "Grab and throw the opponent if they attack you. You cannot counter projectiles or attacks aimed at your feet.",
                "level": "Beginner"
            },
            {
                "title": "Omega Blitz (Final Smash)",
                "content": "Kick opponents into the sky and follow up with a rush of strikes. At the end, deal a powerful downward strike that sends opponents hurtling toward the ground.",
                "level": "Intermediate"
            },
            {
                "title": "Cartwheel Kick (Up Smash Attack)",
                "content": "An upward-kicking backflip. Your legs are invulnerable while you perform it, so it's perfect for countering enemy attacks from above.",
                "level": "Intermediate"
            },
            {
                "title": "Mii Fighters' Origins",
                "content": "Mii characters first appeared in 2006, with the debut of the Wii console and the Mii Channel. They can be used in a variety of games.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "51",
                "name": "Mii Brawler",
                "slug": "mii-brawler",
                "also_appears_in": [
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
    {
        "ids": [
            "52"
        ],
        "name": "Mii Swordfighter",
        "slug": "mii-swordfighter",
        "series": "Super Smash Bros.",
        "availability": "Custom",
        "also_appears_in": [
            "3DS",
            "Wii U"
        ],
        "order": 55,
        "alts": [
            {
                "slot": 1,
                "variant": "Mii Swordfighter",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/mii-swordfighter/main.png"
            }
        ],
        "variants": [
            {
                "name": "Mii Swordfighter",
                "boxing_ring_title": "The Swordfighter of Many Faces",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Gale Strike (Neutral Special)",
                "content": "With Gale Strike, a wide swing of the sword creates a tornado that moves forward. Opponents hit by the tornado are thrown straight up into the air.",
                "level": "Beginner"
            },
            {
                "title": "Gale Strike's Traits (Neutral Special)",
                "content": "The tornado will become weaker as time passes, but you can follow this slow-moving projectile and attack along with it!",
                "level": "Intermediate"
            },
            {
                "title": "Gale Strike's Path (Neutral Special)",
                "content": "A large swing of the sword that summons a tall, damaging tornado. The tornado's path sinks slightly just after it appears.",
                "level": "Beginner"
            },
            {
                "title": "Shuriken of Light (Neutral Special)",
                "content": "The farther the shurikens travel, the more damage they deal. Throwing them at nearby foes won't even make them flinch.",
                "level": "Intermediate"
            },
            {
                "title": "Blurring Blade (Neutral Special)",
                "content": "A flurry of sword stabs right in front of you, followed by a slash forward. Good for keeping your opponents at a safe distance!",
                "level": "Beginner"
            },
            {
                "title": "Charging Blurring Blade (Neutral Special)",
                "content": "Mii Swordfighter attacks with a flurry of fire stabs, then launches the opponent diagonally upward. Hold the button longer to charge the attack. The longer the charge, the greater the attack power.",
                "level": "Beginner"
            },
            {
                "title": "Airborne Assault (Side Special)",
                "content": "The Mii performs a somersault leap forward. If it strikes foes, they will be blasted back and the user will jump upward.",
                "level": "Beginner"
            },
            {
                "title": "Gale Stab (Side Special)",
                "content": "The more this move is charged, the faster you'll move and more power you'll have. After using it in midair, you'll descend helplessly down.",
                "level": "Beginner"
            },
            {
                "title": "Chakram (Side Special)",
                "content": "Throws a ring-shaped projectile. If it hits the stage, it'll stick there. You can adjust the angle of the throw by pressing up or down.",
                "level": "Beginner"
            },
            {
                "title": "Chakram's Traits (Side Special)",
                "content": "You can raise the speed and power of the chakram by flicking the stick as you press the button. You can adjust the angle of the attack with up or down right before it's thrown.",
                "level": "Intermediate"
            },
            {
                "title": "Stone Scabbard (Up Special)",
                "content": "A rising upward slice followed by a plummeting stab down. The falling stab has a meteor effect.",
                "level": "Advanced"
            },
            {
                "title": "Piercing Stone Scabbard (Up Special)",
                "content": "At the end of this move, the sword sticks right through the ground. You can use it to attack unsuspecting enemies below the platform.",
                "level": "Intermediate"
            },
            {
                "title": "Skyward Slash Dash (Up Special)",
                "content": "Slash repeatedly while dashing in the direction you've pressed. Use it in the air to ambush opponents waiting below!",
                "level": "Beginner"
            },
            {
                "title": "Hero's Spin (Up Special)",
                "content": "A spinning sword slice that attacks enemies on both sides. When used in midair it makes you rise upward, so you can use it for recovery.",
                "level": "Beginner"
            },
            {
                "title": "Blade Counter (Down Special)",
                "content": "This move counters an enemy attack. Succeeding with this move lets you move around quickly—perfect for launching a follow-up attack!",
                "level": "Beginner"
            },
            {
                "title": "Blade Counter Technique (Down Special)",
                "content": "You can use this move in midair to slow your fall. This can be useful for throwing off the timing of a foe waiting below you to attack.",
                "level": "Advanced"
            },
            {
                "title": "Reversal Slash (Down Special)",
                "content": "A gust of wind from the Mii character's sword sends projectiles back the way they came. It can also flip opponents around if they get too close.",
                "level": "Beginner"
            },
            {
                "title": "Power Thrust (Down Special)",
                "content": "This dashing thrust will travel sideways on the ground but diagonally down in the air. The sword's tip is especially powerful.",
                "level": "Intermediate"
            },
            {
                "title": "Final Edge (Final Smash)",
                "content": "Quickly swing the sword and unleash fan-shaped shockwaves. It cuts through the stage and has a long range.",
                "level": "Beginner"
            },
            {
                "title": "Mii Fighters' Origins",
                "content": "Mii characters first appeared in 2006, with the debut of the Wii console and the Mii Channel. They can be used in a variety of games.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "52",
                "name": "Mii Swordfighter",
                "slug": "mii-swordfighter",
                "also_appears_in": [
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
    {
        "ids": [
            "53"
        ],
        "name": "Mii Gunner",
        "slug": "mii-gunner",
        "series": "Super Smash Bros.",
        "availability": "Custom",
        "also_appears_in": [
            "3DS",
            "Wii U"
        ],
        "order": 56,
        "alts": [
            {
                "slot": 1,
                "variant": "Mii Gunner",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/mii-gunner/main.png"
            }
        ],
        "variants": [
            {
                "name": "Mii Gunner",
                "boxing_ring_title": "The Gunner of Many Faces",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Charge Blast (Neutral Special)",
                "content": "This move is super powerful when fully charged. You can also charge it in midair. Jumping or shielding will cancel the charge.",
                "level": "Beginner"
            },
            {
                "title": "Laser Blaze (Neutral Special)",
                "content": "This move fires a beam from your arm cannon. It will cause the enemy to flinch slightly, and it can be fired repeatedly.",
                "level": "Beginner"
            },
            {
                "title": "Grenade Launch (Neutral Special)",
                "content": "These grenades fly in an arc—perfect for foes returning to the stage. It's a predictable arc, though, so you'll have to be clever to surprise them.",
                "level": "Beginner"
            },
            {
                "title": "Flame Pillar (Side Special)",
                "content": "Once it hits the ground, it will erupt in a pillar of fire. It lasts a while, making it useful for blocking projectiles or serving as a shield.",
                "level": "Beginner"
            },
            {
                "title": "Stealth Burst (Side Special)",
                "content": "Hold the button down to get more distance, and release to detonate. Any enemies caught in the blast will be sent flying.",
                "level": "Beginner"
            },
            {
                "title": "Gunner Missile (Side Special)",
                "content": "Use this move normally to fire a missile that homes in on opponents. Deliver it like a smash attack to fire a stronger missile that will fly straight.",
                "level": "Beginner"
            },
            {
                "title": "Lunar Launch (Up Special)",
                "content": "The Mii fires straight down, using the recoil to gain height. How fortunate if an opponent gets caught in the blast as well!",
                "level": "Beginner"
            },
            {
                "title": "Cannon Jump Kick (Up Special)",
                "content": "Use your cannon to launch yourself upward. If the blast hits an opponent in the air, it will have a meteor effect. The move doesn't provide a lot of vertical movement, so don't hesitate before using it.",
                "level": "Beginner"
            },
            {
                "title": "Arm Rocket (Up Special)",
                "content": "This move fires a rocket jet from your arm cannon, carrying you upward. It doesn't deal damage, but you can adjust the direction while ascending.",
                "level": "Beginner"
            },
            {
                "title": "Echo Reflector (Down Special)",
                "content": "This move creates a Reflector that sends projectiles back the way they came. They'll be stronger than they were before too!",
                "level": "Beginner"
            },
            {
                "title": "Bomb Drop (Down Special)",
                "content": "The bomb can be detonated by pressing down and the special-move button again. Opponents can hit them back, so be careful!",
                "level": "Beginner"
            },
            {
                "title": "Absorbing Vortex (Down Special)",
                "content": "A barrier that absorbs energy-based projectiles. When you activate the barrier or absorb a projectile, you will deal damage for a brief second.",
                "level": "Beginner"
            },
            {
                "title": "Full Blast (Final Smash)",
                "content": "Shoot out a long-range laser that can be aimed up or down. It pushes opponents slowly, so use it on the edge of the stage for maximum effect.",
                "level": "Beginner"
            },
            {
                "title": "Mii Fighters' Origins",
                "content": "Mii characters first appeared in 2006, with the debut of the Wii console and the Mii Channel. They can be used in a variety of games.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "53",
                "name": "Mii Gunner",
                "slug": "mii-gunner",
                "also_appears_in": [
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
