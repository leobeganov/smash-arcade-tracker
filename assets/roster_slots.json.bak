            },
            {
                "slot": 8,
                "variant": "Piranha Plant",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/piranha-plant/main8.png"
            }
        ],
        "variants": [
            {
                "name": "Piranha Plant",
                "boxing_ring_title": "Bloom of Your Doom",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Piranha Plant's Origins",
                "content": "Piranha Plants first appeared in Super Mario Bros., released in 1985 for the NES. Many of them live in pipes and like to suddenly pop out at regular intervals.",
                "level": "Beginner"
            },
            {
                "title": "Types of Piranha Plants",
                "content": "There are about 60 subspecies of Piranha Plant. Their biologies and personalities are unique.",
                "level": "Beginner"
            },
            {
                "title": "In Its Series",
                "content": "The first Piranha Plant was green with yellow dots. The red version with white spots first appeared in Super Mario Bros. 3.",
                "level": "Beginner"
            },
            {
                "title": "Ptooie (Neutral Special)",
                "content": "If you tilt the control stick left or right while blowing the spiked ball upward, you can launch it in that direction.",
                "level": "Beginner"
            },
            {
                "title": "Ptooie Height (Neutral Special)",
                "content": "Press and hold the special-move button to keep the spiked ball in the air. The closer it is to Piranha Plant's mouth, the farther you can launch it left or right.",
                "level": "Beginner"
            },
            {
                "title": "Repeated Ptooie (Neutral Special)",
                "content": "You can have only one spiked ball out at a time. If you try to use this move again before the first spiked ball disappears, you will be left vulnerable.",
                "level": "Beginner"
            },
            {
                "title": "Ptooie Power (Neutral Special)",
                "content": "The spiked ball loses power each time it hits the stage or a fighter. Also, once it loses enough speed and hits the ground, it won't deal damage to anyone.",
                "level": "Intermediate"
            },
            {
                "title": "Charging Poison Breath (Side Special)",
                "content": "Press the special-move button to start charging Poison Breath, then press it again to spit out a poison cloud. The cloud's size, duration, and damage will increase the longer it's charged.",
                "level": "Beginner"
            },
            {
                "title": "Storing Poison Breath Charge (Side Special)",
                "content": "If you shield, dodge, or jump while charging the poison cloud, you can store the charge, move around, and unleash it later.",
                "level": "Intermediate"
            },
            {
                "title": "Poison Breath Damage (Side Special)",
                "content": "The poison cloud can't be destroyed, but it can be countered or absorbed. Also, the center of the cloud deals the most damage.",
                "level": "Intermediate"
            },
            {
                "title": "Poison Breath's Duration (Side Special)",
                "content": "The duration of the poison cloud becomes shorter as the number of fighters increases.",
                "level": "Intermediate"
            },
            {
                "title": "Piranhacopter (Up Special)",
                "content": "Tilt the control stick left or right while rising to move slightly in that direction. The spinning leaves will hit and damage anyone they hit.",
                "level": "Beginner"
            },
            {
                "title": "Long-Stem Strike Charge (Down Special)",
                "content": "Press and hold the special-move button to charge up power. The longer you charge, the more distance the attack will have.",
                "level": "Beginner"
            },
            {
                "title": "Long-Stem Strike Direction (Down Special)",
                "content": "Tilt the control stick while charging to aim the attack. You can tilt farther in the air than on the ground.",
                "level": "Intermediate"
            },
            {
                "title": "Long-Stem Strike Armor (Down Special)",
                "content": "Piranha Plant gains super armor while charging this move. You'll lose the armor as soon as you stop charging.",
                "level": "Intermediate"
            },
            {
                "title": "Long-Stem Strike Bite (Down Special)",
                "content": "If a fighter is in range when Piranha Plant extends, it will automatically bite the fighter. If you press the special-move button while Piranha Plant is extending, you can bite before it fully extends.",
                "level": "Intermediate"
            },
            {
                "title": "Petey Piranha (Final Smash)",
                "content": "Petey Piranha can trap up to two fighters in cages and deal a great amount of damage. You can't escape until the Final Smash ends or Petey Piranha is KO'd.",
                "level": "Beginner"
            },
            {
                "title": "Petey Piranha's Movement (Final Smash)",
                "content": "You can make Petey Piranha move left or right. You can also make Petey jump.",
                "level": "Beginner"
            },
            {
                "title": "Push and Pull (Side Tilt Attack)",
                "content": "Press the attack button after unleashing the move to perform an additional bite attack. But if you miss the first attack, missing the second attack as well may leave you open to counterattack.",
                "level": "Advanced"
            },
            {
                "title": "Pull Technique (Side Tilt Attack)",
                "content": "The second attack can be delayed to catch opponents off guard. If the first attack is blocked, you still may be able to land the second attack.",
                "level": "Advanced"
            },
            {
                "title": "Prickly Swing (Side Smash Attack)",
                "content": "When Piranha Plant unleashes a side smash attack, it turns into a Prickly Piranha Plant from Super Mario Galaxy 2, complete with red spikes on its head.",
                "level": "Beginner"
            },
            {
                "title": "Fire Breath (Back Air Attack)",
                "content": "Piranha Plant spits out an explosive flame. As with most explosions, it has great launch power.",
                "level": "Beginner"
            },
            {
                "title": "Flowerpot Meteor (Down Air Attack)",
                "content": "Piranha Plant swings the flowerpot (or pipe) downward quickly. The move comes out fast and may surprise opponents. It has a meteor effect at the beginning.",
                "level": "Intermediate"
            },
            {
                "title": "Attack When Stepped On",
                "content": "Piranha Plant will automatically bite if it's crouching and an opponent steps on it. It's an involuntary reflex learned from other games Piranha Plant stars in.",
                "level": "Beginner"
            },
            {
                "title": "Costumes",
                "content": "Piranha Plant's odd-numbered costumes feature flowerpots, and its even-numbered costumes feature pipes.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "70",
                "name": "Piranha Plant",
                "slug": "piranha-plant",
                "also_appears_in": []
            }
        ]
    },
