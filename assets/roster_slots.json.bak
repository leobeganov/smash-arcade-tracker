        ],
        "variants": [
            {
                "name": "Banjo & Kazooie",
                "boxing_ring_title": "Laid-Back Animals",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Banjo & Kazooie's Origins",
                "content": "The first time the duo appeared was in Banjo-Kazooie, released in 1998. Banjo first appeared in Diddy Kong Racing, which was released in 1997.",
                "level": "Beginner"
            },
            {
                "title": "In Their Series",
                "content": "The two set out on a journey to save Banjo's sister Tooty who was abducted by Gruntilda. They adventure through many stages that require them to work together to overcome obstacles.",
                "level": "Beginner"
            },
            {
                "title": "Egg Firing (Neutral Special)",
                "content": "Kazooie can fire eggs from her mouth. The eggs will bounce when they hit the ground and will explode if they hit an opponent.",
                "level": "Beginner"
            },
            {
                "title": "Breegull Blaster (Neutral Special)",
                "content": "Press and hold the button to make Banjo pick Kazooie up and rapidly shoot eggs. You can move and jump while firing eggs this way.",
                "level": "Beginner"
            },
            {
                "title": "Canceling Breegull Blaster (Neutral Special)",
                "content": "Breegull Blaster will end if you try to crouch, shield, or use a different special move. However, the action you used to cancel Breegull Blaster won't happen unless you press and hold the inputs.",
                "level": "Beginner"
            },
            {
                "title": "Breegull Blaster Power (Neutral Special)",
                "content": "The egg's power will decrease if fired continuously. The power will drop up to two times, but it will start to return to normal power once you put the Breegull Blaster away.",
                "level": "Beginner"
            },
            {
                "title": "Wonderwing (Side Special)",
                "content": "Use a Golden Feather to become invincible and charge forward. The powerful tackle is useful for returning to the stage, but if you use up all the feathers, you can't use the move anymore.",
                "level": "Beginner"
            },
            {
                "title": "Wonderwing Tackle (Side Special)",
                "content": "You won't take damage or get knocked back by attacks while charging forward. However, being blocked by a shielding opponent will leave you vulnerable!",
                "level": "Beginner"
            },
            {
                "title": "Wonderwing Feather (Side Special)",
                "content": "You can use five Golden Feathers in standard battles and one during Sudden Death. Your Golden Feathers will not be replenished until you are KO'd.",
                "level": "Beginner"
            },
            {
                "title": "Wonderwing in Stamina Mode (Side Special)",
                "content": "In a stamina battle, the number of available Golden Feathers will vary depending on the initial stamina amount.",
                "level": "Beginner"
            },
            {
                "title": "Shock Spring Jump (Up Special)",
                "content": "Use a Shock Spring Pad to jump straight up. After using this ability, you can freely move and attack while in the air.",
                "level": "Beginner"
            },
            {
                "title": "Shock Spring Jump Charge (Up Special)",
                "content": "You can jump higher if you press and hold the button to charge up power before jumping off of the Shock Spring Pad.",
                "level": "Beginner"
            },
            {
                "title": "Attacking with Shock Spring Pad (Up Special)",
                "content": "The dropped Shock Spring Pad can hit opponents. The attack power won't change even if the move is charged.",
                "level": "Beginner"
            },
            {
                "title": "Rear Egg (Down Special)",
                "content": "Kazooie will shoot grenade eggs diagonally upward in the direction she isn't facing. Make sure to turn around before letting loose.",
                "level": "Beginner"
            },
            {
                "title": "Rear Egg's Characteristics (Down Special)",
                "content": "Grenade eggs aren't perfect circles and have an odd bounce as a result. You can pick one up to throw, but if the timed fuse runs out while you're still holding it, the explosion will damage you!",
                "level": "Beginner"
            },
            {
                "title": "Only One Rear Egg (Down Special)",
                "content": "Only one grenade egg can exist on the stage at any time. If you try to use the move again while your grenade egg exists, you'll be left vulnerable.",
                "level": "Beginner"
            },
            {
                "title": "The Mighty Jinjonator (Final Smash)",
                "content": "Summon a statue from the ground. If it hits an opponent, the Mighty Jinjonator will be awakened from the statue and unleash continuous high-speed strikes alongside other Jinjos to launch the opponent.",
                "level": "Beginner"
            },
            {
                "title": "Twirling Wing Whack (Neutral Air Attack)",
                "content": "Kazooie will spread her wings and twirl to attack in all directions. This attack will reach farther when used while moving to the side rather than up or down.",
                "level": "Beginner"
            },
            {
                "title": "Beak Buster (Down Air Attack)",
                "content": "This move has a meteor effect at the beginning. However you will dive quickly, so be careful of self-destructs.",
                "level": "Intermediate"
            },
            {
                "title": "Downward Throw",
                "content": "Buries a grabbed opponent in the ground. The higher their damage is, the longer they will be buried.",
                "level": "Beginner"
            },
            {
                "title": "Midair Jump",
                "content": "You can perform up to two midair jumps. You can jump after using their up special too, making it easy to recover.",
                "level": "Beginner"
            },
            {
                "title": "Kazooie's Characteristics",
                "content": "Kazooie won't usually get hit by opponents' attacks. However, she will get hit while running.",
                "level": "Beginner"
            },
            {
                "title": "Talon Trot",
                "content": "Kazooie will come out of the backpack and carry Banjo while running. In the original game, you could run faster and run up steep hills with this ability.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "73",
                "name": "Banjo & Kazooie",
                "slug": "banjo-kazooie",
                "also_appears_in": []
            }
        ]
    },
    {
