        "tips": [
            {
                "title": "Lucina's Origins",
                "content": "Lucina made her debut with the 2013 release of Fire Emblem Awakening. At first, she went by Marth, but she later revealed her true identity.",
                "level": "Beginner"
            },
            {
                "title": "In Her Series",
                "content": "Chrom's daughter who comes from the future wielding Parallel Falchion. The Brand of the Exalt is located in her left eye. When she first appears, she wears a mask and calls herself Marth, after the legendary Hero-King.",
                "level": "Beginner"
            },
            {
                "title": "Critical Hit (Final Smash)",
                "content": "Lucina dashes forward and launches any foes in her path. It goes quite far if nothing gets in its way, so swing your sword before you go off-screen!",
                "level": "Beginner"
            },
            {
                "title": "Anti-air Slash (Up Tilt Attack)",
                "content": "Lucina cuts an arc through the air with her sword. This does the most damage at the back, so try using it on foes standing close behind you!",
                "level": "Intermediate"
            },
            {
                "title": "Vs. Marth",
                "content": "Marth's sword deals more damage at the tip, but Lucina's is the same all the way along. That aside, their moves are fundamentally pretty similar.",
                "level": "Beginner"
            }
        ],
