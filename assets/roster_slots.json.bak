            }
        ],
        "variants": [
            {
                "name": "Yoshi",
                "boxing_ring_title": "Omnivore of the Year",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "In Its Series",
                "content": "Yoshi has kept busy appearing in many titles since debuting in Super Mario World. Yoshi can flutter jump and has a long tongue that can gobble up apples and enemies. Yoshis can be a variety of colors.",
                "level": "Beginner"
            },
            {
                "title": "Mario's Loyal Ally",
                "content": "Yoshi made his debut in Super Mario World, where Yoshi was trapped inside an egg by Bowser and freed by Mario.",
                "level": "Beginner"
            },
            {
                "title": "Yoshi's Puzzle Games",
                "content": "Yoshi is the namesake of the NES title Yoshi. Yoshi later appeared in Yoshi's Cookie and Tetris Attack, both for the SNES.",
                "level": "Beginner"
            },
            {
                "title": "Egg Lay (Neutral Special)",
                "content": "This move grabs opponents with Yoshi's tongue and traps them in an egg. They'll take less damage while trapped, but you can hit them all you like!",
                "level": "Intermediate"
            },
            {
                "title": "Egg Lay off the Edge (Neutral Special)",
                "content": "Opponents that have taken a lot of damage have more trouble escaping from eggs. This means you may be able to swallow them and lay them in an egg off the edge of the stage.",
                "level": "Intermediate"
            },
            {
                "title": "Egg Form (Neutral Special)",
                "content": "The more damage Yoshi's foes have accumulated, the longer they'll be stuck as an egg. They can escape faster by wiggling around.",
                "level": "Intermediate"
            },
            {
                "title": "Egg Roll (Side Special)",
                "content": "This move turns Yoshi into an egg that rolls along the ground. The faster it goes, the more powerful it'll be.",
                "level": "Beginner"
            },
            {
                "title": "Egg Roll in the Air (Side Special)",
                "content": "You can start this move in the air, but you won't deal any damage until you hit the ground.",
                "level": "Beginner"
            },
            {
                "title": "Egg Throw's Power (Up Special)",
                "content": "How hard Yoshi throws the egg depends on how long you hold the button down. Tap for a light throw or hold for a powerful one.",
                "level": "Intermediate"
            },
            {
                "title": "Upward Eggs (Up Special)",
                "content": "You can throw the egg straight up by inputting the direction Yoshi's facing away from just before throwing. Fake out your foes with this technique.",
                "level": "Intermediate"
            },
            {
                "title": "A Little Eggstra Boost (Up Special)",
                "content": "Unlike other fighters, Yoshi doesn't have a vertical move used mainly for recovering. However, Yoshi will flutter a little bit if this move is used in midair.",
                "level": "Beginner"
            },
            {
                "title": "Yoshi Bomb's Power (Down Special)",
                "content": "The damage and launching power of the Yoshi Bomb are both a little higher when used on the ground.",
                "level": "Intermediate"
            },
            {
                "title": "Break Shields with Yoshi Bomb (Down Special)",
                "content": "Yoshi Bomb is great for breaking shields. Start off with multiple neutral attacks, and then use Yoshi Bomb to finish that shield off.",
                "level": "Intermediate"
            },
            {
                "title": "Platforms and Yoshi Bomb (Down Special)",
                "content": "At the start of the move, Yoshi will automatically pass through platforms. During the move, keep the stick tilted down to pass through all platforms until Yoshi lands.",
                "level": "Intermediate"
            },
            {
                "title": "Yoshi Stampede (Final Smash)",
                "content": "A mighty Yoshi army stampedes through the stage. Fighters hit by the stampede will be launched. You can hit up to three fighters.",
                "level": "Beginner"
            },
            {
                "title": "Noggin Dunk (Forward Air Attack)",
                "content": "Yoshi charges up for a moment and then delivers a powerful headbutt. If you hit opponents from above, they'll fly down with a meteor effect.",
                "level": "Advanced"
            },
            {
                "title": "Flutter Kick (Down Air Attack)",
                "content": "This attack is very powerful if the foe is directly beneath Yoshi. It can hit an opponent multiple times, so try your best to catch them right at the start of the attack for maximum damage!",
                "level": "Intermediate"
            },
            {
                "title": "Egg Shield",
                "content": "Unlike other fighters, Yoshi's shield is an all-protecting egg. Even if the shield blocks attacks, it won't get smaller and Yoshi's body won't poke out from the shield.",
                "level": "Beginner"
            },
            {
                "title": "Midair Jump",
                "content": "Yoshi's midair jump won't stop if a foe attacks Yoshi in the middle of it. It's more difficult to withstand attacks with high launching power, though, so be careful if your damage is high!",
                "level": "Beginner"
            }
        ],
        "fighters": [
