        ],
        "variants": [
            {
                "name": "Male",
                "boxing_ring_title": "The Ashen Demon",
                "type": "Same character"
            },
            {
                "name": "Female",
                "boxing_ring_title": "The Ashen Demon",
                "type": "Same character"
            }
        ],
        "tips": [
            {
                "title": "Byleth's Origins",
                "content": "Byleth first appeared in the Fire Emblem: Three Houses game, released in 2019. Byleth became a professor at the Officers Academy and led one of three classes.",
                "level": "Beginner"
            },
            {
                "title": "In Their Series",
                "content": "Byleth lived as a mercenary but became a professor after rescuing students of the Officers Academy. Byleth would go on to teach at the school, fighting alongside and commanding the students in battle.",
                "level": "Beginner"
            },
            {
                "title": "Four Weapons",
                "content": "Each move uses a sword, axe, lance, or bow that appears in the original game. The axe, lance, and bow are the Heroes' Relics of the three house leaders, and the sword is Byleth's Hero's Relic.",
                "level": "Beginner"
            },
            {
                "title": "Failnaught (Neutral Special)",
                "content": "Press the special-move button to draw the bow and prepare a powerful attack. It takes time to unleash, but the arrow moves fast and travels far!",
                "level": "Beginner"
            },
            {
                "title": "Failnaught Charged (Neutral Special)",
                "content": "Hold down the button and charge to unleash a beam of light straight across. The attack will usually hit immediately and is extremely powerful against opponents directly in the line of fire.",
                "level": "Beginner"
            },
            {
                "title": "Canceling Failnaught (Neutral Special)",
                "content": "It's possible to dodge in place or shield when you first begin to draw the bow, but the move will reset if you do so. Once the charge begins after holding down the button, you won't be able to dodge or shield.",
                "level": "Beginner"
            },
            {
                "title": "Turning with Failnaught (Neutral Special)",
                "content": "While drawing the bow, you can turn and face the opposite way by tilting in that direction. This won't interrupt the attack, but it can only be done at the beginning of the move.",
                "level": "Beginner"
            },
            {
                "title": "Areadbhar (Side Special)",
                "content": "Swing this legendary lance in front of you, using its long reach to cover the area ahead and upward. The bladed part of the weapon is the most powerful part.",
                "level": "Beginner"
            },
            {
                "title": "Flicking the Stick with Areadbhar (Side Special)",
                "content": "If you flick the stick and input your attack, you will swing up while charging forward. Pay close attention to how far you are from your opponent, and use this technique to surprise them!",
                "level": "Beginner"
            },
            {
                "title": "Using Areadbhar in the Air (Side Special)",
                "content": "When using this move in the air, the attack strikes in a wide arc from below upward. Flicking the stick will allow you to move forward a little too!",
                "level": "Beginner"
            },
            {
                "title": "Sword of the Creator (Up Special)",
                "content": "Extend the sword upward and diagonally. If this attack hits an opponent, the blade will quickly shorten and bring you close to the enemy. After the jump, you can move about freely in the air.",
                "level": "Beginner"
            },
            {
                "title": "Sword of the Creator and Walls (Up Special)",
                "content": "If the blade's tip hits a wall, the sword will shorten and pull you toward the wall. It's possible to then jump off the wall and follow up with another jump or an attack!",
                "level": "Beginner"
            },
            {
                "title": "Sword of the Creator and Edges (Up Special)",
                "content": "If you use this move near an edge and it connects, the sword's blade will bury into the edge and you'll dangle freely. Tilt the stick or press a button and the sword will shorten, pulling you toward the edge.",
                "level": "Beginner"
            },
            {
                "title": "Sword of the Creator and Footstooling Opponents (Up Special)",
                "content": "If the opponent's accumulated damage is 50% or more, the footstool part of this attack will have a meteor effect. Also, the farther the sword is extended, the more power it will have when footstooling someone.",
                "level": "Intermediate"
            },
            {
                "title": "Aymr (Down Special)",
                "content": "Charge up the axe, then swing down with incredible force. It takes a while to prepare this attack, so using it can leave you vulnerable, but enemies on the receiving end of this can suffer serious damage.",
                "level": "Beginner"
            },
            {
                "title": "Turn and Attack with Aymr (Down Special)",
                "content": "If you draw the axe and then input the opposite direction from the way you're facing, you will turn and unleash this attack in the indicated direction instead.",
                "level": "Beginner"
            },
            {
                "title": "Aymr's Super Armor (Down Special)",
                "content": "If this attack is charged while standing on the ground, you'll have super armor until you swing the axe.",
                "level": "Beginner"
            },
            {
                "title": "Progenitor God Ruptured Heaven (Final Smash)",
                "content": "Swing the sword, striking in a wide arc in front of you. This attack can hit up to three opponents. Combine Sothis's strength with the Sword of the Creator to unleash a powerful attack.",
                "level": "Beginner"
            },
            {
                "title": "Side Smash Attack",
                "content": "Extend the lance for a long-range, forward-facing attack! The tip of the lance is the strongest part, and you can adjust the attack's angle up or down. This attack is at its best when angled upward.",
                "level": "Intermediate"
            },
            {
                "title": "Up Smash Attack",
                "content": "Extend the sword and swing it around and up in a wide area. This attack lasts longer than some foes may expect, so it's easy to catch unprepared opponents off guard.",
                "level": "Beginner"
            },
            {
                "title": "Down Smash Attack",
                "content": "You can swing the axe forward and backward, dealing significant damage to anyone it hits. Be careful, though; the damage and launch power of this attack is high, but the move can leave you vulnerable.",
                "level": "Beginner"
            },
            {
                "title": "Down Air Attack",
                "content": "Swing the axe downward. Try to hit your opponent with the tip of the axe just as it reaches the lowest point. If you can pull it off, the blow will have a meteor effect.",
                "level": "Intermediate"
            },
            {
                "title": "Attacks Using the Lance",
                "content": "Side specials, side smash attacks, forward air attacks, and back air attacks all make use of the lance. Remember that the tip of the blade is the most powerful point, and the lance has a long reach.",
                "level": "Beginner"
            },
            {
                "title": "Attacks Using the Axe",
                "content": "Down specials, down smash attacks, and down air attacks all use the axe. The axe is slow and can leave you vulnerable, but that lack of speed is made up for with the devastating power of its attacks.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "75",
                "name": "Byleth",
                "slug": "byleth",
                "also_appears_in": []
            }
        ]
    },
