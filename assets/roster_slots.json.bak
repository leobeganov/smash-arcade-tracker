        "variants": [
            {
                "name": "Palutena",
                "boxing_ring_title": "The Goddess of Light",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Palutena's Origins",
                "content": "Palutena debuted in Kid Icarus for the NES. She only appeared in the ending sequence, but the Japanese version had her name in the title!",
                "level": "Beginner"
            },
            {
                "title": "In Her Series",
                "content": "The goddess that rules over Angel Land in Kid Icarus. Pit serves Palutena, the Goddess of Light and protector of humankind.",
                "level": "Beginner"
            },
            {
                "title": "Explosive Flame (Side Special)",
                "content": "This move causes an explosion a short distance away from Palutena. It deals multiple hits to any opponents in its vicinity and then sends them flying.",
                "level": "Beginner"
            },
            {
                "title": "Explosive Flame Positioning (Side Special)",
                "content": "Flick the control stick when you press the button to make the explosion occur farther away. Gauge the distance between you and the opponent, and try to make the explosion occur at the right spot.",
                "level": "Intermediate"
            },
            {
                "title": "Warp (Up Special)",
                "content": "Palutena disappears and then warps to a location a short distance away. Warp will take Palutena in the direction you press.",
                "level": "Beginner"
            },
            {
                "title": "Counter/Reflect Barrier (Down Special)",
                "content": "Used as a shield, this move can counter attacks, or reflect barrier can reflect projectiles! It is automatic, but both can't happen at once.",
                "level": "Beginner"
            },
            {
                "title": "Black Hole Laser (Final Smash)",
                "content": "Palutena's Final Smash traps opponents in a Black Hole before Palutena fires a laser beam to launch them. The beam's angle can be slightly adjusted.",
                "level": "Beginner"
            },
            {
                "title": "Purging Kick (Down Air Attack)",
                "content": "Compared to other attacks that have a meteor effect, Palutena's down air can be used very quickly. Going for a dunk is always a risky proposition, though.",
                "level": "Intermediate"
            },
            {
                "title": "Attacks Using a Shield",
                "content": "The shield used during her dash attack and back air attack will nullify incoming attacks. This means that you're unlikely to lose a face-off between these attacks and attacking opponents.",
                "level": "Intermediate"
            }
        ],
