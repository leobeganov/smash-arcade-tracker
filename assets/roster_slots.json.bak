        "variants": [
            {
                "name": "Olimar",
                "boxing_ring_title": "The Veteran Astronaut",
                "type": "Default"
            },
            {
                "name": "Alph",
                "boxing_ring_title": "Astronaut in Training",
                "type": "Different character"
            }
        ],
        "tips": [
            {
                "title": "Olimar's Origins",
                "content": "Olimar made his first appearance in the original Pikmin, released in 2001. He's a hardworking space pilot for Hocotate Freight.",
                "level": "Beginner"
            },
            {
                "title": "Alph's Origins",
                "content": "Alph first appeared in the 2013 title Pikmin 3. He's a cheerful and optimistic engineer who loves his job.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "The S.S. Dolphin runs into trouble during a space vacation, causing it to crash-land on an unexplored planet. Olimar tries to repair the ship using the help of the Pikmin he meets there.",
                "level": "Beginner"
            },
            {
                "title": "Origins of Name \"Pikmin\"",
                "content": "Olimar came up with the name \"Pikmin\" because the creatures look similar to a favorite vegetable of his, Pikpik carrots.",
                "level": "Beginner"
            },
            {
                "title": "Pikmin Pluck (Neutral Special)",
                "content": "Olimar will always pluck the Pikmin in this order: red, yellow, blue, white, purple.",
                "level": "Beginner"
            },
            {
                "title": "Pikmin Pluck's Limit (Neutral Special)",
                "content": "You can have up to three Pikmin in tow at any time. Plucking for more while three are already active is, sadly, futile.",
                "level": "Beginner"
            },
            {
                "title": "Pikmin Throw (Side Special)",
                "content": "Most Pikmin latch on to opponents and attack them repeatedly. Purple Pikmin, though, deal one heavy blow and then bounce off.",
                "level": "Beginner"
            },
            {
                "title": "Pikmin Hang Time (Side Special)",
                "content": "The less damage an opponent has accumulated, the longer the Pikmin can hang on to it.",
                "level": "Intermediate"
            },
            {
                "title": "Pikmin Order (Down Special)",
                "content": "This move will change the order of your Pikmin. Use it to plan your attack strategy.",
                "level": "Beginner"
            },
            {
                "title": "Winged Pikmin (Up Special)",
                "content": "The number of Pikmin you have will affect how high up you rise. Also, White Pikmin are light and Purple Pikmin are heavy. These characteristics affect how high you go, too.",
                "level": "Beginner"
            },
            {
                "title": "Orderly Pikmin (Down Special)",
                "content": "Olimar's whistle calls back his scattered Pikmin. Even the ones that are goofing off.",
                "level": "Beginner"
            },
            {
                "title": "Super Armor with Pikmin Order (Down Special)",
                "content": "This move gives Olimar super armor at the start of the move, so it's great not only for calling Pikmin, but also to avoid being launched by an opponent's attacks.",
                "level": "Beginner"
            },
            {
                "title": "End of Day (Final Smash)",
                "content": "When Olimar jumps into the Hocotate Ship, nearby enemies will be buried. If the ship hits anyone while it's airborne, they'll be slammed to the ground.",
                "level": "Intermediate"
            },
            {
                "title": "Starship Landing Site (Final Smash)",
                "content": "You can adjust the trajectory of the Hocotate Ship as it comes back down. If you aim it well, you can deal some serious damage to your opponents.",
                "level": "Intermediate"
            },
            {
                "title": "Smash Attack",
                "content": "All three of Olimar's smash attacks count as projectiles, which can be reflected by moves like Reflector.",
                "level": "Intermediate"
            },
            {
                "title": "Pikmin Left/Right Dash (Down Smash Attack)",
                "content": "If there are at least two Pikmin with Olimar, they'll attack on both sides of him. If there's only one, it'll attack in front of him.",
                "level": "Beginner"
            },
            {
                "title": "Tornado Attack (Neutral Air Attack)",
                "content": "Olimar attacks by twirling. It's his only aerial attack that doesn't use any Pikmin, so you can use it even if all your Pikmin are gone.",
                "level": "Beginner"
            },
            {
                "title": "Lead Pikmin",
                "content": "Olimar always attacks with the Pikmin at the front of the line. You can tell which one this is by the arrow pointing to it.",
                "level": "Beginner"
            },
            {
                "title": "Pikmin's Stamina",
                "content": "When separated from Olimar, Pikmin are vulnerable to enemy attacks.",
                "level": "Beginner"
            },
            {
                "title": "Pikmin Flowers",
                "content": "After being plucked, it takes some time for the flower on a Pikmin's head to bloom. As the flower grows, the Pikmin will move faster!",
                "level": "Advanced"
            },
            {
                "title": "Red Pikmin",
                "content": "Red Pikmin perform attacks that deal 1.4 times the standard damage. They're also immune to fire attacks, but their throw is weak.",
                "level": "Intermediate"
            },
            {
                "title": "Purple Pikmin",
                "content": "Attacks performed using Purple Pikmin deal 1.6 times the standard damage and launch foes farther too! They're lacking in reach and speed, however.",
                "level": "Intermediate"
            },
            {
                "title": "Yellow Pikmin",
                "content": "Yellow Pikmin attacks have 1.5 times the reach of the other colors. The Pikmin can't be killed by electric attacks.",
                "level": "Intermediate"
            },
            {
                "title": "Blue Pikmin",
                "content": "Throws performed with Blue Pikmin deal 1.7 times the standard damage. The rest of their abilities are average, with no real weaknesses.",
                "level": "Intermediate"
            },
            {
                "title": "White Pikmin",
                "content": "White Pikmin that stick to opponents will deal twice the normal amount of damage. They're quite speedy and can jump very high.",
                "level": "Intermediate"
            },
            {
                "title": "Blue Pikmin - Strong in the Water",
                "content": "Blue Pikmin can survive water in Smash Bros., just like they can in games from the Pikmin series. Other colors of Pikmin? Not so much.",
                "level": "Beginner"
            }
        ],
        "fighters": [
