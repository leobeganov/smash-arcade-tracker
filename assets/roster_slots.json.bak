        "variants": [
            {
                "name": "Captain Falcon",
                "boxing_ring_title": "The Supersonic Slugger",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Captain Falcon's Origins",
                "content": "Captain Falcon's first appearance was in the SNES launch title F-Zero, released in North America in 1991. You couldn't see him in the game itself, but he was in the manual.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "He's the main character of the F-Zero series. Known for being a skilled bounty hunter, he's also an exceptional pilot and racer of high-speed F-Zero machines.",
                "level": "Beginner"
            },
            {
                "title": "Captain Falcon's Machine",
                "content": "The Blue Falcon racing machine first appeared in the original F-Zero. Captain Falcon uses it in Smash Bros. for his Final Smash!",
                "level": "Beginner"
            },
            {
                "title": "Turn Around and Attack with Falcon Punch (Neutral Special)",
                "content": "After pressing the attack button, quickly turn around to make Captain Falcon unleash an even more powerful attack as he turns.",
                "level": "Advanced"
            },
            {
                "title": "Raptor Boost (Side Special)",
                "content": "Used in midair, his hand has a meteor effect on the downswing. The trick is to hit the foe when they're below Captain Falcon.",
                "level": "Advanced"
            },
            {
                "title": "Raptor Boost Techniques (Side Special)",
                "content": "Grants super armor at the beginning of the move if performed on the ground. Drive into opponents with Raptor Boost, and then follow up when they're floating in the air.",
                "level": "Beginner"
            },
            {
                "title": "Continuous Falcon Dives (Up Special)",
                "content": "A leaping grab that sends the opponent flying with explosive force. If it connects, you're free to use the same attack again without landing.",
                "level": "Beginner"
            },
            {
                "title": "Falcon Dive's Direction (Up Special)",
                "content": "Press left or right the moment Captain Falcon crouches to adjust the angle of the attack. By holding forward, you can greatly increase the range at which you can grab enemies.",
                "level": "Intermediate"
            },
            {
                "title": "Falcon Kick (Down Special)",
                "content": "The attack is at its most powerful right after pressing the button and loses power as it goes. However, it loses less power when it is used in the air.",
                "level": "Intermediate"
            },
            {
                "title": "Blue Falcon (Final Smash)",
                "content": "The summoned Blue Falcon hits an opponent and sends them flying to an F-Zero course. There, Captain Falcon rams his beloved vehicle into an opponent at high speed, launching them into the air.",
                "level": "Beginner"
            },
            {
                "title": "Blue Falcon Animation (Final Smash)",
                "content": "Depending on if he used it in the air or on the ground, Falcon's pose after striking will change. Of course, he won't be happy if he didn't hit anyone...",
                "level": "Intermediate"
            },
            {
                "title": "Wheel Kick (Up Tilt Attack)",
                "content": "If Falcon's heel hits an airborne enemy during this attack, it will dunk them. Try standing on the edge of the stage and using it on an opponent trying to grab the edge.",
                "level": "Advanced"
            },
            {
                "title": "Knee Smash (Forward Air Attack)",
                "content": "There's a violent knee jab at the start of this move. Connect with that for some serious launching power.",
                "level": "Intermediate"
            },
            {
                "title": "Overhead Kick (Up Air Attack)",
                "content": "It's easy to use this move with a combo or as a diversion. Depending on the hit, you may be able to connect it with a forward air or down air attack to secure a KO.",
                "level": "Beginner"
            }
        ],
        "fighters": [
