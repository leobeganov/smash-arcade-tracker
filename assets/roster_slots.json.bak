        ],
        "variants": [
            {
                "name": "Bayonetta 1",
                "boxing_ring_title": "Umbra Witch",
                "type": "Same character"
            },
            {
                "name": "Bayonetta 2",
                "boxing_ring_title": "Umbra Witch",
                "type": "Same character"
            }
        ],
        "tips": [
            {
                "title": "In Her Series",
                "content": "Bayonetta was a witch that lost her memory. Her real name is Cereza. She uses her arms and legs to wield four guns, and has mastered the Bullet Arts fighting style.",
                "level": "Beginner"
            },
            {
                "title": "Rapid Fire with Bullet Climax (Neutral Special)",
                "content": "Bayonetta alternates which guns she fires each time you use this move. Keep hitting the button while she's firing to let off more shots.",
                "level": "Beginner"
            },
            {
                "title": "Bullet Climax's Charge (Neutral Special)",
                "content": "Hold down the button to unleash more powerful Charge Bullets. Only the first four shots are boosted; the follow-up shots won't be affected.",
                "level": "Beginner"
            },
            {
                "title": "Heel Slide (Side Special)",
                "content": "Performs a low, sliding kick. Hold down the button to get in a few gunshots, and then end with a flip attack for good measure.",
                "level": "Beginner"
            },
            {
                "title": "Two-Part After Burner Kick (Side Special)",
                "content": "If you land a hit with After Burner Kick, you'll have a one-second window to use the kick again. This allows you to travel long distances and combo opponents.",
                "level": "Beginner"
            },
            {
                "title": "After Burner Kick Angle (Side Special)",
                "content": "Tilt the control stick down immediately before or after using After Burner Kick to make the move go diagonally down.",
                "level": "Beginner"
            },
            {
                "title": "Witch Twist's Traits (Up Special)",
                "content": "This versatile move is great for combos or recovery! Do a midair jump after using the move and you can get in a sneaky extra Witch Twist.",
                "level": "Beginner"
            },
            {
                "title": "Witch Twist's Angle (Up Special)",
                "content": "The angle foes are launched at changes between the first and second Witch Twists. Adjust your tactics to the situation to get the best combos.",
                "level": "Beginner"
            },
            {
                "title": "Witch Time's Effect (Down Special)",
                "content": "A successful counter will cause time to slow down. The more damage the opponent has, the longer time will slow down for.",
                "level": "Beginner"
            },
            {
                "title": "Witch Time Confirmation (Down Special)",
                "content": "A clock will appear over an enemy to tell you how much Witch Time is left. Try to get your attacks in before the clock counts down!",
                "level": "Beginner"
            },
            {
                "title": "Witch Time's Traits (Down Special)",
                "content": "Witch Time won't last long if you keep using it against every single attack. Keep it in reserve for when you really need it!",
                "level": "Beginner"
            },
            {
                "title": "Witch Time and Projectiles (Down Special)",
                "content": "If you can counter the opponent's projectile, you can slow the opponent down if you're not too far away from them.",
                "level": "Advanced"
            },
            {
                "title": "Infernal Climax (Final Smash)",
                "content": "For Bayonetta's Final Smash, she enters Witch Time. If you fill up the Climax Gauge by attacking opponents, you can summon Gomorrah. The Climax Gauge has a time limit, so don't dilly dally.",
                "level": "Beginner"
            },
            {
                "title": "Infernal Climax Additional Damage (Final Smash)",
                "content": "The Climax Gauge stays around even after Gomorrah is summoned. If you press attack and light up all eight symbols, you'll deal more damage. If the opponent has over 100% damage, they'll be KO'd.",
                "level": "Beginner"
            },
            {
                "title": "Launching with Consecutive Kicks (Side Tilt Attack)",
                "content": "Keep pressing the button and Bayonetta will do a three-kick attack. The last kick launches foes, so go for a quick midair attack right after!",
                "level": "Beginner"
            },
            {
                "title": "Against Aerial Attacks (Up Tilt Attack)",
                "content": "This move covers a big area above Bayonetta, and it also hits opponents in front of her. Like many other tilt attacks, it's a great setup for a follow-up attack.",
                "level": "Beginner"
            },
            {
                "title": "Kick Attack and Gun Fire (Down Tilt Attack)",
                "content": "Bayonetta quickly sweeps enemies off their feet and will shoot ahead and behind if you hold the button. The guns firing ahead deal more damage.",
                "level": "Beginner"
            },
            {
                "title": "Stomp to Meteor (Down Smash Attack)",
                "content": "Summon the crushing foot of a demon to slam down with a meteor effect, particularly effective in preventing foes from recovering from falls or climbing up edges.",
                "level": "Beginner"
            },
            {
                "title": "Consecutive Midair Attacks (Forward Air Attack)",
                "content": "Keep pressing the button for three shots in the air. Perfect for foes trying to recover. Or hold the button to pile on the pressure with a hail of bullets!",
                "level": "Beginner"
            },
            {
                "title": "Rapidly Descending Meteor (Down Air Attack)",
                "content": "Bayonetta drops straight down into a split kick. She'll constantly deal damage as she drops, and her foot has a meteor effect.",
                "level": "Beginner"
            },
            {
                "title": "Tetsuzankou (Forward Throw)",
                "content": "For Bayonetta's forward throw, she borrows Akira's infamous move from the Virtua Fighter series. When Bayonetta performs this move, she sometimes delivers his catchphrase along with it.",
                "level": "Beginner"
            },
            {
                "title": "Hold Attack to Keep Firing",
                "content": "Keep the button held down after any normal attack (and some specials) to fire your guns.",
                "level": "Intermediate"
            },
            {
                "title": "Hold Attack to Steal KO",
                "content": "Even if an attack misses, you can still hold the button and get a few shots in. You can even steal a KO by hitting a launched foe on their way out! Cheeky.",
                "level": "Intermediate"
            },
            {
                "title": "Bat Within",
                "content": "If Bayonetta is hit during the dodge or during her down special, she'll change into a burst of bats, taking half the damage.",
                "level": "Beginner"
            },
            {
                "title": "Filling the Witch Time Gauge",
                "content": "The gauge fills as you land attacks in Witch Time during Bayonetta's Final Smash. If you focus on a single target, you'll waste time chasing them each time they're launched, so try to attack multiple opponents.",
                "level": "Intermediate"
            }
        ],
        "fighters": [
