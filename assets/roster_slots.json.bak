            },
            {
                "slot": 6,
                "variant": "Rosalina & Luma",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/rosalina-and-luma/main6.png"
            },
            {
                "slot": 7,
                "variant": "Rosalina & Luma",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/rosalina-and-luma/main7.png"
            },
            {
                "slot": 8,
                "variant": "Rosalina & Luma",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/rosalina-and-luma/main8.png"
            }
        ],
        "variants": [
            {
                "name": "Rosalina & Luma",
                "boxing_ring_title": "The Cosmic Travelers",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Rosalina & Luma's Origins",
                "content": "Rosalina and Luma made their debut in the 2007 title Super Mario Galaxy. Rosalina is a mysterious galactic traveler, and the Lumas her companions.",
                "level": "Beginner"
            },
            {
                "title": "In Their Series",
                "content": "The keeper of the Comet Observatory, which floats in the middle of the galaxy. She has a mysterious backstory and travels with the Lumas until they turn into shooting stars.",
                "level": "Beginner"
            },
            {
                "title": "Luma's Color",
                "content": "Lumas come in various colors, but their abilities are identical. The six colors you can get are yellow, red, green, blue, cream, and Polari.",
                "level": "Beginner"
            },
            {
                "title": "Luma Shot (Neutral Special)",
                "content": "This sends Luma hurtling forward with a high chance of launching opponents. Charge up this move to send Luma flying farther.",
                "level": "Beginner"
            },
            {
                "title": "Luma Shot Charges Forth (Neutral Special)",
                "content": "Luma keeps going for a bit after it hits a foe, but it slows down and deals less damage.",
                "level": "Intermediate"
            },
            {
                "title": "Robust Luma (Neutral Special)",
                "content": "It's harder to launch Luma when it's sent out with Luma Shot than it is when Luma is near Rosalina. Try sending Luma away occasionally.",
                "level": "Beginner"
            },
            {
                "title": "Luma's Direction (Neutral Special)",
                "content": "Luma sent out with Luma Shot will automatically face a nearby opponent and attack them when using moves such as neutral attack.",
                "level": "Beginner"
            },
            {
                "title": "Rebound Blows (Neutral Special)",
                "content": "When it's on the way back after Luma Shot, Luma can attack as normal. Use this to surprise fighters heading for Rosalina or as a diversion.",
                "level": "Intermediate"
            },
            {
                "title": "Star Bits (Side Special)",
                "content": "Luma fires Star Bits that can scatter in three directions: high, middle, and low.",
                "level": "Beginner"
            },
            {
                "title": "Launch Star (Up Special)",
                "content": "If you input backward just before Rosalina takes off, she'll fly straight up. Useful when you need as much height as possible.",
                "level": "Intermediate"
            },
            {
                "title": "Gravitational Pull (Down Special)",
                "content": "This move pulls in projectiles from a wide area around Rosalina. Use it to pull Ness's PK Thunder off course when he's trying to recover!",
                "level": "Intermediate"
            },
            {
                "title": "Pulling in Items (Down Special)",
                "content": "Rosalina and Luma's down special draws in items so Rosalina can pick them up. It can be used to nullify a number of projectiles, but it's especially useful for gaining ownership of items thrown at you.",
                "level": "Beginner"
            },
            {
                "title": "Grand Star (Final Smash)",
                "content": "The Grand Star scatters shooting stars across the stage. Eventually, the Grand Star will increase in size and explode. Opponents hit with the shooting stars will be drawn closer to the Grand Star.",
                "level": "Beginner"
            },
            {
                "title": "Controlling Luma",
                "content": "You can attack with Luma even when Rosalina can't move, but you won't be able to while being thrown or right after being launched.",
                "level": "Beginner"
            },
            {
                "title": "Luma Regeneration",
                "content": "If Luma is KO'd, the time it takes for Luma to regenerate depends on how many opponents are in the match. It takes longer when it's 1 vs. 1, and shorter when it's a four-player battle.",
                "level": "Intermediate"
            },
            {
                "title": "Luma at Low Health",
                "content": "When Luma has only a little bit of health it will look down and act tired. In this state, Luma will travel back slower to Rosalina when she uses a neutral special.",
                "level": "Intermediate"
            },
            {
                "title": "Luma's Reactions",
                "content": "When Luma is next to Rosalina, it starts dancing if she grabs an opponent. When she gets hurt, you can see it flailing its little arms in panic!",
                "level": "Beginner"
            }
        ],
        "fighters": [
