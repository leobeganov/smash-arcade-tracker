        ],
        "variants": [
            {
                "name": "Young Link",
                "boxing_ring_title": "The Master of the Ocarina",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Young Link's Origins",
                "content": "Young Link debuted in The Legend of Zelda: Ocarina of Time released in 1998. He lived in the Kokiri Forest, until the Great Deku Tree, guardian of the forest, informs him of danger approaching Hyrule.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "To stop Ganondorf, the Great King of Evil, Young Link travels with his fairy companion Navi. He pulls out the Master Sword, and after a seven-year slumber, emerges as the Hero of Time.",
                "level": "Beginner"
            },
            {
                "title": "Fire Arrow (Neutral Special)",
                "content": "Young Link's arrows will burn anything they hit. They can be used to detonate explosives from far away.",
                "level": "Beginner"
            },
            {
                "title": "Boomerang (Side Special)",
                "content": "The Boomerang will also hit when returning, making it useful to keep opponents at bay. The Boomerang Young Link uses is the one from The Legend of Zelda: Ocarina of Time.",
                "level": "Beginner"
            },
            {
                "title": "Boomerang's Flight Distance (Side Special)",
                "content": "The distance the Boomerang flies depends on how far you tilt the control stick, but it can't fly as far as the other Links' boomerangs. However, it deals heavy damage the moment it's thrown.",
                "level": "Beginner"
            },
            {
                "title": "Spin Attack (Up Special)",
                "content": "Spins around and hits opponents repeatedly. Hold down the button while on the ground to increase the power. The launching power is low, but you can get combos with an air attack.",
                "level": "Beginner"
            },
            {
                "title": "Bomb (Down Special)",
                "content": "Fighters caught in the bomb's explosion can be hit a maximum of four times. Since it hits multiple times, the damage it deals is higher than Link's or Toon Link's bombs.",
                "level": "Beginner"
            },
            {
                "title": "Bomb Blast (Down Special)",
                "content": "Your bombs are special ones—the explosion from hitting an enemy won't hurt you.",
                "level": "Beginner"
            },
            {
                "title": "Triforce Slash (Final Smash)",
                "content": "If the Triforce hits an opponent, the opponent will be bound and hit with the sword multiple times. The final blow can hit multiple enemies.",
                "level": "Beginner"
            },
            {
                "title": "Down Taunt",
                "content": "Young Link drinks the famous product of Lon Lon Ranch, Lon Lon Milk. Drinking it won't heal any damage, but it sure is delicious!",
                "level": "Intermediate"
            },
            {
                "title": "Differences from Other Links",
                "content": "Young Link's launch power is the weakest of the Links, but that makes it easier to perform combos. He's quicker in the air, can unleash moves faster, and is less vulnerable when landing.",
                "level": "Beginner"
            }
        ],
