        "variants": [
            {
                "name": "Mewtwo",
                "boxing_ring_title": "A Legend Reawakens",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Mewtwo's Origins",
                "content": "Mewtwo first appears in Pokémon Red and Pokémon Blue. After the trainer comes out victorious in the Pokémon League, Mewtwo can be found in a cave on the outskirts of Cerulean City.",
                "level": "Beginner"
            },
            {
                "title": "In Its Series",
                "content": "Mewtwo was born from recombined genes of a Mythical Pokémon, Mew. Its fighting ability is incredibly high, and it's said to have the most savage heart among Pokémon.",
                "level": "Beginner"
            },
            {
                "title": "Mega Mewtwo Y",
                "content": "In its Final Smash, Mewtwo Mega Evolves into Mega Mewtwo Y. In the Pokémon games, it can Mega Evolve into this form if it holds on to Mewtwonite Y.",
                "level": "Beginner"
            },
            {
                "title": "Charging Shadow Ball (Neutral Special)",
                "content": "This move does more damage the longer it's charged...but it also has more recoil. The recoil is stronger when this move is used in midair.",
                "level": "Beginner"
            },
            {
                "title": "Holding Charge on Shadow Ball (Neutral Special)",
                "content": "Mewtwo won't automatically attack when this move is fully charged. You can press the shield button to cancel the move and keep the charge.",
                "level": "Intermediate"
            },
            {
                "title": "Confusion (Side Special)",
                "content": "This special grabbing move lets Mewtwo repel foes with telekinesis. It can also reflect enemy projectiles.",
                "level": "Beginner"
            },
            {
                "title": "Confusion's Traits (Side Special)",
                "content": "This move sends the opponent spinning, and sometimes you can get in follow-up attacks since the time it takes for an opponent to be able to move again is affected by how much damage they've taken.",
                "level": "Intermediate"
            },
            {
                "title": "Teleport (Up Special)",
                "content": "Mewtwo will disappear for a moment, reappearing elsewhere on the stage. Mewtwo is completely invulnerable while teleporting.",
                "level": "Beginner"
            },
            {
                "title": "Teleport Landing Position (Up Special)",
                "content": "If Mewtwo finishes this move on the ground, Mewtwo will stop in place, but if the move finishes in the air, Mewtwo's momentum will carry it a bit farther.",
                "level": "Intermediate"
            },
            {
                "title": "Teleport's Traits (Up Special)",
                "content": "If Mewtwo hits a platform while teleporting, it will slide across it. You can adjust its destination with directional inputs.",
                "level": "Intermediate"
            },
            {
                "title": "Disable (Down Special)",
                "content": "The higher the target's damage, the longer they'll be stunned for. However, if the move is reflected, Mewtwo will be stunned instead.",
                "level": "Beginner"
            },
            {
                "title": "Warnings for Disable (Down Special)",
                "content": "This powerful move requires eye contact to work. If the enemy is looking, it can stun them, but if not... Well, it's not much of a staring contest.",
                "level": "Intermediate"
            },
            {
                "title": "Disable Techniques (Down Special)",
                "content": "Immediately after unleashing this move, you'll be invincible for a quick moment, allowing you to avoid attacks. It's a powerful move to use just as an opponent begins their attack.",
                "level": "Advanced"
            },
            {
                "title": "Psystrike (Final Smash)",
                "content": "Mewtwo Mega Evolves into Mega Mewtwo Y and fires a projectile that penetrates terrain and opponents. It'll stop the movement of any opponent it touches, and then launches them.",
                "level": "Beginner"
            },
            {
                "title": "Tail Sweep (Down Tilt Attack)",
                "content": "You can change the direction you launch enemies in by hitting them with different parts of Mewtwo's tail.",
                "level": "Beginner"
            },
            {
                "title": "Shadow Blast (Side Smash Attack)",
                "content": "The shock wave does more damage at the very edges than at the core. Watch what you're doing, and try to attack with the edge of the wave.",
                "level": "Beginner"
            },
            {
                "title": "Galaxy Force (Up Smash Attack)",
                "content": "This attack can strike an enemy multiple times if you can hit them at the right time. It's very difficult to escape this attack before it's over.",
                "level": "Beginner"
            },
            {
                "title": "Shadow Bomb (Down Smash Attack)",
                "content": "This attack only strikes right beside Mewtwo's feet and doesn't do so much damage, but it has a high launching ability to make up for it.",
                "level": "Beginner"
            },
            {
                "title": "Body Spark (Neutral Air Attack)",
                "content": "Hitting an enemy with this doesn't do much damage, but it hits multiple times. If you time it right, it can even launch foes.",
                "level": "Beginner"
            },
            {
                "title": "Shadow Scratch (Forward Air Attack)",
                "content": "This attack might be short range, but it's fast and has a lot of launch power. Use it while ascending to get the most out of it!",
                "level": "Beginner"
            },
            {
                "title": "Shadow Cannon (Forward Throw)",
                "content": "Mewtwo will throw an enemy and quickly fire Shadow Ball five times. Each projectile doesn't do much damage, but it can hit multiple foes.",
                "level": "Beginner"
            },
            {
                "title": "Psychic Whirlwind (Up Throw)",
                "content": "Mewtwo's up throw boasts top class launching power compared to all of the other fighters' throw moves. It's super effective in situations where there is no ceiling.",
                "level": "Intermediate"
            },
            {
                "title": "Mewtwo's Launchability",
                "content": "Despite Mewtwo's fierce appearance, Mewtwo is very light and easy to launch. When playing as Mewtwo, you'll need to prioritize your defense and evasion as much as your offense.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "24",
                "name": "Mewtwo",
                "slug": "mewtwo",
                "also_appears_in": [
                    "Melee",
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
