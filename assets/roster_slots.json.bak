                "type": "Different character"
            }
        ],
        "tips": [
            {
                "title": "Bowser Jr.'s Origins",
                "content": "Bowser Jr. first appeared in the 2002 title Super Mario Sunshine. He's a bit of a brat, but he does have a lot of love for his daddy.",
                "level": "Beginner"
            },
            {
                "title": "Larry's Origins",
                "content": "Larry Koopa's debut was in Super Mario Bros. 3, released in North America in 1990. He's the youngest of the Koopalings.",
                "level": "Beginner"
            },
            {
                "title": "Roy's Origins",
                "content": "Roy Koopa's debut was in Super Mario Bros. 3, released in North America in 1990. If you see a big Koopaling wearing pink shades, that's him.",
                "level": "Beginner"
            },
            {
                "title": "Lemmy's Origins",
                "content": "Lemmy Koopa debuted in Super Mario Bros. 3, released in North America in 1990. He's the smallest and quickest of the Koopalings.",
                "level": "Beginner"
            },
            {
                "title": "Ludwig's Origins",
                "content": "Ludwig von Koopa first appeared in Super Mario Bros. 3, released in North America in 1990. You could call him the brains of the Koopalings.",
                "level": "Beginner"
            },
            {
                "title": "Morton's Origins",
                "content": "Morton Koopa Jr.'s debut was in Super Mario Bros. 3, released in North America in 1990. As the largest of the Koopalings, he's proudly more brawn than brains.",
                "level": "Beginner"
            },
            {
                "title": "Wendy's Origins",
                "content": "The stylish Wendy O. Koopa made her debut in North America with the 1990 release of Super Mario Bros. 3. She's the only female Koopaling.",
                "level": "Beginner"
            },
            {
                "title": "Iggy's Origins",
                "content": "Trickster Iggy Koopa debuted in Super Mario Bros. 3, released in North America in 1990. Fun fact: he's the only nearsighted Koopaling!",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Bowser's openly selfish son Bowser Jr. made his first appearance in Super Mario Sunshine. He kidnaps Peach and calls her Mama.",
                "level": "Beginner"
            },
            {
                "title": "Clown Cannon (Neutral Special)",
                "content": "This move fires a cannonball from the Junior Clown Car. The longer this attack is charged, the faster and more powerful it will be.",
                "level": "Beginner"
            },
            {
                "title": "Clown Kart Dash (Side Special)",
                "content": "The Junior Clown Car becomes a kart and charges forward. The higher the speed, the more damage it will deal.",
                "level": "Beginner"
            },
            {
                "title": "Clown Kart Dash and Jump (Side Special)",
                "content": "Input a jump while performing this, and you'll cancel the dash. This can be handy for recovery, as a lead-in to other moves, or as a feint.",
                "level": "Intermediate"
            },
            {
                "title": "Abandon Ship (Up Special)",
                "content": "Bowser Jr. abandons his Junior Clown Car and performs a massive leap. After a short delay, the abandoned vehicle will self-destruct.",
                "level": "Beginner"
            },
            {
                "title": "Abandon Ship, then Hammer Attack",
                "content": "After leaping out of the Junior Clown Car, Bowser Jr. can swing a hammer with the neutral-attack button. This attack is great for launching.",
                "level": "Intermediate"
            },
            {
                "title": "Mechakoopa (Down Special)",
                "content": "The Junior Clown Car spits out a Mechakoopa that explodes on contact with an enemy. It'll explode if you just leave it alone for a while too.",
                "level": "Beginner"
            },
            {
                "title": "Picking Up Mechakoopa (Down Special)",
                "content": "After taking out a Mechakoopa, Bowser Jr. can pick it back up himself. It's a versatile tool that can be used in a variety of ways to corner foes.",
                "level": "Intermediate"
            },
            {
                "title": "Shadow Mario Paint (Final Smash)",
                "content": "Shadow Mario paints a big X across the screen. If opponents touch the X, they'll receive damage and be launched. Bowser Jr. can move around after painting, so follow up with an attack!",
                "level": "Beginner"
            },
            {
                "title": "Smash Twin Drills (Side Smash Attack)",
                "content": "Bowser Jr.'s side smash can hit multiple times, making it hard to dodge. Even if the attack is blocked by a shield, Bowser Jr. isn't left vulnerable, so it's hard for the opponent to counter.",
                "level": "Beginner"
            },
            {
                "title": "Junior Clown Car",
                "content": "The Junior Clown Car takes less damage than Bowser Jr.'s body. When you're under attack, try to get the opponent to hit the Junior Clown Car instead of Bowser Jr.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "58",
                "name": "Bowser Jr.",
                "slug": "bowser-jr",
                "also_appears_in": [
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
