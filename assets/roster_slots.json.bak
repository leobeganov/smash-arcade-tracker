        ],
        "variants": [
            {
                "name": "Pac-Man",
                "boxing_ring_title": "The Yellow Bane of Ghosts",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "PAC-MAN's Origins",
                "content": "PAC-MAN made his debut in 1980. His debut title was later recognized by Guinness World Records as the \"Most Successful Coin-Operated Arcade Game.\"",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "PAC-MAN, released in 1980, is both the name of the arcade game and its main character. In that game, PAC-MAN navigates a maze, dodging ghosts while trying to gobble up Power Pellets.",
                "level": "Beginner"
            },
            {
                "title": "Cutscene Easter Egg",
                "content": "In PAC-MAN, players were rewarded with an intermission after clearing a set number of rounds. In one of them, Blinky shows a little bit of...leg?!",
                "level": "Beginner"
            },
            {
                "title": "Highscore Battle",
                "content": "If you got a perfect score on all 256 stages, the highest score you could get would be 3,333,360 points. Once you get a perfect score, it's time to start racing your friends!",
                "level": "Beginner"
            },
            {
                "title": "Cherry Bonus Fruit (Neutral Special)",
                "content": "Cherries fly in a low arc. After hitting the floor, they'll bounce only once.",
                "level": "Intermediate"
            },
            {
                "title": "Orange Bonus Fruit (Neutral Special)",
                "content": "Oranges don't deal much damage, but they fly straight and at high speed, making it pretty easy to hit foes with them.",
                "level": "Intermediate"
            },
            {
                "title": "Strawberry Bonus Fruit (Neutral Special)",
                "content": "PAC-MAN's strawberry flies a little farther than other fruit and bounces twice when it lands.",
                "level": "Intermediate"
            },
            {
                "title": "Melon Bonus Fruit (Neutral Special)",
                "content": "PAC-MAN's melon moves slowly through the air, making it difficult to hit opponents. But when it does hit, it deals big damage.",
                "level": "Intermediate"
            },
            {
                "title": "Apple Bonus Fruit (Neutral Special)",
                "content": "PAC-MAN's apple bounces repeatedly across the ground. It travels quite a distance!",
                "level": "Intermediate"
            },
            {
                "title": "Key Bonus...Fruit? (Neutral Special)",
                "content": "The key flies forward at high speed while spinning. It deals the most damage of all the Bonus Fruit items.",
                "level": "Intermediate"
            },
            {
                "title": "Boss Galaxian (Neutral Special)",
                "content": "The Boss Galaxian Bonus Fruit moves forward a little, twirls around once, and continues forward. It's great for combos since it can hit the same opponent at least two times.",
                "level": "Beginner"
            },
            {
                "title": "Bell Bonus Fruit (Neutral Special)",
                "content": "The Bell Bonus Fruit can stun opponents. It's a great opportunity to follow up with a smash attack or a powerful move.",
                "level": "Beginner"
            },
            {
                "title": "Canceling Bonus Fruit (Neutral Special)",
                "content": "You can cancel charging Bonus Fruit with a jump or by shielding. Press and hold the button again to resume charging. However, if you press and release the button immediately, you will throw the fruit.",
                "level": "Beginner"
            },
            {
                "title": "Power Pellet (Side Special)",
                "content": "If an opponent attacks the Power Pellet, this attack will be canceled. It's a useful move for recovery, but be careful when foes are around!",
                "level": "Beginner"
            },
            {
                "title": "Pac-Jump (Up Special)",
                "content": "This move sets up a trampoline for PAC-MAN to jump on. If you jump on it repeatedly, you'll go higher with each bounce!",
                "level": "Beginner"
            },
            {
                "title": "Fire Hydrant (Down Special)",
                "content": "PAC-MAN places a fire hydrant on the ground. The water that it spurts will push fighters back.",
                "level": "Beginner"
            },
            {
                "title": "Aerial Fire Hydrant (Down Special)",
                "content": "If you use this attack in the air, the falling hydrant itself becomes a form of attack. Try dropping it on an opponent trying to return to the stage!",
                "level": "Intermediate"
            },
            {
                "title": "Attack Using Fire Hydrant (Down Special)",
                "content": "The water that sprays from the hydrant will even push PAC-MAN himself. You can use this to sneak up on a foe while charging an attack!",
                "level": "Intermediate"
            },
            {
                "title": "Tumbling Fire Hydrant (Down Special)",
                "content": "If you drop a hydrant on a steep slope, it'll go tumbling down. The tumbling hydrant can deal damage to enemies it hits.",
                "level": "Intermediate"
            },
            {
                "title": "Launching Fire Hydrant (Down Special)",
                "content": "The direction the fire hydrant is launched depends on the last move that hits it. Try to learn what moves make the fire hydrant fly in certain directions.",
                "level": "Intermediate"
            },
            {
                "title": "Super PAC-MAN (Final Smash)",
                "content": "A Final Smash where PAC-MAN becomes Super PAC-MAN and eats opponents to launch them. He'll loop around the other side of the screen and speed up as time goes on!",
                "level": "Beginner"
            },
            {
                "title": "PAC Dash Bite (Dash Attack)",
                "content": "Opponents can easily predict this move since it travels straight forward, but the move doesn't leave you vulnerable to attack, so it's safe to use almost anytime.",
                "level": "Intermediate"
            },
            {
                "title": "About the Trampoline",
                "content": "The durability of the trampoline will be reduced when attacked by other fighters. The more powerful the attack, the more the durability will suffer.",
                "level": "Intermediate"
            }
        ],
        "fighters": [
            {
                "id": "55",
                "name": "Pac-Man",
                "slug": "pac-man",
                "also_appears_in": [
                    "3DS",
                    "Wii U"
                ]
            }
        ]
    },
    {
