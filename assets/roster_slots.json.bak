            {
                "name": "Pichu",
                "boxing_ring_title": "Shockingly Adorable",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Pichu's Origins",
                "content": "Pichu debuted in Pokémon Gold and Silver, released in North America in 2000. If you leave two Pikachu or two Raichu of the opposite sex at the Daycare, Pichu can hatch from the Egg that is found.",
                "level": "Beginner"
            },
            {
                "title": "In Its Series",
                "content": "Pichu isn't a professional at charging electricity like Pikachu. The slightest touch can make Pichu discharge its electricity and shock itself.",
                "level": "Beginner"
            },
            {
                "title": "Thunder Jolt (Neutral Special)",
                "content": "Pichu's Thunder Jolt is smaller, faster, and stronger than Pikachu's, but it also does damage to Pichu.",
                "level": "Beginner"
            },
            {
                "title": "Skull Bash (Side Special)",
                "content": "It takes a while to charge up to the max, but the power unleashed at max is incredibly powerful. This comes at a risk of self-destructing from the force.",
                "level": "Beginner"
            },
            {
                "title": "Agility (Up Special)",
                "content": "Pichu's up special travels farther than Pikachu's, but it causes Pichu to take damage, and it doesn't deal damage to opponents on contact.",
                "level": "Beginner"
            },
            {
                "title": "Thunder (Down Special)",
                "content": "A lightning strike from above that unleashes a bolt of electricity. If the bolt hits Pichu, Pichu will take damage.",
                "level": "Beginner"
            },
            {
                "title": "Volt Tackle (Final Smash)",
                "content": "Become an electric ball and bounce around the screen. It does more damage and has more launch power than Pikachu's Final Smash, but it also does a lot of damage to Pichu.",
                "level": "Beginner"
            },
            {
                "title": "Damage from Electricity",
                "content": "Any move where Pichu is engulfed in electricity will deal damage to Pichu. However, Pichu's moves also have significant power and are great for launching opponents.",
                "level": "Beginner"
            },
            {
                "title": "The Three Lightest Fighters",
                "content": "#1 is Pichu, #2 is Jigglypuff, and #3 is Mr. Game & Watch and Squirtle. Light fighters are easy to launch but can easily escape from combos.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "19",
                "name": "Pichu",
                "slug": "pichu",
                "also_appears_in": [
                    "Melee"
                ]
            }
        ]
    },
