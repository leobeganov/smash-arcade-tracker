        "variants": [
            {
                "name": "Falco",
                "boxing_ring_title": "The Proud Space Ace",
                "type": "Default"
            }
        ],
        "tips": [
            {
                "title": "Falco's Origins",
                "content": "Falco debuted alongside Fox in the 1993 SNES title Star Fox. He may be hotheaded and a little cocky, but his skills are the real deal.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Falco—full name Falco Lombardi—has appeared in Star Fox games starting with the first one, Star Fox. He's as skilled an Arwing pilot as Fox. His design is based on a pheasant.",
                "level": "Beginner"
            },
            {
                "title": "Blaster (Neutral Special)",
                "content": "Unlike Fox's Blaster, Falco's Blaster can make opponents flinch. It fires faster when airborne.",
                "level": "Beginner"
            },
            {
                "title": "Additional Attacks with Blaster (Neutral Special)",
                "content": "After throwing an opponent up, down, or backward, you can follow up with a shot from Blaster. If the opponent has already taken a lot of damage, the shot might not hit them, though.",
                "level": "Intermediate"
            },
            {
                "title": "Falco Phantasm (Side Special)",
                "content": "Falco Phantasm can send an airborne enemy straight down—use it to dunk them into the abyss!",
                "level": "Advanced"
            },
            {
                "title": "Low Air Phantasm (Side Special)",
                "content": "You can use Falco Phantasm at low altitude by jumping while running and immediately pressing the special-move button. I hear he prefers the air, anyway.",
                "level": "Advanced"
            },
            {
                "title": "Fire Bird (Up Special)",
                "content": "Inertia affects this move more than it affects Fox's Fire Fox. If you use it while moving horizontally in midair, you'll slide along in midair for a moment.",
                "level": "Intermediate"
            },
            {
                "title": "Reflector (Down Special)",
                "content": "The energy shield can be used to slow an opponent down in addition to reflecting projectiles.",
                "level": "Intermediate"
            },
            {
                "title": "Team Star Fox (Final Smash)",
                "content": "Falco jumps into a fighter craft called an Arwing and joins Team Star Fox for a full-on assault. Falco's line changes depending on if he's attacking one opponent or a group of opponents.",
                "level": "Beginner"
            },
            {
                "title": "Tail Cutter (Down Tilt Attack)",
                "content": "This move can launch an enemy off the stage with one hit if their damage is high enough. You're not left vulnerable, so it's a low-risk way to KO foes.",
                "level": "Intermediate"
            },
            {
                "title": "Spinning Falco Chop (Neutral Air Attack)",
                "content": "If you land just before the final attack in Falco's midair combo, you can move straight into a neutral combo on the ground.",
                "level": "Advanced"
            },
            {
                "title": "Corkscrew Meteor (Down Air Attack)",
                "content": "Compared to Fox, the move is slow to attack and doesn't hit multiple times, but the first kick has a meteor effect.",
                "level": "Beginner"
            },
            {
                "title": "The Three Highest Jumpers",
                "content": "#1 is Falco, #2 is Greninja, and #3 is Zero Suit Samus. The difference was very slight, but it was enough to place Luigi as #4.",
                "level": "Beginner"
            }
        ],
        "fighters": [
