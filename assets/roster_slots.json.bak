            },
            {
                "slot": 8,
                "variant": "Student",
                "image": "https://pub-2e66ebfa40554bb697519d28926cd04c.r2.dev/roster-slots/joker/main8.png"
            }
        ],
        "variants": [
            {
                "name": "Phantom Thief",
                "boxing_ring_title": "The Great Phantom Thief",
                "type": "Same character"
            },
            {
                "name": "Student",
                "boxing_ring_title": "The Great Phantom Thief",
                "type": "Same character"
            }
        ],
        "tips": [
            {
                "title": "Joker's Origins",
                "content": "Joker made his debut in Persona 5, released in 2017. He's a young man with a strong sense of justice and is the leader of the Phantom Thieves of Hearts, a group who changes the hearts of evildoers.",
                "level": "Beginner"
            },
            {
                "title": "In His Series",
                "content": "Joker transferred to Shujin Academy after a certain incident and then acquired Persona skills. While in his thief form, he gives off a different vibe than his usual personality.",
                "level": "Beginner"
            },
            {
                "title": "Gun / Gun Special (Neutral Special)",
                "content": "Joker quickly fires a gun with his left hand. Press the button repeatedly or hold it to fire continuously. While Arsene is summoned, the number of shots fired and the power of the shots increases.",
                "level": "Beginner"
            },
            {
                "title": "Jumping during Gun / Gun Special (Neutral Special)",
                "content": "If you press the jump button immediately after firing your gun on the ground, you'll jump into the air and shoot straight down. You can also use the stick to move left and right in the air.",
                "level": "Intermediate"
            },
            {
                "title": "Dodging during Gun / Gun Special (Neutral Special)",
                "content": "While holding the special-move button to fire your gun, quickly flick the stick to the left or right to make Joker dodge while continuing to fire.",
                "level": "Beginner"
            },
            {
                "title": "Vulnerability While Gun Dodging (Neutral Special)",
                "content": "Dodging while shooting makes you invincible for a shorter time than a normal dodge, and repeated dodging will slow your reaction time and leave you even more vulnerable.",
                "level": "Beginner"
            },
            {
                "title": "Gun / Gun Special in the Air (Neutral Special)",
                "content": "Once you fire a shot in the air, tilt the stick up and press the button to fire rapidly. If you tilt the stick down and press the button, you can continue your move by shooting downward.",
                "level": "Intermediate"
            },
            {
                "title": "Eiha (Side Special)",
                "content": "Fire a bolt that explodes and deals continuous damage. If the bolt hits an opponent, it will knock the opponent into the air.",
                "level": "Beginner"
            },
            {
                "title": "Eigaon (Side Special)",
                "content": "While Arsene is summoned, Joker will use Eigaon, which is bigger and faster than Eiha and also has more launch power and higher continuous damage. When it hits the terrain, it explodes.",
                "level": "Beginner"
            },
            {
                "title": "Eiha/Eigaon Damage (Side Special)",
                "content": "The continuous damage after the bolt explodes is greater than the damage of hitting an opponent with the bolt itself.",
                "level": "Intermediate"
            },
            {
                "title": "Grappling Hook (Up Special)",
                "content": "Shoot a grappling hook diagonally upward. If it hits an opponent, they'll be pulled closer and thrown. If it hits an edge while you're in midair, you'll cling to the edge. If it hits an item, you'll pull it toward you.",
                "level": "Beginner"
            },
            {
                "title": "Wings of Rebellion (Up Special)",
                "content": "When Arsene is summoned, you can use Wings of Rebellion to fly upward a long distance. It has great range, but it can't be used to attack.",
                "level": "Beginner"
            },
            {
                "title": "Wings of Rebellion and Moving Left and Right (Up Special)",
                "content": "If you tilt the stick left or right before rising up, you can slightly change the angle of ascent. Tilting the stick while falling will allow you to move slightly as well.",
                "level": "Intermediate"
            },
            {
                "title": "Rebel's Guard (Down Special)",
                "content": "Joker will pose once using the move and take a hit from the opponent. You will take less damage from the attack, and your Rebellion Gauge will fill up greatly.",
                "level": "Beginner"
            },
            {
                "title": "After Rebel's Guard (Down Special)",
                "content": "Press and hold the button to extend the duration of the move. Once you're hit with an attack, release the button to unleash a force that pushes opponents.",
                "level": "Beginner"
            },
            {
                "title": "Tetrakarn / Makarakarn (Down Special)",
                "content": "A move that can be used while Arsene is summoned. You can counter direct attacks from opponents with Tetrakarn. Projectiles will be reflected with Makarakarn.",
                "level": "Beginner"
            },
            {
                "title": "All-Out Attack (Final Smash)",
                "content": "Joker dashes forward to attack. If it hits an opponent, the Phantom Thieves will perform an All-Out Attack. There are two versions and different members will appear. There are also six different spoken lines.",
                "level": "Beginner"
            },
            {
                "title": "Charging with All-Out Attack (Final Smash)",
                "content": "You can hit up to four opponents with the initial dash forward. Even if it doesn't hit anyone, you can tilt the stick the opposite direction immediately after missing to dash the other way.",
                "level": "Intermediate"
            },
            {
                "title": "End the Battle with an All-Out Attack (Final Smash)",
                "content": "If an opponent is damaged enough by the end of the attack, they'll be instantly KO'd. If you end the battle with this KO, you might get to see a special cinematic.",
                "level": "Beginner"
            },
            {
                "title": "Down Air Attack",
                "content": "While Arsene is summoned, your down air attack gains a meteor effect.",
                "level": "Intermediate"
            },
            {
                "title": "Rebellion Gauge",
                "content": "If you receive damage or get hit while using Rebel's Guard, the Rebellion Gauge will fill up. Once it's full, Joker will summon Arsene. Your special moves will change, and your attacks will be stronger.",
                "level": "Beginner"
            },
            {
                "title": "Rebellion Gauge and Arsene",
                "content": "While Arsene is present, the Rebellion Gauge will not charge. The gauge will deplete as time passes or if Joker takes damage, and once it's completely empty, Arsene will exit the scene.",
                "level": "Beginner"
            },
            {
                "title": "Rebellion Gauge in Team Battle",
                "content": "When your teammates are damaged or KO'd during Team Battle, the Rebellion Gauge will fill a little bit.",
                "level": "Intermediate"
            },
            {
                "title": "Special Cinematics for When Arsene Is Summoned",
                "content": "When it's 1 vs. 1 or the opponent is a CPU, there is a cut-in when Arsene appears.",
                "level": "Beginner"
            }
        ],
        "fighters": [
            {
                "id": "71",
                "name": "Joker",
                "slug": "joker",
                "also_appears_in": []
            }
        ]
    },
